@model IEnumerable<HDKmall.Models.Coupon>
@{
    ViewData["Title"] = "Quản lý mã giảm giá";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-section">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-size:18px; font-weight:700;">Quản lý mã giảm giá</h2>
        
        <form asp-controller="Coupon" asp-action="Index" method="get" class="d-flex">
            <input type="text" name="q" class="form-control me-2" placeholder="Tìm mã giảm giá..." />
            <button type="submit" class="btn btn-outline-primary">Tìm </button>
        </form>

        <a asp-area="Admin" asp-controller="Coupon" asp-action="Create" class="btn btn-primary btn-sm">+ Thêm mã mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">#</th>
                    <th>Mã</th>
                    <th>Giảm giá</th>
                    <th>Hết hạn</th>
                    <th>Đã dùng / Giới hạn</th>
                    <th class="pe-3 text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var coupon in Model)
                    {
                        var expired = coupon.ExpiryDate < DateTime.Now;
                        <tr>
                            <td class="ps-3">@coupon.Id</td>
                            <td class="fw-bold font-monospace">@coupon.Code</td>
                            <td class="text-danger fw-bold">@coupon.DiscountAmount.ToString("N0")₫</td>
                            <td>
                                @coupon.ExpiryDate.ToString("dd/MM/yyyy")
                                @if (expired)
                                {
                                    <span class="badge bg-danger ms-1">Hết hạn</span>
                                }
                            </td>
                            <td>@coupon.UsedCount / @coupon.UsageLimit</td>
                            <td class="pe-3 text-center">
                                <a asp-area="Admin" asp-controller="Coupon" asp-action="Edit" asp-route-id="@coupon.Id" class="btn btn-sm btn-outline-primary me-1">Sửa</a>
                                <form asp-area="Admin" asp-controller="Coupon" asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa mã giảm giá này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@coupon.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center py-4 text-muted">Chưa có mã giảm giá nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
