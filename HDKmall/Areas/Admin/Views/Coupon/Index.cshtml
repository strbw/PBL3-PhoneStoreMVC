@model IEnumerable<HDKmall.Models.Coupon>
@{
    ViewData["Title"] = "Quản lý mã giảm giá";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🎟️ Quản lý Mã Giảm Giá</h2>
    <a asp-area="Admin" asp-controller="Coupon" asp-action="Create" class="btn btn-danger text-white fw-bold shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Mã Mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả mã giảm giá</h5>
        <form asp-area="Admin" asp-controller="Coupon" asp-action="Index" method="get" class="d-flex" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control bg-light border-start-0 rounded-end-pill focus-ring focus-ring-danger" placeholder="Tìm mã giảm giá..." />
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Mã Coupon</th>
                        <th class="py-3 border-0 text-end">Giảm Giá</th>
                        <th class="py-3 border-0">Hết Hạn</th>
                        <th class="py-3 border-0">Sử Dụng</th>
                        <th class="py-3 border-0">Trạng Thái</th>
                        <th class="px-4 py-3 border-0 text-end">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var coupon in Model)
                        {
                            var expired = coupon.ExpiryDate < DateTime.Now;
                            var usageFull = coupon.UsedCount >= coupon.UsageLimit;
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@coupon.Id</td>
                                <td>
                                    <span class="badge bg-dark bg-opacity-10 text-dark border border-dark-subtle font-monospace px-3 py-2 rounded-3 fs-6 fw-bold">
                                        @coupon.Code
                                    </span>
                                </td>
                                <td class="text-end fw-bold text-danger">@coupon.DiscountAmount.ToString("N0") ₫</td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-medium">@coupon.ExpiryDate.ToString("dd/MM/yyyy")</span>
                                        @if (expired)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle rounded-pill px-2 mt-1" style="width:fit-content;">
                                                <i class="bi bi-clock-history me-1" style="font-size:10px;"></i>Hết hạn
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:6px; max-width:80px;">
                                            @{
                                                var usedPct = coupon.UsageLimit > 0 ? (int)Math.Min(100, coupon.UsedCount * 100 / coupon.UsageLimit) : 0;
                                                var barColor = usageFull ? "bg-danger" : (usedPct > 70 ? "bg-warning" : "bg-success");
                                            }
                                            <div class="progress-bar @barColor" style="width:@usedPct%"></div>
                                        </div>
                                        <span class="text-muted small">@coupon.UsedCount/@coupon.UsageLimit</span>
                                    </div>
                                </td>
                                <td>
                                    @if (expired)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1 rounded-pill">
                                            <i class="bi bi-x-circle me-1" style="font-size:10px;"></i>Hết hạn
                                        </span>
                                    }
                                    else if (usageFull)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle px-2 py-1 rounded-pill">
                                            <i class="bi bi-dash-circle me-1" style="font-size:10px;"></i>Đã dùng hết
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1 rounded-pill">
                                            <i class="bi bi-check-circle me-1" style="font-size:10px;"></i>Còn hiệu lực
                                        </span>
                                    }
                                </td>
                                <td class="px-4 text-end">
                                    <a asp-area="Admin" asp-controller="Coupon" asp-action="Edit" asp-route-id="@coupon.Id"
                                       class="btn btn-sm btn-light text-primary border shadow-sm rounded-3 me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-area="Admin" asp-controller="Coupon" asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa mã giảm giá này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@coupon.Id" />
                                        <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">🎟️</div>
                                <h5>Chưa có mã giảm giá nào</h5>
                                <p>Hãy tạo mã giảm giá đầu tiên để thu hút khách hàng!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center rounded-bottom-4">
        <span class="text-muted small">Hiển thị @Model?.Count() mã giảm giá</span>
    </div>
</div>
