@model IEnumerable<HDKmall.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🖼️ Quản Lý Banner</h2>
    <a asp-area="Admin" asp-controller="Banner" asp-action="Create" class="btn btn-danger text-white fw-bold shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Banner Mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả banner</h5>
        <form asp-controller="Banner" asp-action="Index" method="get" class="d-flex" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" value="@ViewBag.Search" class="form-control bg-light border-start-0 rounded-end-pill" placeholder="Tìm tiêu đề banner..." />
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Hình ảnh</th>
                        <th class="py-3 border-0">Tiêu đề</th>
                        <th class="py-3 border-0">Link</th>
                        <th class="py-3 border-0 text-center">Trạng thái</th>
                        <th class="px-4 py-3 border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var banner in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@banner.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(banner.ImageUrl))
                                    {
                                        <img src="@banner.ImageUrl" alt="@banner.Title"
                                             class="rounded-3 shadow-sm border"
                                             style="width: 80px; height: 50px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded-3 bg-light border d-flex align-items-center justify-content-center"
                                             style="width:80px; height:50px; font-size:20px; color:#ccc;">🖼️</div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@(banner.Title ?? "(Không có tiêu đề)")</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                    {
                                        <a href="@banner.LinkUrl" target="_blank" class="text-muted small text-decoration-none" style="max-width:200px; display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @banner.LinkUrl
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (banner.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1 rounded-pill">Hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-2 py-1 rounded-pill">Ẩn</span>
                                    }
                                </td>
                                <td class="px-4 text-end">
                                    <a asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@banner.Id"
                                       class="btn btn-sm btn-light text-primary border shadow-sm rounded-3 me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-area="Admin" asp-controller="Banner" asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa banner này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@banner.Id" />
                                        <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">🖼️</div>
                                <h5>Chưa có banner nào</h5>
                                <p>Hãy thêm banner đầu tiên!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">Hiển thị @Model?.Count() banner</span>
    </div>
</div>

