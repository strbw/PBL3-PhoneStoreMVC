@model IEnumerable<HDKmall.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🖼️ Quản lý Banner</h2>
    <a asp-area="Admin" asp-controller="Banner" asp-action="Create" class="btn btn-danger text-white fw-bold shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Banner Mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả banner</h5>
        <form asp-area="Admin" asp-controller="Banner" asp-action="Index" method="get" class="d-flex" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control bg-light border-start-0 rounded-end-pill" placeholder="Tìm banner..." />
            </div>
        </form>
    </div>

    <div class="card-body px-4 pb-4 pt-2">
        @if (Model != null && Model.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var banner in Model)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden banner-card">
                            @if (!string.IsNullOrEmpty(banner.ImageUrl))
                            {
                                <div class="banner-img-wrapper" style="height:180px; overflow:hidden; position:relative;">
                                    <img src="@banner.ImageUrl" alt="@banner.Title"
                                         style="width:100%; height:100%; object-fit:cover; transition: transform 0.3s ease;" class="banner-img" />
                                    <div class="banner-overlay" style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 60%);"></div>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-light rounded-top-4" style="height:180px;">
                                    <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                                </div>
                            }
                            <div class="card-body pb-2">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0 text-dark" style="max-width:200px;">@(banner.Title ?? "(Không có tiêu đề)")</h6>
                                    @if (banner.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle px-2">
                                            <i class="bi bi-eye-fill me-1" style="font-size:10px;"></i>Hiển thị
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-2">
                                            <i class="bi bi-eye-slash-fill me-1" style="font-size:10px;"></i>Ẩn
                                        </span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                {
                                    <p class="text-muted small mb-0 text-truncate">
                                        <i class="bi bi-link-45deg me-1"></i>@banner.LinkUrl
                                    </p>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0"><i class="bi bi-link-45deg me-1"></i>Chưa có đường dẫn</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent border-0 d-flex gap-2 pt-0 px-3 pb-3">
                                <a asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@banner.Id"
                                   class="btn btn-sm btn-light text-primary border shadow-sm rounded-3 flex-fill">
                                    <i class="bi bi-pencil-square me-1"></i>Sửa
                                </a>
                                <form asp-area="Admin" asp-controller="Banner" asp-action="Delete" method="post" class="d-inline flex-fill"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa banner này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@banner.Id" />
                                    <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3 w-100">
                                        <i class="bi bi-trash me-1"></i>Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <div class="fs-1 mb-3">🖼️</div>
                <h5>Chưa có banner nào</h5>
                <p>Hãy thêm banner đầu tiên để trang trí cửa hàng!</p>
                <a asp-area="Admin" asp-controller="Banner" asp-action="Create" class="btn btn-danger rounded-pill px-4 mt-2">
                    <i class="bi bi-plus-circle me-1"></i>Thêm Banner
                </a>
            </div>
        }
    </div>

    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center rounded-bottom-4">
        <span class="text-muted small">Hiển thị @Model?.Count() banner</span>
    </div>
</div>

<style>
    .banner-card:hover .banner-img { transform: scale(1.05); }
    .banner-card { transition: box-shadow 0.2s; }
    .banner-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.12) !important; }
</style>
