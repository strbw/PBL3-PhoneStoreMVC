@model HDKmall.Models.Banner
@{
    ViewData["Title"] = "Sửa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🖼️ Sửa Banner</h2>
    <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4 fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger shadow-sm border-0 rounded-3">
        <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Vui lòng kiểm tra lại:</div>
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-info-circle me-2"></i>Thông tin banner</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-bold text-muted small">Tiêu đề</label>
                            <input asp-for="Title" class="form-control bg-light border-0" id="bannerTitle" placeholder="Nhập tiêu đề banner..." />
                            <span asp-validation-for="Title" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="LinkUrl" class="form-label fw-bold text-muted small">Đường dẫn khi click</label>
                            <input asp-for="LinkUrl" class="form-control bg-light border-0" id="bannerLink" placeholder="VD: /Product hoặc https://..." />
                            <span asp-validation-for="LinkUrl" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-bold text-muted small">Hiển thị banner</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-images me-2"></i>Hình ảnh banner</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Upload ảnh mới (bỏ qua nếu không đổi)</label>
                        <div class="p-4 border border-dashed rounded-3 bg-light text-center">
                            <i class="bi bi-cloud-arrow-up text-primary fs-1"></i>
                            <p class="text-muted mb-2 mt-2">Kéo thả hoặc chọn file ảnh</p>
                            <input asp-for="ImageFile" type="file" class="form-control bg-white" accept="image/*" id="bannerFile" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold text-muted small">URL ảnh hiện tại</label>
                        <input asp-for="ImageUrl" class="form-control bg-light border-0" id="bannerUrl" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger small mt-1"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-eye me-2"></i>Xem trước</h5>
                </div>
                <div class="card-body p-4">
                    <div style="background:#f8f9fa; border-radius:10px; overflow:hidden; min-height:160px; position:relative;">
                        <img id="bannerPreviewImage"
                             data-preview-src="@Model.ImageUrl"
                             src="@Model.ImageUrl"
                             style="width:100%; max-height:200px; object-fit:cover; @(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")"
                             class="rounded-3" />
                        <div class="p-3">
                            <div class="fw-bold text-dark" id="bannerPreviewTitle" style="font-size:15px;">@(Model.Title ?? "(Tiêu đề banner)")</div>
                            <div class="text-muted small" id="bannerPreviewLink">@(Model.LinkUrl ?? "(Link)")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <button type="submit" class="btn btn-danger text-white fw-bold w-100 rounded-pill mb-2">
                        <i class="bi bi-check-circle me-1"></i> Cập nhật Banner
                    </button>
                    <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-light border w-100 rounded-pill">Hủy</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function updateBannerPreview() {
            const url = document.getElementById('bannerUrl').value;
            const title = document.getElementById('bannerTitle').value;
            const link = document.getElementById('bannerLink').value;
            document.getElementById('bannerPreviewTitle').innerText = title || "(Tiêu đề banner)";
            document.getElementById('bannerPreviewLink').innerText = link || "(Link)";
            if (url) {
                const img = document.getElementById('bannerPreviewImage');
                img.src = url;
                img.setAttribute('data-preview-src', url);
                img.style.display = 'block';
            }
        }
        document.getElementById('bannerUrl').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerTitle').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerLink').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerFile').addEventListener('change', function () {
            const img = document.getElementById('bannerPreviewImage');
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    img.src = e.target.result;
                    img.setAttribute('data-preview-src', e.target.result);
                    img.style.display = 'block';
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}
