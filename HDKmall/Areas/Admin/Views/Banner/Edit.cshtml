@model HDKmall.Models.Banner
@{
    ViewData["Title"] = "Sửa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-section" style="max-width:520px;">
    <h2 style="font-size:18px; font-weight:700; margin-bottom:20px;">Sửa banner</h2>

    <form asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label fw-medium">URL ảnh *</label>
            <input asp-for="ImageUrl" class="form-control" id="bannerUrl" />
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-medium">Upload ảnh mới</label>
            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" id="bannerFile" />
        </div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label fw-medium">Tiêu đề</label>
            <input asp-for="Title" class="form-control" id="bannerTitle" />
        </div>

        <div class="mb-3">
            <label asp-for="LinkUrl" class="form-label fw-medium">Đường dẫn khi click</label>
            <input asp-for="LinkUrl" class="form-control" id="bannerLink" />
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label fw-medium">Hiển thị banner</label>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-bold">Preview</div>
            <div class="card-body">
                <img id="bannerPreviewImage"
                     data-preview-src="@Model.ImageUrl"
                     src="@Model.ImageUrl"
                     style="max-height:140px;object-fit:cover" class="rounded" />
                <div class="fw-bold mt-2" id="bannerPreviewTitle">@Model.Title</div>
                <div class="text-muted" id="bannerPreviewLink">@Model.LinkUrl</div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function updateBannerPreview() {
            const url = document.getElementById('bannerUrl').value;
            const title = document.getElementById('bannerTitle').value;
            const link = document.getElementById('bannerLink').value;

            document.getElementById('bannerPreviewTitle').innerText = title || "(Tiêu đề)";
            document.getElementById('bannerPreviewLink').innerText = link || "(Link)";

            if (url) {
                const img = document.getElementById('bannerPreviewImage');
                img.src = url;
               img.setAttribute('data-preview-src', url);
                img.style.opacity = "1";
            }
        }

        document.getElementById('bannerUrl').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerTitle').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerLink').addEventListener('input', updateBannerPreview);

        document.getElementById('bannerFile').addEventListener('change', function () {
            const img = document.getElementById('bannerPreviewImage');
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    img.src = e.target.result;
                    img.setAttribute('data-preview-src', e.target.result); 
            img.style.opacity = "1";
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}