@model HDKmall.Models.Banner
@{
    ViewData["Title"] = "Sửa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-section" style="max-width:520px;">
    <h2 style="font-size:18px; font-weight:700; margin-bottom:20px;">Sửa banner</h2>

    <form asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label fw-medium">URL ảnh *</label>
            <input asp-for="ImageUrl" class="form-control" />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="mt-2 rounded" style="max-height:120px; object-fit:cover;" alt="preview" />
            }
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Title" class="form-label fw-medium">Tiêu đề</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="LinkUrl" class="form-label fw-medium">Đường dẫn khi click</label>
            <input asp-for="LinkUrl" class="form-control" />
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label fw-medium">Hiển thị banner</label>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>
