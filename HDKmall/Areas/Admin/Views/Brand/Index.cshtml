@model IEnumerable<HDKmall.Models.Brand>

@{
    ViewData["Title"] = "Quản lý Thương hiệu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🏆 Quản lý Thương hiệu</h2>
    <a asp-action="Create" class="btn btn-danger text-white fw-bold shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Thương hiệu mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Tên Thương hiệu</th>
                        <th class="py-3 border-0">Mô tả</th>
                        <th class="px-4 py-3 border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@item.Id</td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td class="text-muted">@item.Description</td>
                                <td class="px-4 text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border shadow-sm rounded-3 me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xoá thương hiệu này?');">
                                        <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xoá">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
