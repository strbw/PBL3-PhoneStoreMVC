@using System.Text.Json
@using HDKmall.Models
@using HDKmall.ViewModels
@model DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row g-4 mb-4">
        <!-- Stat Cards -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary">
                        <i class="bi bi-cart-check-fill fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small uppercase fw-bold">Tổng đơn hàng</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalOrders</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3 text-success">
                        <i class="bi bi-currency-dollar fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small uppercase fw-bold">Doanh thu</h6>
                        <h3 class="mb-0 fw-bold text-success">@Model.TotalRevenue.ToString("N0")₫</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 p-3 rounded-3 me-3 text-info">
                        <i class="bi bi-laptop fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small uppercase fw-bold">Sản phẩm</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalProducts</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3 text-warning">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 small uppercase fw-bold">Người dùng</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalUsers</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Revenue Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Doanh thu 6 tháng gần nhất</h5>
                    <div class="text-muted small">Đơn vị: VNĐ</div>
                </div>
                <div class="card-body px-4 pb-4">
                    <canvas id="revenueChart" height="280"></canvas>
                </div>
            </div>
        </div>
        <!-- Orders by Status -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0 fw-bold">Trạng thái đơn hàng</h5>
                </div>
                <div class="card-body px-4 pb-4 d-flex flex-column">
                    <div style="height: 220px; position: relative;">
                        @if (Model.OrdersByStatus != null && Model.OrdersByStatus.Any())
                        {
                            <canvas id="statusChart"></canvas>
                        }
                        else
                        {
                            <div class="h-100 d-flex align-items-center justify-content-center text-muted small fst-italic">
                                Chưa có dữ liệu trạng thái
                            </div>
                        }
                    </div>
                    <div class="mt-auto pt-4">
                        @if (Model.OrdersByStatus != null && Model.OrdersByStatus.Any())
                        {
                            foreach (var item in Model.OrdersByStatus)
                            {
                                <div class="d-flex justify-content-between mb-1 small">
                                    <span class="text-muted">@(string.IsNullOrEmpty(item.Status) ? "Chưa xác định" : item.Status)</span>
                                    <span class="fw-bold">@item.Count</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Daily Orders -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0 fw-bold">Đơn hàng 7 ngày qua</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <canvas id="dailyOrdersChart" height="200"></canvas>
                </div>
            </div>
        </div>
        <!-- Top Products -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0 fw-bold">🏆 Sản phẩm bán chạy</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 border-0">
                            <thead class="table-light">
                                <tr class="small text-muted">
                                    <th class="ps-4">Tên sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end pe-4">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.TopProducts)
                                {
                                    <tr>
                                        <td class="ps-4 fw-medium small">@p.ProductName</td>
                                        <td class="text-center"><span class="badge bg-light text-dark fw-bold">@p.Quantity</span></td>
                                        <td class="text-end pe-4 text-danger fw-bold small">@p.Revenue.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Orders -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">⚡ Đơn hàng mới nhất</h5>
                    <a href="/Admin/Order" class="btn btn-sm btn-light rounded-pill px-3">Xem tất cả</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr class="small text-muted">
                                    <th class="ps-4">ID</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td class="ps-4 small text-muted">#@order.Id</td>
                                        <td class="fw-medium small">@(order.User?.FullName ?? "Khách")</td>
                                        <td class="small text-muted">@order.OrderDate.ToString("dd/MM/yy")</td>
                                        <td>
                                            <span class="badge @(order.Status switch {
                                                "Pending" => "bg-warning text-dark",
                                                "Processing" => "bg-info text-white",
                                                "Shipping" => "bg-primary text-white",
                                                "Delivered" => "bg-success text-white",
                                                "Cancelled" => "bg-danger text-white",
                                                _ => "bg-secondary text-white"
                                            }) bg-opacity-75 rounded-pill px-2 py-1" style="font-size:10px;">@order.Status</span>
                                        </td>
                                        <td class="text-end pe-4 text-dark fw-bold small">@order.TotalAmount.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <!-- Low Stock Alert -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 border-start border-4 border-danger h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Tồn kho thấp</h5>
                </div>
                <div class="card-body px-4">
                    <div class="vstack gap-3">
                        @foreach (var item in Model.LowStockProducts)
                        {
                            <div class="p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                                <div class="overflow-hidden">
                                    <div class="fw-bold text-truncate small">@item.ProductName</div>
                                    <div class="text-muted small">@item.VariantName</div>
                                </div>
                                <div class="badge bg-danger rounded-pill">@item.Stock</div>
                            </div>
                        }
                        @if (!Model.LowStockProducts.Any())
                        {
                            <div class="text-center text-muted py-4">Tất cả sản phẩm đều đủ hàng.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Common options
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, grid: { borderDash: [2, 2], drawBorder: false } },
                    x: { grid: { display: false } }
                }
            };

            // Helper to safely get data
            function safeData(data) {
                return data || [];
            }

            // 1. Revenue Chart
            try {
                const ctxRevenue = document.getElementById('revenueChart');
                if (ctxRevenue) {
                    new Chart(ctxRevenue, {
                        type: 'line',
                        data: {
                            labels: @Html.Raw(JsonSerializer.Serialize(Model.MonthlyRevenueLabels)),
                            datasets: [{
                                label: 'Doanh thu',
                                data: @Html.Raw(JsonSerializer.Serialize(Model.MonthlyRevenueData)),
                                borderColor: '#0d6efd',
                                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointRadius: 4,
                                pointBackgroundColor: '#0d6efd'
                            }]
                        },
                        options: commonOptions
                    });
                }
            } catch (e) { console.error("Revenue Chart Error:", e); }

            // 2. Daily Orders Chart
            try {
                const ctxDaily = document.getElementById('dailyOrdersChart');
                if (ctxDaily) {
                    new Chart(ctxDaily, {
                        type: 'bar',
                        data: {
                            labels: @Html.Raw(JsonSerializer.Serialize(Model.DailyOrderLabels)),
                            datasets: [{
                                label: 'Đơn hàng',
                                data: @Html.Raw(JsonSerializer.Serialize(Model.DailyOrderData)),
                                backgroundColor: '#dc3545',
                                borderRadius: 6
                            }]
                        },
                        options: commonOptions
                    });
                }
            } catch (e) { console.error("Daily Orders Chart Error:", e); }

            // 3. Status Chart
            try {
                const ctxStatus = document.getElementById('statusChart');
                if (ctxStatus && @(Model.OrdersByStatus != null && Model.OrdersByStatus.Any() ? "true" : "false")) {
                    new Chart(ctxStatus, {
                        type: 'doughnut',
                        data: {
                            labels: @Html.Raw(JsonSerializer.Serialize(Model.OrdersByStatus.Select(x => x.Status ?? "Chờ xử lý").ToList())),
                            datasets: [{
                                data: @Html.Raw(JsonSerializer.Serialize(Model.OrdersByStatus.Select(x => x.Count).ToList())),
                                backgroundColor: ['#ffc107', '#0dcaf0', '#0d6efd', '#198754', '#dc3545', '#6c757d'],
                                borderWidth: 0,
                                hoverOffset: 10
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom', labels: { boxWidth: 12, padding: 15, font: { size: 11 } } }
                            },
                            cutout: '70%'
                        }
                    });
                }
            } catch (e) { console.error("Status Chart Error:", e); }
        });
    </script>
}