@model IEnumerable<HDKmall.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-section">
    <div class="admin-section-header d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-size:18px; font-weight:700;">Quản lý người dùng</h2>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">#</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-3">@(i++)</td>
                            <td class="fw-medium">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td><span class="badge bg-secondary">@(user.Role?.RoleName ?? "-")</span></td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã khóa</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có người dùng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
