@model IEnumerable<HDKmall.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">👥 Quản lý Người Dùng</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Stats -->
@if (Model != null && Model.Any())
{
    var totalUsers  = Model.Count();
    var activeUsers = Model.Count(u => u.IsActive);
    var lockedUsers = Model.Count(u => !u.IsActive);
    var adminCount  = Model.Count(u => u.Role?.RoleName == "Admin");
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:46px;height:46px;flex-shrink:0;">
                        <i class="bi bi-people text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Tổng người dùng</div>
                        <div class="fw-bold fs-5">@totalUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width:46px;height:46px;flex-shrink:0;">
                        <i class="bi bi-person-check text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Hoạt động</div>
                        <div class="fw-bold fs-5">@activeUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 bg-danger bg-opacity-10 d-flex align-items-center justify-content-center" style="width:46px;height:46px;flex-shrink:0;">
                        <i class="bi bi-person-x text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Đã khóa</div>
                        <div class="fw-bold fs-5">@lockedUsers</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="rounded-3 bg-warning bg-opacity-10 d-flex align-items-center justify-content-center" style="width:46px;height:46px;flex-shrink:0;">
                        <i class="bi bi-shield-check text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Quản trị viên</div>
                        <div class="fw-bold fs-5">@adminCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả người dùng</h5>
        <form asp-area="Admin" asp-controller="User" asp-action="Index" method="get" class="d-flex" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control bg-light border-start-0 rounded-end-pill focus-ring focus-ring-danger" placeholder="Tìm tên, email..." />
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Người dùng</th>
                        <th class="py-3 border-0">Email</th>
                        <th class="py-3 border-0">Điện thoại</th>
                        <th class="py-3 border-0">Vai trò</th>
                        <th class="py-3 border-0">Trạng thái</th>
                        <th class="px-4 py-3 border-0">Ngày tham gia</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        int i = 1;
                        foreach (var user in Model)
                        {
                            var isAdmin = user.Role?.RoleName == "Admin";
                            var avatarColors = new[] {
                                "bg-primary", "bg-success", "bg-info", "bg-warning", "bg-danger",
                                "bg-secondary", "bg-dark"
                            };
                            var avatarColor = avatarColors[user.UserId % avatarColors.Length];
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@(i++)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle @avatarColor bg-opacity-15 d-flex align-items-center justify-content-center fw-bold text-dark"
                                             style="width:38px;height:38px;font-size:15px;flex-shrink:0;">
                                             @((user.FullName ?? "?").Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-dark" style="font-size:14px;">@user.FullName</div>
                                            <div class="text-muted" style="font-size:11px;">ID: @user.UserId</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <a href="mailto:@user.Email" class="text-decoration-none text-dark small">
                                        <i class="bi bi-envelope me-1 text-muted"></i>@user.Email
                                    </a>
                                </td>
                                <td>
                                    <form asp-action="UpdateRole" method="post" class="d-flex align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.UserId" />
                                        <select name="roleId" class="form-select form-select-sm border-0 bg-light rounded-pill px-3" onchange="this.form.submit()" style="font-size:12px; width:120px;">
                                            @foreach (var role in (IEnumerable<HDKmall.Models.Role>)ViewBag.Roles)
                                            {
                                                <option value="@role.RoleId" selected="@(user.RoleId == role.RoleId)">@role.RoleName</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="ToggleStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.UserId" />
                                        @if (user.IsActive)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3 border-success-subtle" style="font-size:11px;">
                                                <i class="bi bi-check-circle-fill me-1"></i>Hoạt động
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 border-danger-subtle" style="font-size:11px;">
                                                <i class="bi bi-lock-fill me-1"></i>Đã khóa
                                            </button>
                                        }
                                    </form>
                                </td>
                                <td class="px-4">
                                    <div class="fw-medium small">@user.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size:11px;">@user.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td class="px-4 text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3">
                                            <li><a class="dropdown-item small" href="#"><i class="bi bi-eye me-2"></i>Xem chi tiết</a></li>
                                            <li><a class="dropdown-item small" href="#"><i class="bi bi-pencil me-2"></i>Sửa thông tin</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="ToggleStatus" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@user.UserId" />
                                                    <button type="submit" class="dropdown-item small text-danger">
                                                        <i class="bi @(user.IsActive ? "bi-lock" : "bi-unlock") me-2"></i>@(user.IsActive ? "Khóa tài khoản" : "Mở khóa")
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">👥</div>
                                <h5>Chưa có người dùng nào</h5>
                                <p>Người dùng sẽ xuất hiện tại đây sau khi đăng ký.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center rounded-bottom-4">
        <span class="text-muted small">Hiển thị @(Model?.Count() ?? 0) người dùng</span>
    </div>
</div>
