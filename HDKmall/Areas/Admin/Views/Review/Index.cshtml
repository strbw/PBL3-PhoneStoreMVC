@model IEnumerable<HDKmall.Models.Review>
@{
    ViewData["Title"] = "Quản lý đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">⭐ Quản lý Đánh Giá Sản Phẩm</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả đánh giá</h5>
        <form asp-area="Admin" asp-controller="Review" asp-action="Index" method="get" class="d-flex" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control bg-light border-start-0 rounded-end-pill focus-ring focus-ring-danger" placeholder="Tìm đánh giá..." />
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Sản Phẩm</th>
                        <th class="py-3 border-0">Người Dùng</th>
                        <th class="py-3 border-0">Đánh Giá</th>
                        <th class="py-3 border-0">Nội Dung</th>
                        <th class="py-3 border-0">Ngày</th>
                        <th class="px-4 py-3 border-0 text-end">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var review in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@review.Id</td>
                                <td>
                                    <a href="/Product/Detail/@review.ProductId" class="text-decoration-none fw-semibold text-primary-emphasis"
                                       style="max-width:160px; display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @(review.Product?.Name ?? $"#{review.ProductId}")
                                    </a>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold"
                                             style="width:32px; height:32px; font-size:13px; flex-shrink:0;">
                                            @((review.User?.FullName ?? "?").Substring(0, 1).ToUpper())
                                        </div>
                                        <span class="fw-medium text-dark">@(review.User?.FullName ?? $"#{review.UserId}")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <span style="color:@(s <= review.Rating ? "#ffc107" : "#e0e0e0"); font-size:16px;">★</span>
                                        }
                                        <span class="ms-1 text-muted small fw-medium">(@review.Rating)</span>
                                    </div>
                                </td>
                                <td style="max-width:220px;">
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <p class="mb-0 small text-dark" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                            @review.Comment
                                        </p>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">Không có nội dung</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-medium small">@review.CreatedAt.ToString("dd/MM/yyyy")</span>
                                        <span class="text-muted" style="font-size:11px;">@review.CreatedAt.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td class="px-4 text-end">
                                    <form asp-area="Admin" asp-controller="Review" asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa đánh giá này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@review.Id" />
                                        <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">⭐</div>
                                <h5>Chưa có đánh giá nào</h5>
                                <p>Các đánh giá từ khách hàng sẽ xuất hiện tại đây.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center rounded-bottom-4">
        <span class="text-muted small">Hiển thị @Model?.Count() đánh giá</span>
        @if (Model != null && Model.Any())
        {
            var avg = Model.Average(r => r.Rating);
            <div class="d-flex align-items-center gap-1">
                <span style="color:#ffc107;">★</span>
                <span class="fw-bold text-dark small">@avg.ToString("F1")</span>
                <span class="text-muted small">trung bình</span>
            </div>
        }
    </div>
</div>
