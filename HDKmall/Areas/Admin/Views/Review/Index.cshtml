@model IEnumerable<HDKmall.Models.Review>
@{
    ViewData["Title"] = "Quản lý đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">⭐ Quản Lý Đánh Giá</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả đánh giá</h5>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <!-- Status filter -->
            <div class="btn-group" role="group">
                <a asp-action="Index" asp-route-q="@ViewBag.Search"
                   class="btn btn-sm @(ViewBag.Status == null ? "btn-danger" : "btn-outline-secondary") rounded-start-pill">Tất cả</a>
                <a asp-action="Index" asp-route-q="@ViewBag.Search" asp-route-status="pending"
                   class="btn btn-sm @(ViewBag.Status == "pending" ? "btn-warning text-dark" : "btn-outline-secondary")">Chờ duyệt</a>
                <a asp-action="Index" asp-route-q="@ViewBag.Search" asp-route-status="approved"
                   class="btn btn-sm @(ViewBag.Status == "approved" ? "btn-success" : "btn-outline-secondary")">Đã duyệt</a>
                <a asp-action="Index" asp-route-q="@ViewBag.Search" asp-route-status="hidden"
                   class="btn btn-sm @(ViewBag.Status == "hidden" ? "btn-dark" : "btn-outline-secondary") rounded-end-pill">Đã ẩn</a>
            </div>
            <!-- Search -->
            <form asp-controller="Review" asp-action="Index" method="get" class="d-flex">
                @if (ViewBag.Status != null) { <input type="hidden" name="status" value="@ViewBag.Status" /> }
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="q" value="@ViewBag.Search" class="form-control bg-light border-start-0 rounded-end-pill" placeholder="Tìm đánh giá..." style="width:220px;" />
                </div>
            </form>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Sản phẩm</th>
                        <th class="py-3 border-0">Người dùng</th>
                        <th class="py-3 border-0">Số sao</th>
                        <th class="py-3 border-0">Nội dung</th>
                        <th class="py-3 border-0">Tags</th>
                        <th class="py-3 border-0">Trạng thái</th>
                        <th class="py-3 border-0">Ngày</th>
                        <th class="px-4 py-3 border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var review in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@review.Id</td>
                                <td>
                                    <a href="/Product/Detail/@review.ProductId" class="text-decoration-none fw-semibold text-dark" style="max-width:160px; display:block; white-space:normal; font-size:13px;">
                                        @(review.Product?.Name ?? $"#{review.ProductId}")
                                    </a>
                                </td>
                                <td>
                                    <span class="fw-medium" style="font-size:13px;">@(review.User?.FullName ?? $"#{review.UserId}")</span>
                                </td>
                                <td>
                                    <span style="color:#ffc107; font-size:15px;">
                                        @for (int s = 1; s <= 5; s++) { <span>@(s <= review.Rating ? "★" : "☆")</span> }
                                    </span>
                                </td>
                                <td style="max-width:200px; white-space:normal; font-size:13px; color:#555;">
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        @(review.Comment.Length > 80 ? review.Comment.Substring(0, 80) + "…" : review.Comment)
                                    }
                                    @if (review.Images != null && review.Images.Any())
                                    {
                                        <br /><small class="text-muted"><i class="bi bi-images me-1"></i>@review.Images.Count ảnh</small>
                                    }
                                </td>
                                <td style="max-width:150px;">
                                    @if (review.TagMappings != null && review.TagMappings.Any())
                                    {
                                        @foreach (var tm in review.TagMappings.Take(3))
                                        {
                                            <span class="badge bg-light text-dark border me-1 mb-1" style="font-size:11px;">@(tm.Tag?.Emoji) @(tm.Tag?.Name)</span>
                                        }
                                        @if (review.TagMappings.Count > 3)
                                        {
                                            <span class="badge bg-light text-muted border">+@(review.TagMappings.Count - 3)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    @if (review.IsHidden)
                                    {
                                        <span class="badge bg-dark">Đã ẩn</span>
                                    }
                                    else if (review.IsApproved)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-muted small">@review.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 text-end">
                                    <div class="d-flex justify-content-end gap-1 flex-wrap">
                                        @if (!review.IsApproved || review.IsHidden)
                                        {
                                            <form asp-action="Approve" asp-route-id="@review.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-light text-success border shadow-sm rounded-3" title="Duyệt">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (!review.IsHidden)
                                        {
                                            <form asp-action="Hide" asp-route-id="@review.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-light text-warning border shadow-sm rounded-3" title="Ẩn">
                                                    <i class="bi bi-eye-slash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Unhide" asp-route-id="@review.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-light text-info border shadow-sm rounded-3" title="Hiện lại">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Xóa đánh giá này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">⭐</div>
                                <h5>Chưa có đánh giá nào</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">Hiển thị @Model?.Count() đánh giá</span>
    </div>
</div>

