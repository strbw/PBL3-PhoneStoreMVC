@model HDKmall.ViewModels.ProductVM

@{
    ViewData["Title"] = "Sửa Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Sửa Sản Phẩm #@Model.Id</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- Basic Info -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Thông tin cơ bản</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Name" class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label">Giá cơ bản (₫) <span class="text-danger">*</span></label>
                    <input asp-for="Price" type="number" class="form-control" min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoryId" class="form-label">Danh mục <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BrandId" class="form-label">Thương hiệu</label>
                    <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select">
                        <option value="">-- Chọn thương hiệu --</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </div>

    <!-- Images -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Hình ảnh sản phẩm</div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Ảnh hiện tại</label><br />
                    <img src="@Model.ImageUrl" alt="@Model.Name" style="width:120px;height:120px;object-fit:cover;border-radius:8px;border:2px solid #d70018;" />
                </div>
            }
            <div class="mb-3">
                <label class="form-label">Thêm ảnh mới (các ảnh sẽ được thêm vào danh sách)</label>
                <input type="file" name="Images" multiple accept="image/*" class="form-control" id="imageInput" />
                <small class="text-muted">Chọn nhiều file cùng lúc. Ảnh mới sẽ được thêm vào danh sách hiện có.</small>
            </div>
            <div class="mb-3">
                <label class="form-label">Thay thế ảnh chính</label>
                <input type="file" asp-for="Image" accept="image/*" class="form-control" />
                <small class="text-muted">Chọn file này để thay thế ảnh chính hiện tại.</small>
            </div>
            <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
        </div>
    </div>

    <!-- Variants -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">Phiên bản sản phẩm (Variants)</span>
            <button type="button" class="btn btn-sm btn-success" onclick="addVariant()">+ Thêm phiên bản</button>
        </div>
        <div class="card-body">
            <div id="variantsContainer">
                @if (Model.Variants != null)
                {
                    for (int i = 0; i < Model.Variants.Count; i++)
                    {
                        <div class="row g-2 mb-2 align-items-end variant-row" id="variant_existing_@i">
                            <div class="col-md-3">
                                <label class="form-label small">Màu sắc</label>
                                <input type="text" name="Variants[@i].Color" value="@Model.Variants[i].Color" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Dung lượng</label>
                                <input type="text" name="Variants[@i].Capacity" value="@Model.Variants[i].Capacity" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Giá (₫)</label>
                                <input type="number" name="Variants[@i].Price" value="@Model.Variants[i].Price" class="form-control form-control-sm" min="0" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Tồn kho</label>
                                <input type="number" name="Variants[@i].Stock" value="@Model.Variants[i].Stock" class="form-control form-control-sm" min="0" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">URL ảnh</label>
                                <input type="text" name="Variants[@i].ImageUrl" value="@Model.Variants[i].ImageUrl" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeRow('variant_existing_@i')">✕</button>
                            </div>
                        </div>
                    }
                }
            </div>
            <p class="text-muted small" id="variantHint" style="@(Model.Variants?.Count > 0 ? "display:none" : "")">Chưa có phiên bản nào. Nhấn "Thêm phiên bản" để thêm.</p>
        </div>
    </div>

    <!-- Specifications -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">Thông số kỹ thuật</span>
            <button type="button" class="btn btn-sm btn-success" onclick="addSpec()">+ Thêm thông số</button>
        </div>
        <div class="card-body">
            <div id="specsContainer">
                @if (Model.Specifications != null)
                {
                    for (int i = 0; i < Model.Specifications.Count; i++)
                    {
                        <div class="row g-2 mb-2 align-items-end spec-row" id="spec_existing_@i">
                            <div class="col-md-4">
                                <label class="form-label small">Tên thông số</label>
                                <input type="text" name="Specifications[@i].SpecName" value="@Model.Specifications[i].SpecName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label small">Giá trị</label>
                                <input type="text" name="Specifications[@i].SpecValue" value="@Model.Specifications[i].SpecValue" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeRow('spec_existing_@i')">✕</button>
                            </div>
                        </div>
                    }
                }
            </div>
            <p class="text-muted small" id="specHint" style="@(Model.Specifications?.Count > 0 ? "display:none" : "")">Chưa có thông số nào. Nhấn "Thêm thông số" để thêm.</p>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">💾 Lưu Thay Đổi</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Keep track of the highest variant/spec index from server-rendered rows
        let variantIndex = @(Model.Variants?.Count ?? 0);
        let specIndex = @(Model.Specifications?.Count ?? 0);

        // Image preview for new uploads
        document.getElementById('imageInput').addEventListener('change', function () {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            Array.from(this.files).forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.innerHTML = `<img src="${e.target.result}" style="width:100px;height:100px;object-fit:cover;border-radius:6px;border:2px solid #ddd">`;
                    preview.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        });

        function addVariant() {
            document.getElementById('variantHint').style.display = 'none';
            const idx = variantIndex++;
            const html = `
            <div class="row g-2 mb-2 align-items-end variant-row" id="variant_${idx}">
                <div class="col-md-3">
                    <label class="form-label small">Màu sắc</label>
                    <input type="text" name="Variants[${idx}].Color" class="form-control form-control-sm" placeholder="Ví dụ: Đen, Trắng..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Dung lượng</label>
                    <input type="text" name="Variants[${idx}].Capacity" class="form-control form-control-sm" placeholder="256GB" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Giá (₫)</label>
                    <input type="number" name="Variants[${idx}].Price" class="form-control form-control-sm" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Tồn kho</label>
                    <input type="number" name="Variants[${idx}].Stock" class="form-control form-control-sm" min="0" value="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">URL ảnh</label>
                    <input type="text" name="Variants[${idx}].ImageUrl" class="form-control form-control-sm" placeholder="https://..." />
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeRow('variant_${idx}')">✕</button>
                </div>
            </div>`;
            document.getElementById('variantsContainer').insertAdjacentHTML('beforeend', html);
        }

        function addSpec() {
            document.getElementById('specHint').style.display = 'none';
            const idx = specIndex++;
            const html = `
            <div class="row g-2 mb-2 align-items-end spec-row" id="spec_${idx}">
                <div class="col-md-4">
                    <label class="form-label small">Tên thông số</label>
                    <input type="text" name="Specifications[${idx}].SpecName" class="form-control form-control-sm" placeholder="Ví dụ: Kích thước màn hình" />
                </div>
                <div class="col-md-7">
                    <label class="form-label small">Giá trị</label>
                    <input type="text" name="Specifications[${idx}].SpecValue" class="form-control form-control-sm" placeholder="Ví dụ: 6.3 inch" />
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeRow('spec_${idx}')">✕</button>
                </div>
            </div>`;
            document.getElementById('specsContainer').insertAdjacentHTML('beforeend', html);
        }

        function removeRow(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }
    </script>
}
