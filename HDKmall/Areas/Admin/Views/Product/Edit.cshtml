@model HDKmall.ViewModels.ProductVM
@using HDKmall.ViewModels

@{
    ViewData["Title"] = "Chỉnh sửa Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .version-card { border: 1px solid #e0e0e0; transition: all 0.3s ease; }
    .version-card:hover { border-color: #0d6efd; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important; }
    .nested-card { background-color: #f8f9fa; border: 1px dashed #dee2e6; }
    .btn-remove { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; padding: 0; }
    .preview-option-item { border: 1.5px solid #e0e0e0; border-radius: 10px; padding: 10px; background: #fff; text-align: center; display: flex; flex-direction: column; justify-content: center; min-height: 56px; }
    .preview-option-item.active { border-color: #d70018; background: #fff5f5; box-shadow: 0 0 0 1px #d70018; }
    .preview-current-price { color: #d70018; font-size: 2.2rem; font-weight: 800; line-height: 1; }
    #livePreviewSection { background: #f8fafc; border-radius: 32px; padding: 60px 40px; margin-top: 50px; }
    .preview-card-inner { background: #fff; border-radius: 24px; padding: 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); width: 100%; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">✏️ Chỉnh sửa Sản phẩm</h2>
    <a asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4 fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="productForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-lg-12">
            <!-- ===== CHỌN LOẠI SẢN PHẨM ===== -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-danger"><i class="bi bi-grid-1x2-fill me-2"></i>Loại sản phẩm</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <input type="radio" class="btn-check" asp-for="ProductType" id="typeVersions" value="1">
                            <label class="btn btn-outline-primary w-100 py-3 rounded-3 text-start" for="typeVersions">
                                <strong>Dung lượng</strong>
                                <div class="small mt-1">iPhone, Laptop...</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <input type="radio" class="btn-check" asp-for="ProductType" id="typeColors" value="2">
                            <label class="btn btn-outline-success w-100 py-3 rounded-3 text-start" for="typeColors">
                                <strong>Chỉ màu sắc</strong>
                                <div class="small mt-1">Loa, Tai nghe...</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <input type="radio" class="btn-check" asp-for="ProductType" id="typeSimple" value="3">
                            <label class="btn btn-outline-secondary w-100 py-3 rounded-3 text-start" for="typeSimple">
                                <strong>Đơn giản</strong>
                                <div class="small mt-1">Ốp lưng, Cáp...</div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin chung -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-info-circle-fill me-2"></i>Thông tin chung</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold text-muted small">Tên (Model)</label>
                            <input asp-for="Name" class="form-control bg-light border-0" required />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CategoryId" class="form-label fw-bold text-muted small">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select bg-light border-0" required></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="BrandId" class="form-label fw-bold text-muted small">Thương hiệu</label>
                            <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select bg-light border-0">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>

                        <div class="col-md-3" id="directPriceSection" style="display:none;">
                            <label asp-for="Price" class="form-label fw-bold text-muted small">Giá bán (₫)</label>
                            <input asp-for="Price" class="form-control bg-light border-0 fw-bold text-danger" type="number" />
                        </div>
                        <div class="col-md-3" id="directOriginalPriceSection" style="display:none;">
                            <label asp-for="OriginalPrice" class="form-label fw-bold text-muted small">Giá gốc</label>
                            <input asp-for="OriginalPrice" class="form-control bg-light border-0" type="number" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GalleryFiles" class="form-label fw-bold text-muted small">Ảnh Gallery mới</label>
                            <input asp-for="GalleryFiles" type="file" multiple class="form-control bg-light border-0" accept="image/*" />
                        </div>

                        @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                        {
                            <div class="col-12 mt-2">
                                <div class="d-flex flex-wrap gap-2">
                                    @for (int i = 0; i < Model.ExistingImages.Count; i++)
                                    {
                                        <div class="position-relative border rounded" style="width:70px; height:70px;">
                                            <img src="@Model.ExistingImages[i].ImageUrl" class="w-100 h-100 rounded" style="object-fit:cover;" />
                                            <input type="hidden" name="ExistingImages[@i].Id" value="@Model.ExistingImages[i].Id" />
                                            <input type="hidden" name="ExistingImages[@i].ImageUrl" value="@Model.ExistingImages[i].ImageUrl" />
                                            <input class="form-check-input position-absolute top-0 end-0 m-1" type="checkbox" name="ExistingImages[@i].IsMain" value="true" />
                                            <input type="hidden" name="ExistingImages[@i].IsMain" value="false" />
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold text-muted small">Mô tả</label>
                            <textarea asp-for="Description" class="form-control bg-light border-0" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PHẦN 1: DUNG LƯỢNG -->
            <div id="sectionVersions" style="display:none;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Phiên bản dung lượng</h5>
                    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="addVersion()">
                        <i class="bi bi-plus-lg me-1"></i> Thêm
                    </button>
                </div>
                <div id="versionsContainer">
                    @if (Model.Versions != null && Model.ProductType == ProductType.HasVersions)
                    {
                        for (int v = 0; v < Model.Versions.Count; v++)
                        {
                            <div class="card shadow-sm border-0 rounded-4 mb-4 version-card" id="version_@v">
                                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                                    <h6 class="fw-bold text-primary mb-0">Phiên bản: @Model.Versions[v].Name</h6>
                                    <button type="button" class="btn btn-outline-danger btn-remove rounded-circle" onclick="removeRow('version_@v')"><i class="bi bi-x"></i></button>
                                </div>
                                <div class="card-body p-4">
                                    <input type="hidden" name="Versions[@v].Id" value="@Model.Versions[v].Id" />
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-3"><label class="small fw-bold">Dung lượng</label><input type="text" name="Versions[@v].Name" value="@Model.Versions[v].Name" class="form-control bg-light border-0" required /></div>
                                        <div class="col-md-3"><label class="small fw-bold text-danger">Giá bán</label><input type="number" name="Versions[@v].BasePrice" value="@Model.Versions[v].BasePrice" class="form-control bg-light border-0" required /></div>
                                        <div class="col-md-3"><label class="small fw-bold">Giá gốc</label><input type="number" name="Versions[@v].OriginalPrice" value="@Model.Versions[v].OriginalPrice" class="form-control bg-light border-0" /></div>
                                        <div class="col-md-3"><label class="small fw-bold">Ảnh</label><input type="file" name="Versions[@v].ImageFile" class="form-control form-control-sm" /><input type="hidden" name="Versions[@v].ImageUrl" value="@Model.Versions[v].ImageUrl" /></div>
                                    </div>
                                    <div class="row g-4">
                                        <div class="col-lg-7" id="variantsContainer_@v">
                                            @for (int vr = 0; vr < Model.Versions[v].Variants.Count; vr++)
                                            {
                                                var variant = Model.Versions[v].Variants[vr];
                                                <div class="bg-white p-3 rounded-3 border mb-2 position-relative" id="variant_@v @vr">
                                                    <button type="button" class="btn btn-sm text-danger position-absolute top-0 end-0 m-1 border-0" onclick="removeRow('variant_@v @vr')"><i class="bi bi-trash"></i></button>
                                                    <div class="row g-2 align-items-end pe-3">
                                                        <input type="hidden" name="Versions[@v].Variants[@vr].Id" value="@variant.Id" />
                                                        <div class="col-4"><label class="tiny-label">Màu</label><input type="text" name="Versions[@v].Variants[@vr].Color" value="@variant.Color" class="form-control form-control-sm" required /></div>
                                                        <div class="col-4"><label class="tiny-label">Giá</label><input type="number" name="Versions[@v].Variants[@vr].Price" value="@variant.Price" class="form-control form-control-sm" /></div>
                                                        <div class="col-4"><label class="tiny-label">Kho</label><input type="number" name="Versions[@v].Variants[@vr].Stock" value="@variant.Stock" class="form-control form-control-sm" required /></div>
                                                        <div class="col-12 mt-2"><input type="file" name="Versions[@v].Variants[@vr].ImageFile" class="form-control form-control-sm" /><input type="hidden" name="Versions[@v].Variants[@vr].ImageUrl" value="@variant.ImageUrl" /></div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="col-lg-5" id="specsContainer_@v">
                                            @for (int s = 0; s < Model.Versions[v].Specifications.Count; s++)
                                            {
                                                var spec = Model.Versions[v].Specifications[s];
                                                <div class="row g-1 bg-white p-1 rounded-3 border mb-1" id="spec_@v @s">
                                                    <input type="hidden" name="Versions[@v].Specifications[@s].Id" value="@spec.Id" />
                                                    <div class="col-5"><input type="text" name="Versions[@v].Specifications[@s].SpecName" value="@spec.SpecName" class="form-control form-control-sm" required /></div>
                                                    <div class="col-6"><input type="text" name="Versions[@v].Specifications[@s].SpecValue" value="@spec.SpecValue" class="form-control form-control-sm" required /></div>
                                                    <div class="col-1"><button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeRow('spec_@v @s')"><i class="bi bi-x-circle-fill"></i></button></div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-end mt-3">
                                        <button type="button" class="btn btn-sm btn-light border me-2" onclick="addVariant(@v)">Thêm màu</button>
                                        <button type="button" class="btn btn-sm btn-light border" onclick="addSpec(@v)">Thêm thông số</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- PHẦN 2: CHỈ CÓ MÀU SẮC -->
            <div id="sectionColors" style="display:none;">
                @* Hidden inputs for the default version — needed for proper update (avoid delete+recreate) *@
                @if (Model.Versions != null && Model.Versions.Any())
                {
                    <input type="hidden" name="Versions[0].Id" value="@Model.Versions[0].Id" />
                }
                <input type="hidden" name="Versions[0].Name" value="Mặc định" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Danh sách màu sắc</h5>
                    <button type="button" class="btn btn-success rounded-pill px-4 shadow-sm" onclick="addColorVariant()">
                        <i class="bi bi-plus-lg me-1"></i> Thêm màu
                    </button>
                </div>
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="px-4">Màu sắc</th><th>Giá riêng</th><th>Tồn kho</th><th>Hình ảnh</th><th class="text-end px-4">Xóa</th>
                                </tr>
                            </thead>
                            <tbody id="colorVariantsContainer">
                                @if (Model.ProductType == ProductType.ColorsOnly && Model.Versions != null && Model.Versions.Count > 0)
                                {
                                    var defaultV = Model.Versions[0];
                                    for (int vr = 0; vr < defaultV.Variants.Count; vr++)
                                    {
                                        var variant = defaultV.Variants[vr];
                                        <tr id="colorRow_@vr">
                                            <input type="hidden" name="Versions[0].Variants[@vr].Id" value="@variant.Id" />
                                            <td class="px-4"><input type="text" name="Versions[0].Variants[@vr].Color" value="@variant.Color" class="form-control border-light" required /></td>
                                            <td><input type="number" name="Versions[0].Variants[@vr].Price" value="@variant.Price" class="form-control border-light" /></td>
                                            <td><input type="number" name="Versions[0].Variants[@vr].Stock" value="@variant.Stock" class="form-control border-light" required /></td>
                                            <td><input type="file" name="Versions[0].Variants[@vr].ImageFile" class="form-control form-control-sm" /><input type="hidden" name="Versions[0].Variants[@vr].ImageUrl" value="@variant.ImageUrl" /></td>
                                            <td class="text-end px-4"><button type="button" class="btn btn-sm btn-outline-danger border-0 rounded-circle" onclick="removeRow('colorRow_@vr')"><i class="bi bi-trash"></i></button></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky-bottom bg-white border-top p-3 mt-4 text-end rounded-top-4 shadow-lg d-flex justify-content-end gap-3" style="z-index: 1000;">
        <button type="button" class="btn btn-outline-primary btn-lg px-4 rounded-pill fw-bold shadow-sm" onclick="showPreview()">
            <i class="bi bi-eye-fill me-2"></i> XEM TRƯỚC
        </button>
        <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill fw-bold shadow">
            <i class="bi bi-cloud-upload-fill me-2"></i> CẬP NHẬT
        </button>
    </div>
</form>

<div id="livePreviewSection" style="display: none;">
    <div class="d-flex align-items-center mb-5">
        <div class="flex-grow-1 h-px bg-secondary opacity-10"></div>
        <h2 class="mx-4 fw-bold text-dark">BẢN XEM TRƯỚC GIAO DIỆN</h2>
        <div class="flex-grow-1 h-px bg-secondary opacity-10"></div>
    </div>
    <div id="previewContent"></div>
</div>

@section Scripts {
    <script>
        let versionCount = @(Model.Versions?.Count ?? 0);
        let colorVariantCount = @( (Model.ProductType == ProductType.ColorsOnly && Model.Versions != null && Model.Versions.Count > 0) ? Model.Versions[0].Variants.Count : 0);
        let variantCounters = {}; let specCounters = {};

        @if(Model.Versions != null) {
            for(int i=0; i<Model.Versions.Count; i++) {
                @:variantCounters[@i] = @(Model.Versions[i].Variants?.Count ?? 0);
                @:specCounters[@i] = @(Model.Versions[i].Specifications?.Count ?? 0);
            }
        }

        window.onload = function() {
            updateSections();
        };

        document.querySelectorAll('input[name="ProductType"]').forEach(radio => {
            radio.addEventListener('change', updateSections);
        });

        function updateSections() {
            const val = document.querySelector('input[name="ProductType"]:checked')?.value;
            const sectionVersions  = document.getElementById('sectionVersions');
            const sectionColors    = document.getElementById('sectionColors');
            const directPrice      = document.getElementById('directPriceSection');
            const directOrig       = document.getElementById('directOriginalPriceSection');

            sectionVersions.style.display = (val === '1') ? 'block' : 'none';
            sectionColors.style.display   = (val === '2') ? 'block' : 'none';
            directPrice.style.display     = (val === '2' || val === '3') ? 'block' : 'none';
            directOrig.style.display      = (val === '2' || val === '3') ? 'block' : 'none';

            // Disable inputs in hidden sections to prevent form submission conflicts
            toggleSectionInputs('sectionVersions', val === '1');
            toggleSectionInputs('sectionColors', val === '2');
        }

        function toggleSectionInputs(sectionId, enabled) {
            const section = document.getElementById(sectionId);
            if (!section) return;
            section.querySelectorAll('input, textarea, select').forEach(el => {
                el.disabled = !enabled;
            });
        }

        function addVersion() {
            const vIdx = versionCount++;
            const html = `<div class="card shadow-sm border-0 rounded-4 mb-4 version-card" id="version_${vIdx}">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold text-primary mb-0">Phiên bản mới #${vIdx + 1}</h6>
                    <button type="button" class="btn btn-outline-danger btn-remove rounded-circle" onclick="removeRow('version_${vIdx}')"><i class="bi bi-x"></i></button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-3"><label class="small fw-bold">Dung lượng</label><input type="text" name="Versions[${vIdx}].Name" class="form-control bg-light border-0" required /></div>
                        <div class="col-md-3"><label class="small fw-bold text-danger">Giá bán</label><input type="number" name="Versions[${vIdx}].BasePrice" class="form-control bg-light border-0" required /></div>
                        <div class="col-md-3"><label class="small fw-bold">Giá gốc</label><input type="number" name="Versions[${vIdx}].OriginalPrice" class="form-control bg-light border-0" /></div>
                        <div class="col-md-3"><label class="small fw-bold">Ảnh</label><input type="file" name="Versions[${vIdx}].ImageFile" class="form-control form-control-sm" /></div>
                        <div class="col-12"><textarea name="Versions[${vIdx}].Description" class="form-control bg-light border-0" rows="2"></textarea></div>
                    </div>
                    <div class="row g-4"><div class="col-lg-7" id="variantsContainer_${vIdx}"></div><div class="col-lg-5" id="specsContainer_${vIdx}"></div></div>
                    <div class="text-end mt-3"><button type="button" class="btn btn-sm btn-light border me-2" onclick="addVariant(${vIdx})">Thêm màu</button><button type="button" class="btn btn-sm btn-light border" onclick="addSpec(${vIdx})">Thêm thông số</button></div>
                </div>
            </div>`;
            document.getElementById('versionsContainer').insertAdjacentHTML('beforeend', html);
        }

        function addVariant(vIdx) {
            if (!variantCounters[vIdx]) variantCounters[vIdx] = 0;
            const vr = variantCounters[vIdx]++;
            const html = `<div class="bg-white p-2 rounded-3 border mb-2 position-relative" id="variant_${vIdx}_${vr}">
                <button type="button" class="btn btn-sm text-danger position-absolute top-0 end-0 m-1 border-0" onclick="removeRow('variant_${vIdx}_${vr}')"><i class="bi bi-trash"></i></button>
                <div class="row g-2 align-items-end pe-3">
                    <div class="col-4"><input type="text" name="Versions[${vIdx}].Variants[${vr}].Color" placeholder="Màu" class="form-control form-control-sm" required /></div>
                    <div class="col-4"><input type="number" name="Versions[${vIdx}].Variants[${vr}].Price" placeholder="Giá" class="form-control form-control-sm" /></div>
                    <div class="col-4"><input type="number" name="Versions[${vIdx}].Variants[${vr}].Stock" placeholder="Kho" class="form-control form-control-sm" value="10" /></div>
                </div>
            </div>`;
            document.getElementById(`variantsContainer_${vIdx}`).insertAdjacentHTML('beforeend', html);
        }

        function addSpec(vIdx) {
            if (!specCounters[vIdx]) specCounters[vIdx] = 0;
            const s = specCounters[vIdx]++;
            const html = `<div class="row g-1 mb-1" id="spec_${vIdx}_${s}">
                <div class="col-5"><input type="text" name="Versions[${vIdx}].Specifications[${s}].SpecName" placeholder="Tên" class="form-control form-control-sm" required /></div>
                <div class="col-6"><input type="text" name="Versions[${vIdx}].Specifications[${s}].SpecValue" placeholder="Giá trị" class="form-control form-control-sm" required /></div>
                <div class="col-1"><button type="button" class="btn btn-sm text-danger border-0" onclick="removeRow('spec_${vIdx}_${s}')"><i class="bi bi-x-circle"></i></button></div>
            </div>`;
            document.getElementById(`specsContainer_${vIdx}`).insertAdjacentHTML('beforeend', html);
        }

        function addColorVariant() {
            const idx = colorVariantCount++;
            const html = `<tr id="colorRow_${idx}">
                <td class="px-4"><input type="text" name="Versions[0].Variants[${idx}].Color" class="form-control border-light shadow-xs" required /></td>
                <td><input type="number" name="Versions[0].Variants[${idx}].Price" class="form-control border-light shadow-xs" value="0" /></td>
                <td><input type="number" name="Versions[0].Variants[${idx}].Stock" class="form-control border-light shadow-xs" value="10" required /></td>
                <td><input type="file" name="Versions[0].Variants[${idx}].ImageFile" class="form-control form-control-sm" /></td>
                <td class="text-end px-4"><button type="button" class="btn btn-sm btn-outline-danger border-0 rounded-circle" onclick="removeRow('colorRow_${idx}')"><i class="bi bi-trash"></i></button></td>
            </tr>`;
            document.getElementById('colorVariantsContainer').insertAdjacentHTML('beforeend', html);
        }

        function removeRow(id) { document.getElementById(id).remove(); }

        function showPreview() {
            const productName = document.querySelector('input[name="Name"]').value || "Tên sản phẩm";
            const description = document.querySelector('textarea[name="Description"]').value || "Mô tả sản phẩm...";
            const productType = document.querySelector('input[name="ProductType"]:checked')?.value;
            let html = '';

            if (productType === "1") {
                const versionElements = document.querySelectorAll('.version-card');
                let tabsHtml = ''; let tabContentsHtml = '';
                versionElements.forEach((vEl, vIdx) => {
                    const vName = vEl.querySelector('input[name*=".Name"]')?.value || `Dung lượng ${vIdx+1}`;
                    const vPrice = parseFloat(vEl.querySelector('input[name*=".BasePrice"]')?.value || '0');
                    let varsHtml = '';
                    [...vEl.querySelectorAll('[id^="variant_"]')].forEach((vr, i) => {
                        const color = vr.querySelector('input[name*=".Color"]')?.value || 'Màu';
                        const price = parseFloat(vr.querySelector('input[name*=".Price"]')?.value || '0');
                        varsHtml += `<div class="preview-option-item ${i===0?'active':''}"><span class="fw-bold small">${color}</span><small>${(price > 0 ? price : vPrice).toLocaleString('vi-VN')}₫</small></div>`;
                    });
                    tabsHtml += `<button type="button" class="btn ${vIdx===0?'btn-danger':'btn-outline-secondary'} btn-sm rounded-pill px-3 me-2 mb-2" onclick="switchPreviewTab(${vIdx}, ${versionElements.length})" id="ptab_${vIdx}">${vName}</button>`;
                    tabContentsHtml += `<div id="ptabContent_${vIdx}" style="display:${vIdx===0?'block':'none'}">${buildInnerHtml(productName, vName, vPrice, 0, varsHtml, description)}</div>`;
                });
                html = `<div class="mb-4 d-flex justify-content-center flex-wrap">${tabsHtml}</div>${tabContentsHtml}`;
            } else {
                const p = parseFloat(document.querySelector('input[name="Price"]').value || '0'), op = parseFloat(document.querySelector('input[name="OriginalPrice"]').value || '0');
                let varsHtml = '';
                if (productType === "2") {
                    [...document.querySelectorAll('[id^="colorRow_"]')].forEach((row, i) => {
                        const color = row.querySelector('input[name*=".Color"]')?.value || 'Màu';
                        const vp = parseFloat(row.querySelector('input[name*=".Price"]')?.value || '0');
                        varsHtml += `<div class="preview-option-item ${i===0?'active':''}"><span class="fw-bold small">${color}</span><small>${(vp > 0 ? vp : p).toLocaleString('vi-VN')}₫</small></div>`;
                    });
                }
                html = buildInnerHtml(productName, "", p, op, varsHtml, description);
            }
            document.getElementById('previewContent').innerHTML = html; document.getElementById('livePreviewSection').style.display = 'block'; document.getElementById('livePreviewSection').scrollIntoView({ behavior: 'smooth' });
        }

        function buildInnerHtml(n, sn, p, op, vh, d) {
            const ph = (op > p) ? `<div class="preview-current-price">${p.toLocaleString('vi-VN')}₫</div><del class="text-muted ms-2 small">${op.toLocaleString('vi-VN')}₫</del>` : `<div class="preview-current-price">${p.toLocaleString('vi-VN')}₫</div>`;
            return `<div class="preview-card-inner border"><div class="row"><div class="col-lg-5 text-center bg-light rounded-4 py-5 mb-4 mb-lg-0"><i class="bi bi-image fs-1 text-muted"></i></div><div class="col-lg-7 px-lg-5"><h3 class="fw-bold">${n}</h3>${sn?`<p class="text-muted">${sn}</p>`:''}<div class="d-flex align-items-center mb-4">${ph}</div>${vh?`<div class="mb-4"><label class="small fw-bold d-block mb-2">Màu sắc:</label><div class="d-flex flex-wrap gap-2">${vh}</div></div>`:''}<div class="border-top pt-3"><label class="small fw-bold d-block mb-1">Mô tả:</label><div class="small text-muted" style="white-space:pre-wrap">${d}</div></div></div></div></div>`;
        }

        function switchPreviewTab(idx, total) {
            for(let i=0;i<total;i++) {
                if(document.getElementById(`ptabContent_${i}`)) document.getElementById(`ptabContent_${i}`).style.display = i===idx?'block':'none';
                if(document.getElementById(`ptab_${i}`)) { document.getElementById(`ptab_${i}`).classList.toggle('btn-danger', i===idx); document.getElementById(`ptab_${i}`).classList.toggle('btn-outline-secondary', i!==idx); }
            }
        }
    </script>
}