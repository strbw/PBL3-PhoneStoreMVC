@model HDKmall.ViewModels.ProductVM

@{
    ViewData["Title"] = "Sửa Sản Phẩm (CellphoneS Style)";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .version-card { border: 1px solid #e0e0e0; transition: all 0.3s ease; }
    .version-card:hover { border-color: #0d6efd; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important; }
    .nested-card { background-color: #f8f9fa; border: 1px dashed #dee2e6; }
    .btn-remove { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; padding: 0; }
    .tiny-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">✏️ Chỉnh sửa Sản Phẩm #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4 fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-lg-12">
            <!-- Thông tin chung -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-info-circle-fill me-2"></i>Thông tin chung</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold text-muted small">Tên sản phẩm (Model) <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control bg-light border-0" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CategoryId" class="form-label fw-bold text-muted small">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select bg-light border-0"></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="BrandId" class="form-label fw-bold text-muted small">Thương hiệu</label>
                            <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select bg-light border-0">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="ImageFile" class="form-label fw-bold text-muted small">Hình ảnh đại diện sản phẩm (Chung)</label>
                            <div class="d-flex gap-3 align-items-center">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" class="rounded shadow-sm" style="width:60px;height:60px;object-fit:cover;" />
                                }
                                <div class="flex-grow-1">
                                    <input asp-for="ImageFile" type="file" class="form-control bg-light border-0" accept="image/*" />
                                    <input type="hidden" asp-for="ImageUrl" />
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold text-muted small">Mô tả tổng quát</label>
                            <textarea asp-for="Description" class="form-control bg-light border-0" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cấu trúc Dung lượng (Versions) -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-stack me-2"></i>Các phiên bản Dung lượng</h5>
                <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="addVersion()">
                    <i class="bi bi-plus-lg me-1"></i> Thêm dung lượng mới
                </button>
            </div>

            <div id="versionsContainer">
                @if (Model.Versions != null)
                {
                    for (int v = 0; v < Model.Versions.Count; v++)
                    {
                        var version = Model.Versions[v];
                        <div class="card shadow-sm border-0 rounded-4 mb-4 version-card" id="version_@v">
                            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="fw-bold text-primary mb-1">Dung lượng: @version.Name</h6>
                                    <input type="hidden" name="Versions[@v].Id" value="@version.Id" />
                                </div>
                                <button type="button" class="btn btn-outline-danger btn-remove rounded-circle" onclick="removeRow('version_@v')">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                            <div class="card-body p-4">
                                <div class="row g-3 mb-4">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-muted">Tên dung lượng</label>
                                        <input type="text" name="Versions[@v].Name" value="@version.Name" class="form-control bg-light border-0 fw-bold" required />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-muted">Giá cơ bản (₫)</label>
                                        <input type="number" name="Versions[@v].BasePrice" value="@version.BasePrice" class="form-control bg-light border-0" required />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-muted">Ảnh đại diện dung lượng</label>
                                        <div class="d-flex gap-2">
                                            <input type="file" name="Versions[@v].ImageFile" class="form-control form-control-sm border-0 bg-light" accept="image/*" />
                                            @if (!string.IsNullOrEmpty(version.ImageUrl))
                                            {
                                                <img src="@version.ImageUrl" class="rounded shadow-sm" style="width:31px;height:31px;object-fit:cover;" />
                                                <input type="hidden" name="Versions[@v].ImageUrl" value="@version.ImageUrl" />
                                            }
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-bold small text-muted">Đặc điểm nổi bật</label>
                                        <textarea name="Versions[@v].Description" class="form-control bg-light border-0" rows="3">@version.Description</textarea>
                                    </div>
                                </div>

                                <div class="row g-4">
                                    <div class="col-lg-7">
                                        <div class="card nested-card rounded-3 h-100">
                                            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                                <span class="fw-bold small text-dark">Màu sắc & Tồn kho</span>
                                                <button type="button" class="btn btn-sm btn-white border shadow-sm rounded-pill px-3" onclick="addVariant(@v)">Thêm màu</button>
                                            </div>
                                            <div class="card-body pt-0">
                                                <div id="variantsContainer_@v" class="d-flex flex-column gap-2">
                                                    @for (int vr = 0; vr < version.Variants.Count; vr++)
                                                    {
                                                        var variant = version.Variants[vr];
                                                        <div class="bg-white p-3 rounded-3 border shadow-xs position-relative mb-2" id="variant_@v @vr">
                                                            <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle" onclick="removeRow('variant_@v @vr')"><i class="bi bi-trash"></i></button>
                                                            <div class="row g-2 align-items-end pe-4">
                                                                <div class="col-md-4">
                                                                    <label class="tiny-label fw-bold text-muted mb-1 d-block">Màu sắc</label>
                                                                    <input type="text" name="Versions[@v].Variants[@vr].Color" value="@variant.Color" class="form-control form-control-sm border-light" />
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <label class="tiny-label fw-bold text-muted mb-1 d-block">Giá (₫)</label>
                                                                    <input type="number" name="Versions[@v].Variants[@vr].Price" value="@variant.Price" class="form-control form-control-sm border-light" />
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <label class="tiny-label fw-bold text-muted mb-1 d-block">Tồn kho</label>
                                                                    <input type="number" name="Versions[@v].Variants[@vr].Stock" value="@variant.Stock" class="form-control form-control-sm border-light" />
                                                                </div>
                                                                <div class="col-12 mt-2">
                                                                    <div class="d-flex gap-2">
                                                                        <input type="file" name="Versions[@v].Variants[@vr].ImageFile" class="form-control form-control-sm border-light" accept="image/*" />
                                                                        @if (!string.IsNullOrEmpty(variant.ImageUrl))
                                                                        {
                                                                            <img src="@variant.ImageUrl" class="rounded shadow-sm" style="width:28px;height:28px;object-fit:cover;" />
                                                                            <input type="hidden" name="Versions[@v].Variants[@vr].ImageUrl" value="@variant.ImageUrl" />
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-5">
                                        <div class="card nested-card rounded-3 h-100">
                                            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                                <span class="fw-bold small text-dark">Thông số kỹ thuật</span>
                                                <button type="button" class="btn btn-sm btn-white border shadow-sm rounded-pill px-3" onclick="addSpec(@v)">Thêm thông số</button>
                                            </div>
                                            <div class="card-body pt-0">
                                                <div id="specsContainer_@v" class="d-flex flex-column gap-2">
                                                    @for (int s = 0; s < version.Specifications.Count; s++)
                                                    {
                                                        var spec = version.Specifications[s];
                                                        <div class="row g-1 bg-white p-2 rounded-3 border shadow-xs mb-1" id="spec_@v @s">
                                                            <div class="col-5">
                                                                <input type="text" name="Versions[@v].Specifications[@s].SpecName" value="@spec.SpecName" class="form-control form-control-sm border-light" />
                                                            </div>
                                                            <div class="col-6">
                                                                <input type="text" name="Versions[@v].Specifications[@s].SpecValue" value="@spec.SpecValue" class="form-control form-control-sm border-light" />
                                                            </div>
                                                            <div class="col-1 text-center">
                                                                <button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeRow('spec_@v @s')"><i class="bi bi-x-circle-fill"></i></button>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="sticky-bottom bg-white border-top p-3 mt-4 text-end rounded-top-4 shadow-lg d-flex justify-content-end gap-3">
        <button type="button" class="btn btn-outline-primary btn-lg px-4 rounded-pill fw-bold shadow-sm" onclick="showPreview()">
            <i class="bi bi-eye-fill me-2"></i> XEM TRƯỚC GIAO DIỆN
        </button>
        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow">
            <i class="bi bi-cloud-upload-fill me-2"></i> CẬP NHẬT SẢN PHẨM
        </button>
    </div>
</form>

<!-- Modal Xem trước -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-phone-vibrate me-2"></i>Bản xem trước sản phẩm (Dự kiến)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="previewContent" class="p-4">
                    <!-- Content will be injected here via JS -->
                </div>
            </div>
            <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng bản xem trước</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        let versionCount = @(Model.Versions?.Count ?? 0);
        let variantCounters = {};
        let specCounters = {};

        @if(Model.Versions != null) {
            for(int i=0; i<Model.Versions.Count; i++) {
                @:variantCounters[@i] = @(Model.Versions[i].Variants?.Count ?? 0);
                @:specCounters[@i] = @(Model.Versions[i].Specifications?.Count ?? 0);
            }
        }

        function addVersion() {
            const container = document.getElementById('versionsContainer');
            const vIdx = versionCount++;
            const vHtml = `
            <div class="card shadow-sm border-0 rounded-4 mb-4 version-card" id="version_${vIdx}">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-start">
                    <h6 class="fw-bold text-primary mb-1">Phiên bản mới #${vIdx + 1}</h6>
                    <button type="button" class="btn btn-outline-danger btn-remove rounded-circle" onclick="removeRow('version_${vIdx}')"><i class="bi bi-x"></i></button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-4"><label class="form-label fw-bold small">Dung lượng</label><input type="text" name="Versions[${vIdx}].Name" class="form-control bg-light border-0 fw-bold" required /></div>
                        <div class="col-md-4"><label class="form-label fw-bold small">Giá cơ bản (₫)</label><input type="number" name="Versions[${vIdx}].BasePrice" class="form-control bg-light border-0" required /></div>
                        <div class="col-md-4"><label class="form-label fw-bold small">Ảnh</label><input type="file" name="Versions[${vIdx}].ImageFile" class="form-control form-control-sm border-0 bg-light" accept="image/*" /></div>
                        <div class="col-12"><textarea name="Versions[${vIdx}].Description" class="form-control bg-light border-0" rows="3" placeholder="Đặc điểm nổi bật..."></textarea></div>
                    </div>
                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="card nested-card rounded-3">
                                <div class="card-header border-0 d-flex justify-content-between align-items-center"><span>Màu sắc</span><button type="button" class="btn btn-sm btn-white border rounded-pill px-3" onclick="addVariant(${vIdx})">Thêm</button></div>
                                <div class="card-body pt-0"><div id="variantsContainer_${vIdx}"></div></div>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="card nested-card rounded-3">
                                <div class="card-header border-0 d-flex justify-content-between align-items-center"><span>Thông số</span><button type="button" class="btn btn-sm btn-white border rounded-pill px-3" onclick="addSpec(${vIdx})">Thêm</button></div>
                                <div class="card-body pt-0"><div id="specsContainer_${vIdx}"></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;
            container.insertAdjacentHTML('beforeend', vHtml);
        }

        function addVariant(vIdx) {
            if (!variantCounters[vIdx]) variantCounters[vIdx] = 0;
            const varIdx = variantCounters[vIdx]++;
            const html = `
            <div class="bg-white p-3 rounded-3 border mb-2 position-relative" id="variant_${vIdx}_${varIdx}">
                <button type="button" class="btn btn-sm text-danger position-absolute top-0 end-0 m-1 border-0" onclick="removeRow('variant_${vIdx}_${varIdx}')"><i class="bi bi-trash"></i></button>
                <div class="row g-2 align-items-end pe-3">
                    <div class="col-4"><label class="tiny-label fw-bold text-muted">Màu</label><input type="text" name="Versions[${vIdx}].Variants[${varIdx}].Color" class="form-control form-control-sm" required /></div>
                    <div class="col-4"><label class="tiny-label fw-bold text-muted">Giá</label><input type="number" name="Versions[${vIdx}].Variants[${varIdx}].Price" class="form-control form-control-sm" value="0" /></div>
                    <div class="col-4"><label class="tiny-label fw-bold text-muted">Kho</label><input type="number" name="Versions[${vIdx}].Variants[${varIdx}].Stock" class="form-control form-control-sm" value="0" /></div>
                    <div class="col-12 mt-2"><input type="file" name="Versions[${vIdx}].Variants[${varIdx}].ImageFile" class="form-control form-control-sm" accept="image/*" /></div>
                </div>
            </div>`;
            document.getElementById(`variantsContainer_${vIdx}`).insertAdjacentHTML('beforeend', html);
        }

        function addSpec(vIdx) {
            if (!specCounters[vIdx]) specCounters[vIdx] = 0;
            const sIdx = specCounters[vIdx]++;
            const html = `
            <div class="row g-1 bg-white p-1 rounded-3 border mb-1" id="spec_${vIdx}_${sIdx}">
                <div class="col-5"><input type="text" name="Versions[${vIdx}].Specifications[${sIdx}].SpecName" class="form-control form-control-sm" placeholder="Tên" required /></div>
                <div class="col-6"><input type="text" name="Versions[${vIdx}].Specifications[${sIdx}].SpecValue" class="form-control form-control-sm" placeholder="Giá trị" required /></div>
                <div class="col-1"><button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeRow('spec_${vIdx}_${sIdx}')"><i class="bi bi-x-circle-fill"></i></button></div>
            </div>`;
            document.getElementById(`specsContainer_${vIdx}`).insertAdjacentHTML('beforeend', html);
        }

        function removeRow(id) { document.getElementById(id).remove(); }

        function showPreview() {
            const productName = document.querySelector('input[name="Name"]').value || "Tên sản phẩm";
            const description = document.querySelector('textarea[name="Description"]').value || "Mô tả sản phẩm...";
            
            let versionsHtml = "";
            const versionElements = document.querySelectorAll('.version-card');
            
            versionElements.forEach((vEl, vIdx) => {
                const vName = vEl.querySelector(`input[name="Versions[${vIdx}].Name"]`)?.value || "Dung lượng";
                const vBasePrice = vEl.querySelector(`input[name="Versions[${vIdx}].BasePrice"]`)?.value || "0";
                const vDesc = vEl.querySelector(`textarea[name="Versions[${vIdx}].Description"]`)?.value || "";
                
                let variantsHtml = "";
                const variantRows = vEl.querySelectorAll(`[id^="variant_${vIdx}_"]`);
                variantRows.forEach((varRow, varIdx) => {
                    const color = varRow.querySelector(`input[name="Versions[${vIdx}].Variants[${varIdx}].Color"]`)?.value || "Màu";
                    const price = varRow.querySelector(`input[name="Versions[${vIdx}].Variants[${varIdx}].Price"]`)?.value || "0";
                    const stock = varRow.querySelector(`input[name="Versions[${vIdx}].Variants[${varIdx}].Stock"]`)?.value || "0";
                    const displayPrice = parseInt(price) > 0 ? price : vBasePrice;
                    
                    variantsHtml += `
                        <div class="col-md-6 mb-2">
                            <div class="p-2 border rounded-3 bg-white shadow-xs">
                                <div class="fw-bold small text-dark">${color}</div>
                                <div class="text-danger fw-bold">${new Intl.NumberFormat('vi-VN').format(displayPrice)}₫</div>
                                <div class="tiny-label text-muted">Tồn kho: ${stock}</div>
                            </div>
                        </div>`;
                });

                let specsHtml = "";
                const specRows = vEl.querySelectorAll(`[id^="spec_${vIdx}_"]`);
                specRows.forEach((sRow, sIdx) => {
                    const name = sRow.querySelector(`input[name="Versions[${vIdx}].Specifications[${sIdx}].SpecName"]`)?.value || "";
                    const value = sRow.querySelector(`input[name="Versions[${vIdx}].Specifications[${sIdx}].SpecValue"]`)?.value || "";
                    specsHtml += `<tr><td class="fw-bold py-1" style="width:40%">${name}</td><td class="py-1">${value}</td></tr>`;
                });

                versionsHtml += `
                    <div class="mb-4 p-3 border rounded-4 bg-light shadow-xs">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold text-primary mb-0">${vName}</h5>
                            <span class="badge bg-white text-dark shadow-xs border">Giá cơ bản: ${new Intl.NumberFormat('vi-VN').format(vBasePrice)}₫</span>
                        </div>
                        <p class="text-muted small mb-3">${vDesc}</p>
                        <div class="row mb-3">${variantsHtml || '<div class="col-12 text-muted small">Chưa có màu sắc</div>'}</div>
                        <div class="bg-white p-3 rounded-3 shadow-xs">
                            <h6 class="fw-bold small mb-2"><i class="bi bi-list-task me-1"></i>Thông số kỹ thuật</h6>
                            <table class="table table-sm table-borderless mb-0 small">${specsHtml || '<tr><td>Chưa có thông số</td></tr>'}</table>
                        </div>
                    </div>`;
            });

            const currentImageUrl = document.querySelector('input[name="ImageUrl"]')?.value || "";
            const imagePlaceholder = currentImageUrl 
                ? `<img src="${currentImageUrl}" class="rounded-4 img-fluid shadow" style="max-height:400px; object-fit:contain;" />`
                : `<div class="text-center"><i class="bi bi-image fs-1 text-muted"></i><p class="text-muted small mt-2">Chưa có ảnh đại diện</p></div>`;

            const html = `
                <div class="row">
                    <div class="col-lg-5">
                        <div class="bg-light rounded-4 d-flex align-items-center justify-content-center border border-dashed p-3" style="min-height: 400px;">
                            ${imagePlaceholder}
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <h2 class="fw-bold text-dark mb-1">${productName}</h2>
                        <div class="mb-3">
                            <span class="badge bg-danger rounded-pill px-3 py-2">Premium Product</span>
                        </div>
                        <hr class="my-4 opacity-10">
                        <div class="product-description text-muted mb-4">
                            ${description}
                        </div>
                        <h6 class="fw-bold mb-3"><i class="bi bi-layers me-2"></i>Các phiên bản hiện tại:</h6>
                        ${versionsHtml || '<div class="alert alert-light">Chưa có phiên bản nào</div>'}
                    </div>
                </div>`;

            document.getElementById('previewContent').innerHTML = html;
            const modal = new bootstrap.Modal(document.getElementById('previewModal'));
            modal.show();
        }
    </script>
}