@model HDKmall.ViewModels.ProductVM

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Thêm Sản Phẩm</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- ===== IMAGE UPLOAD ===== -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Hình ảnh sản phẩm</div>
        <div class="card-body">
            <input type="file" name="Images" multiple accept="image/*" class="form-control" id="imageInput" />
            <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-3"></div>
        </div>
    </div>

    <!-- ===== PREVIEW ===== -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Preview</div>
        <div class="card-body">
            <div class="d-flex gap-3">

                <img id="previewMainImage"
                     src="/img/Product_Default.jpg"
                     style="width:120px;height:120px;object-fit:cover;border-radius:8px;border:1px solid #ddd;opacity:0.5;" />

                <div>
                    <div id="previewName">(Tên sản phẩm)</div>
                    <div id="previewPrice">(Giá)</div>
                    <div id="previewDescTop">(Mô tả)</div>
                </div>

            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
</form>

@section Scripts {
    <script>
        // ===== PREVIEW IMAGE =====
        document.getElementById('imageInput').addEventListener('change', function () {

            const preview = document.getElementById('imagePreview');
            const mainImg = document.getElementById('previewMainImage');

            preview.innerHTML = '';

            if (this.files.length === 0) {
                mainImg.src = "/img/Product_Default.jpg";
                mainImg.style.opacity = "0.5";
                return;
            }

            Array.from(this.files).forEach((file, i) => {
                const reader = new FileReader();

                reader.onload = function (e) {

                    // tạo ảnh nhỏ
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.width = '100px';
                    img.style.height = '100px';
                    img.style.objectFit = 'cover';
                    img.style.borderRadius = '6px';
                    img.style.border = i === 0 ? '2px solid red' : '1px solid #ddd';

                    // click đổi ảnh chính
                    img.onclick = function () {
                        mainImg.src = e.target.result;
                    };

                    preview.appendChild(img);

                    // ảnh đầu làm ảnh chính
                    if (i === 0) {
                        mainImg.src = e.target.result;
                        mainImg.style.opacity = "1";
                    }
                };

                reader.readAsDataURL(file);
            });
        });

        // ===== PREVIEW TEXT =====
        function updatePreview() {
            document.getElementById('previewName').innerText =
                document.getElementById('pName')?.value || "(Tên sản phẩm)";

            const price = document.getElementById('pPrice')?.value;
            document.getElementById('previewPrice').innerText =
                price ? Number(price).toLocaleString() + " ₫" : "(Giá)";

            document.getElementById('previewDescTop').innerText =
                document.getElementById('pDesc')?.value || "(Mô tả)";
        }

        ['pName','pPrice','pDesc'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updatePreview);
        });

        updatePreview();
    </script>
}
