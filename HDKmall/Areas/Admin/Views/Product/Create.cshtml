@model HDKmall.ViewModels.ProductVM

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🛍️ Thêm Sản Phẩm Mới</h2>
    <a asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4 fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger shadow-sm border-0 rounded-3">
        <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Vui lòng kiểm tra lại:</div>
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-lg-8">
            <!-- Thông tin cơ bản -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-info-circle me-2"></i>Thông tin cơ bản</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-bold text-muted small">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control bg-light border-0" id="pName" placeholder="VD: iPhone 15 Pro Max 256GB" />
                            <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-bold text-muted small">Giá cơ bản (₫) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" type="number" class="form-control bg-light border-0" min="0" id="pPrice" placeholder="0" />
                                <span class="input-group-text bg-light border-0 text-muted">₫</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CategoryId" class="form-label fw-bold text-muted small">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select bg-light border-0" id="pCategory">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="BrandId" class="form-label fw-bold text-muted small">Thương hiệu</label>
                            <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select bg-light border-0" id="pBrand">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold text-muted small">Mô tả sản phẩm</label>
                            <textarea asp-for="Description" class="form-control bg-light border-0" rows="5" id="pDesc" placeholder="Nhập mô tả chi tiết sản phẩm..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hình ảnh -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-images me-2"></i>Hình ảnh sản phẩm</h5>
                </div>
                <div class="card-body p-4">
                    <div class="p-4 border border-dashed rounded-3 bg-light text-center mb-3">
                        <i class="bi bi-cloud-arrow-up text-primary fs-1"></i>
                        <h6 class="mt-2 fw-bold">Tải ảnh lên</h6>
                        <p class="text-muted small mb-3">Chọn một hoặc nhiều ảnh (png, jpg, jpeg)</p>
                        <input type="file" name="Images" multiple accept="image/*" class="form-control form-control-sm mx-auto" style="max-width: 300px;" id="imageInput" />
                    </div>
                    <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                </div>
            </div>

            <!-- Variants -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-layers me-2"></i>Phiên bản (Variants)</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary fw-bold rounded-pill px-3" onclick="addVariant()">
                        <i class="bi bi-plus-lg me-1"></i> Thêm phiên bản
                    </button>
                </div>
                <div class="card-body p-4">
                    <div id="variantsContainer" class="d-flex flex-column gap-3">
                        @if (Model.Variants != null)
                        {
                            for (int i = 0; i < Model.Variants.Count; i++)
                            {
                                <div class="bg-light p-3 rounded-3 position-relative variant-row" id="variant_existing_@i">
                                    <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle shadow-sm" onclick="removeRow('variant_existing_@i')"><i class="bi bi-x-lg"></i></button>
                                    <div class="row g-2 align-items-end pe-4">
                                        <div class="col-md-2">
                                            <label class="form-label small text-muted fw-bold mb-1">Màu sắc</label>
                                            <input type="text" name="Variants[@i].Color" value="@Model.Variants[i].Color" class="form-control border-0 shadow-sm" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label small text-muted fw-bold mb-1">Dung lượng</label>
                                            <input type="text" name="Variants[@i].Capacity" value="@Model.Variants[i].Capacity" class="form-control border-0 shadow-sm" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label small text-muted fw-bold mb-1">Giá (₫)</label>
                                            <input type="number" name="Variants[@i].Price" value="@Model.Variants[i].Price" class="form-control border-0 shadow-sm" min="0" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label small text-muted fw-bold mb-1">Tồn kho</label>
                                            <input type="number" name="Variants[@i].Stock" value="@Model.Variants[i].Stock" class="form-control border-0 shadow-sm" min="0" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small text-muted fw-bold mb-1">Ảnh variant</label>
                                            <div class="d-flex gap-2">
                                                <input type="file" name="Variants[@i].ImageFile" class="form-control form-control-sm border-0 shadow-sm" accept="image/*" onchange="previewVariantImage(this, 'variant_preview_existing_@i')" />
                                                <img id="variant_preview_existing_@i" class="rounded shadow-sm" style="width: 32px; height: 32px; object-fit: cover; @(string.IsNullOrEmpty(Model.Variants[i].ImageUrl) ? "display:none" : "")" src="@Model.Variants[i].ImageUrl" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="text-center text-muted p-3 bg-light rounded-3 mt-3" id="variantHint" style="@(Model.Variants?.Count > 0 ? "display:none" : "")">
                        <i class="bi bi-box-seam mb-2 fs-4 d-block"></i>
                        Sản phẩm này chưa có biến thể nào (sẽ lấy giá và kho mặc định).
                    </div>
                </div>
            </div>

            <!-- Specs -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-cpu me-2"></i>Thông số kỹ thuật</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary fw-bold rounded-pill px-3" onclick="addSpec()">
                        <i class="bi bi-plus-lg me-1"></i> Thêm thông số
                    </button>
                </div>
                <div class="card-body p-4">
                    <div id="specsContainer" class="d-flex flex-column gap-2">
                        @if (Model.Specifications != null)
                        {
                            for (int i = 0; i < Model.Specifications.Count; i++)
                            {
                                <div class="row g-2 spec-row align-items-center bg-light p-2 rounded-3" id="spec_existing_@i">
                                    <div class="col-md-4">
                                        <input type="text" name="Specifications[@i].SpecName" value="@Model.Specifications[i].SpecName" class="form-control border-0 shadow-sm" placeholder="Tên (VD: RAM)" />
                                    </div>
                                    <div class="col-md-7">
                                        <input type="text" name="Specifications[@i].SpecValue" value="@Model.Specifications[i].SpecValue" class="form-control border-0 shadow-sm" placeholder="Giá trị (VD: 8GB)" />
                                    </div>
                                    <div class="col-md-1 text-center">
                                        <button type="button" class="btn btn-sm btn-light text-danger shadow-sm rounded-circle" onclick="removeRow('spec_existing_@i')"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="text-center text-muted p-3 bg-light rounded-3 mt-3" id="specHint" style="@(Model.Specifications?.Count > 0 ? "display:none" : "")">
                        <i class="bi bi-list-columns mb-2 fs-4 d-block"></i>
                        Chưa có thông số kỹ thuật nào.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Sidebar Preview -->
            <div class="card shadow-sm border-0 rounded-4 mb-4 sticky-top" style="top: 100px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-secondary"><i class="bi bi-eye me-2"></i>Xem trước</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <img id="previewMainImage" src="/img/Product_Default.jpg" class="rounded-4 shadow-sm mb-3 w-100" style="aspect-ratio: 1/1; object-fit: cover;" />
                    
                    <div class="text-start">
                        <div class="badge bg-light text-secondary border mb-2 px-2 py-1 rounded-pill" id="previewMeta">Danh mục</div>
                        <h5 class="fw-bold text-dark lh-base mb-2" id="previewName">Tên sản phẩm sẽ hiển thị ở đây</h5>
                        <h4 class="text-danger fw-bold mb-3" id="previewPrice">0 ₫</h4>
                        <div class="small text-muted mb-4 text-truncate" style="max-height: 40px;" id="previewDesc">Mô tả sản phẩm sẽ hiển thị ở đây...</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger fw-bold rounded-pill shadow-sm py-2">
                            <i class="bi bi-check-circle me-1"></i> Lưu Sản Phẩm Mới
                        </button>
                        <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill py-2" onclick="openProductPreview()">
                            <i class="bi bi-arrows-fullscreen me-1"></i> Xem giao diện khách hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- ===== FULL PREVIEW MODAL ===== -->
<div id="productPreviewModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:9999; align-items:center; justify-content:center; backdrop-filter: blur(5px);">
    <div style="background:#fff; width:90%; max-width:1100px; max-height:90vh; overflow:auto; border-radius:16px; position:relative; padding:30px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
        <button onclick="closeProductPreview()" class="btn btn-light rounded-circle shadow-sm" style="position:absolute; top:15px; right:15px; width:40px; height:40px; z-index: 10;"><i class="bi bi-x-lg"></i></button>

        <div class="row g-5">
            <div class="col-md-5">
                <div class="position-relative bg-light rounded-4 p-3 border">
                    <button type="button" onclick="prevPreviewImg()" class="btn btn-light rounded-circle shadow-sm position-absolute start-0 top-50 translate-middle-y ms-2"><i class="bi bi-chevron-left"></i></button>
                    <img id="previewMainImg" src="/img/Product_Default.jpg" class="w-100 rounded-3" style="aspect-ratio:1/1; object-fit:contain; background: white;">
                    <button type="button" onclick="nextPreviewImg()" class="btn btn-light rounded-circle shadow-sm position-absolute end-0 top-50 translate-middle-y me-2"><i class="bi bi-chevron-right"></i></button>
                </div>
                <div id="previewThumbs" class="d-flex gap-2 mt-3 flex-wrap justify-content-center"></div>
            </div>

            <div class="col-md-7">
                <div class="badge bg-light text-secondary border mb-3" id="previewBrandModal">Thương hiệu</div>
                <h3 id="previewTitleModal" class="fw-bold mb-3">Tên sản phẩm</h3>
                <h2 style="color:#d70018;" class="fw-bold mb-4" id="previewPriceModal">0₫</h2>

                <div class="mb-4">
                    <div class="fw-bold mb-2">Màu sắc:</div>
                    <div id="previewColors" class="d-flex gap-2 flex-wrap"></div>
                </div>

                <div class="mb-4">
                    <div class="fw-bold mb-2">Dung lượng:</div>
                    <div id="previewCapacities" class="d-flex gap-2 flex-wrap"></div>
                </div>

                <div class="mb-4">
                    <div class="fw-bold mb-2">Mô tả ngắn:</div>
                    <div id="previewDescModal" class="text-muted"></div>
                </div>

                <button class="btn btn-danger w-100 py-3 rounded-3 fw-bold fs-5 shadow">THÊM VÀO GIỎ HÀNG</button>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-lg-12">
                <ul class="nav nav-tabs mb-4">
                    <li class="nav-item">
                        <a class="nav-link active fw-bold text-danger border-bottom border-danger border-2" href="#">Đặc điểm nổi bật</a>
                    </li>
                </ul>
                <div id="previewDescFull" class="text-muted lh-lg mb-5"></div>

                <h5 class="fw-bold mb-3 border-bottom pb-2">Thông số kỹ thuật</h5>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered" id="previewSpecTable">
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let variantIndex = @(Model?.Variants?.Count ?? 0);
        let specIndex = @(Model?.Specifications?.Count ?? 0);
        let previewImages = [];
        let previewIndex = 0;

        document.getElementById('imageInput').addEventListener('change', function () {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            Array.from(this.files).forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.innerHTML = `<img src="${e.target.result}" style="width:60px;height:60px;object-fit:cover;border-radius:8px;border:1px solid #ddd" class="shadow-sm">`;
                    preview.appendChild(div);

                    if (i === 0) {
                        document.getElementById('previewMainImage').src = e.target.result;
                    }
                };
                reader.readAsDataURL(file);
            });
            if(this.files.length === 0){
                 document.getElementById('previewMainImage').src = "/img/Product_Default.jpg";
            }
        });

        function addVariant() {
            document.getElementById('variantHint').style.display = 'none';
            const idx = variantIndex++;
            const html = `
            <div class="bg-light p-3 rounded-3 position-relative variant-row" id="variant_${idx}">
                <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle shadow-sm" onclick="removeRow('variant_${idx}')"><i class="bi bi-x-lg"></i></button>
                <div class="row g-2 align-items-end pe-4">
                    <div class="col-md-2"><label class="form-label small text-muted fw-bold mb-1">Màu sắc</label><input type="text" name="Variants[${idx}].Color" class="form-control border-0 shadow-sm" /></div>
                    <div class="col-md-2"><label class="form-label small text-muted fw-bold mb-1">Dung lượng</label><input type="text" name="Variants[${idx}].Capacity" class="form-control border-0 shadow-sm" /></div>
                    <div class="col-md-2"><label class="form-label small text-muted fw-bold mb-1">Giá (₫)</label><input type="number" name="Variants[${idx}].Price" class="form-control border-0 shadow-sm" min="0" /></div>
                    <div class="col-md-2"><label class="form-label small text-muted fw-bold mb-1">Tồn kho</label><input type="number" name="Variants[${idx}].Stock" class="form-control border-0 shadow-sm" min="0" value="0" /></div>
                    <div class="col-md-4"><label class="form-label small text-muted fw-bold mb-1">Ảnh variant</label>
                    <div class="d-flex gap-2"><input type="file" name="Variants[${idx}].ImageFile" class="form-control form-control-sm border-0 shadow-sm" accept="image/*" onchange="previewVariantImage(this, 'variant_preview_${idx}')" /><img id="variant_preview_${idx}" class="rounded shadow-sm" style="width:32px;height:32px;object-fit:cover;display:none" /></div></div>
                    <input type="hidden" name="Variants[${idx}].ImageUrl" value="" />
                </div>
            </div>`;
            document.getElementById('variantsContainer').insertAdjacentHTML('beforeend', html);
        }

        function addSpec() {
            document.getElementById('specHint').style.display = 'none';
            const idx = specIndex++;
            const html = `
            <div class="row g-2 spec-row align-items-center bg-light p-2 rounded-3" id="spec_${idx}">
                <div class="col-md-4"><input type="text" name="Specifications[${idx}].SpecName" class="form-control border-0 shadow-sm" placeholder="Tên thông số" /></div>
                <div class="col-md-7"><input type="text" name="Specifications[${idx}].SpecValue" class="form-control border-0 shadow-sm" placeholder="Giá trị" /></div>
                <div class="col-md-1 text-center"><button type="button" class="btn btn-sm btn-light text-danger shadow-sm rounded-circle" onclick="removeRow('spec_${idx}')"><i class="bi bi-trash"></i></button></div>
            </div>`;
            document.getElementById('specsContainer').insertAdjacentHTML('beforeend', html);
        }

        function removeRow(id) { const el = document.getElementById(id); if (el) el.remove(); }

        function previewVariantImage(input, previewId) {
            const img = document.getElementById(previewId);
            if (!input.files || !input.files[0]) return;
            const reader = new FileReader();
            reader.onload = e => { img.src = e.target.result; img.style.display = 'block'; };
            reader.readAsDataURL(input.files[0]);
        }

        function updatePreview() {
            document.getElementById('previewName').innerText = document.getElementById('pName').value || "Tên sản phẩm sẽ hiển thị ở đây";
            const price = document.getElementById('pPrice').value;
            document.getElementById('previewPrice').innerText = price ? `${Number(price).toLocaleString()} ₫` : "0 ₫";
            const cat = document.getElementById('pCategory').selectedOptions[0]?.text || "";
            const brand = document.getElementById('pBrand').selectedOptions[0]?.text || "";
            document.getElementById('previewMeta').innerText = `${cat} ${brand && brand !== '-- Chọn --' ? "- " + brand : ""}` || "Danh mục";
            document.getElementById('previewDesc').innerText = document.getElementById('pDesc').value || "Mô tả sản phẩm sẽ hiển thị ở đây...";
        }
        ['pName','pPrice','pCategory','pBrand','pDesc'].forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener('input', updatePreview); });
        
        // Initial setup
        setTimeout(updatePreview, 100);

        function openProductPreview() {
            const name = document.getElementById('pName')?.value || 'Tên sản phẩm';
            const price = document.getElementById('pPrice')?.value || 0;
            const brand = document.getElementById('pBrand')?.selectedOptions[0]?.text || 'Thương hiệu';
            const desc = document.getElementById('pDesc')?.value || 'Mô tả';
            const colors = [...document.querySelectorAll('input[name*=".Color"]')].map(i => i.value).filter(v => v && v.trim() !== '');
            const caps = [...document.querySelectorAll('input[name*=".Capacity"]')].map(i => i.value).filter(v => v && v.trim() !== '');

            document.getElementById('previewTitleModal').innerText = name;
            document.getElementById('previewPriceModal').innerText = Number(price).toLocaleString('vi-VN') + '₫';
            document.getElementById('previewBrandModal').innerText = brand === '-- Chọn --' ? 'Thương hiệu' : brand;
            document.getElementById('previewDescModal').innerText = desc;
            document.getElementById('previewDescFull').innerHTML = desc.replace(/\n/g, "<br/>");

            // Specs table
            const specRows = [...document.querySelectorAll('input[name*=".SpecName"]')].map((el, idx) => {
                const name = el.value?.trim();
                const valInput = document.querySelectorAll('input[name*=".SpecValue"]')[idx];
                const val = valInput?.value?.trim();
                return (name && val) ? { name, val } : null;
            }).filter(x => x);

            const tbody = document.querySelector('#previewSpecTable tbody');
            tbody.innerHTML = '';
            if (specRows.length === 0) {
                tbody.innerHTML = `<tr><td class="text-muted p-3 text-center">Chưa có thông số.</td></tr>`;
            } else {
                specRows.forEach(s => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td style="width:30%" class="fw-bold text-secondary bg-light">${s.name}</td><td>${s.val}</td>`;
                    tbody.appendChild(tr);
                });
            }

            previewImages = [];
            const addIfValid = (url) => { if (url && url.trim() && url.trim() !== "null") previewImages.push(url.trim()); };

            const fileInput = document.getElementById('imageInput');
            if (fileInput && fileInput.files.length > 0) {
                const files = Array.from(fileInput.files);
                let loaded = 0;
                files.forEach(f => {
                    const reader = new FileReader();
                    reader.onload = e => { addIfValid(e.target.result); loaded++; if (loaded === files.length) renderPreviewGallery(); };
                    reader.readAsDataURL(f);
                });
            } else {
                addIfValid(document.getElementById('previewMainImage')?.src);
                [...document.querySelectorAll('img[id^="variant_preview"]')].forEach(img => { if(img.style.display !== 'none') addIfValid(img.src); });
                renderPreviewGallery();
            }

            const colorWrap = document.getElementById('previewColors');
            colorWrap.innerHTML = '';
            if(colors.length > 0) {
                [...new Set(colors)].forEach(c => {
                    colorWrap.innerHTML += `<div class="border rounded-3 px-3 py-2 bg-light shadow-sm fw-bold">${c}</div>`;
                });
            } else { colorWrap.innerHTML = '<span class="text-muted">Mặc định</span>'; }

            const capWrap = document.getElementById('previewCapacities');
            capWrap.innerHTML = '';
            if(caps.length > 0) {
                [...new Set(caps)].forEach(c => {
                    capWrap.innerHTML += `<div class="border rounded-3 px-3 py-2 bg-light shadow-sm fw-bold">${c}</div>`;
                });
            } else { capWrap.innerHTML = '<span class="text-muted">Mặc định</span>'; }

            document.getElementById('productPreviewModal').style.display = 'flex';
        }

        function renderPreviewGallery() {
            if (previewImages.length === 0) previewImages = ["/img/Product_Default.jpg"];
            previewImages = [...new Set(previewImages)];
            previewIndex = 0;
            document.getElementById('previewMainImg').src = previewImages[0];
            const thumbs = document.getElementById('previewThumbs');
            thumbs.innerHTML = '';
            if (previewImages.length <= 1) { thumbs.style.display = 'none'; return; }
            thumbs.style.display = 'flex';
            previewImages.forEach((src, i) => {
                const img = document.createElement('img');
                img.src = src;
                img.className = "rounded-3 shadow-sm cursor-pointer";
                img.style.width = '60px'; img.style.height = '60px'; img.style.objectFit = 'cover';
                img.style.border = i === 0 ? '2px solid #d70018' : '2px solid transparent';
                img.onclick = () => { previewIndex = i; updatePreviewMain(); };
                thumbs.appendChild(img);
            });
        }

        function updatePreviewMain() {
            document.getElementById('previewMainImg').src = previewImages[previewIndex];
            document.querySelectorAll('#previewThumbs img').forEach((t, i) => {
                t.style.border = i === previewIndex ? '2px solid #d70018' : '2px solid transparent';
            });
        }
        function nextPreviewImg(){ previewIndex = (previewIndex+1) % previewImages.length; updatePreviewMain(); }
        function prevPreviewImg(){ previewIndex = (previewIndex-1+previewImages.length) % previewImages.length; updatePreviewMain(); }
        function closeProductPreview(){ document.getElementById('productPreviewModal').style.display='none'; }
    </script>
}