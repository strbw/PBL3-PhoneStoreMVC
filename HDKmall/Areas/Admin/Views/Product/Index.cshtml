@model IEnumerable<HDKmall.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; // hoặc _Layout tuỳ của bạn
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Danh Sách Sản Phẩm</h2>
    <a asp-action="Create" class="btn btn-primary">Thêm Sản Phẩm Mới</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Hình Ảnh</th>
            <th>Tên Sản Phẩm</th>
            <th>Giá</th>
            <th>Danh Mục</th>
            <th>Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @if(Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <!-- Hiển thị ảnh kích thước nhỏ -->
                        <img src="@item.ImageUrl" alt="@item.Name" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("N0") VNĐ</td>
                    <td>@item.CategoryId</td>
                    <td>
                        <!-- Nút Edit và Delete chờ bạn phát triển tiếp -->
                        <a href="#" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="#" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">Chưa có sản phẩm nào.</td>
            </tr>
        }
    </tbody>
</table>