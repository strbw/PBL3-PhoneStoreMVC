@model IEnumerable<HDKmall.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🛍️ Danh Sách Sản Phẩm</h2> 
    <a asp-action="Create" class="btn btn-danger text-white fw-bold shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Mới Sản Phẩm
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-secondary">Tất cả sản phẩm</h5>
        <form asp-controller="Product" asp-action="Index" method="get" class="d-flex" style="width: 350px;">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control bg-light border-start-0 rounded-end-pill focus-ring focus-ring-danger" placeholder="Tìm tên, danh mục..." />
            </div>
        </form>
    </div>
    
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="px-4 py-3 border-0">ID</th>
                        <th class="py-3 border-0">Sản phẩm</th>
                        <th class="py-3 border-0 text-end">Giá bán</th>
                        <th class="py-3 border-0">Danh mục</th>
                        <th class="py-3 border-0">Thương hiệu</th>
                        <th class="px-4 py-3 border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if(Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted fw-medium">#@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/Product_Default.jpg" : item.ImageUrl)"
                                             alt="@item.Name"
                                             class="rounded-3 shadow-sm border"
                                             style="width: 50px; height: 50px; object-fit: cover; cursor: pointer;" 
                                             data-preview-src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/Product_Default.jpg" : item.ImageUrl)" />
                                        <div class="ms-3">
                                            <div class="fw-bold text-dark text-wrap" style="max-width: 250px;">@item.Name</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end fw-bold text-danger">@item.Price.ToString("N0") ₫</td>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1 rounded-pill">
                                        @(item.Category?.Name ?? item.CategoryId.ToString())
                                    </span>
                                </td>
                                <td>
                                    @if(item.Brand != null) {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-2 py-1 rounded-pill">
                                            @item.Brand.Name
                                        </span>
                                    } else {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="px-4 text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border shadow-sm rounded-3 me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                        <button type="submit" class="btn btn-sm btn-light text-danger border shadow-sm rounded-3" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="fs-1 mb-3">📦</div>
                                <h5>Chưa có sản phẩm nào</h5>
                                <p>Hãy thêm sản phẩm đầu tiên của bạn!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">Hiển thị @Model?.Count() sản phẩm</span>
    </div>
</div>
