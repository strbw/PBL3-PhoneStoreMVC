@model HDKmall.Models.ShoppingCart
@using HDKmall.Helpers
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="main-content bg-light pb-5 pt-4">
    <div class="container">
        <!-- Progress Steps -->
        <div class="d-flex justify-content-center mb-5 d-none d-md-flex">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px; z-index: 1; opacity:0.5; position:relative;">
                    1
                    <span class="position-absolute top-100 mt-2 text-muted fw-semibold text-nowrap" style="font-size: 13px;">Giỏ hàng</span>
                </div>
                <div class="bg-primary" style="height: 4px; width: 100px; margin: 0 -5px;"></div>
                <div class="rounded-circle bg-primary border border-2 border-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm position-relative" style="width: 40px; height: 40px; z-index: 1;">
                    2
                    <span class="position-absolute top-100 mt-2 text-primary fw-bold text-nowrap" style="font-size: 13px;">Thanh toán</span>
                </div>
                <div class="bg-secondary" style="height: 4px; width: 100px; margin: 0 -5px; opacity: 0.3;"></div>
                <div class="rounded-circle bg-white border border-2 border-secondary text-secondary d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px; z-index: 1; opacity: 0.5; position:relative;">
                    3
                    <span class="position-absolute top-100 mt-2 text-muted fw-semibold text-nowrap" style="font-size: 13px;">Hoàn tất</span>
                </div>
            </div>
        </div>
        <h2 class="section-title mb-4 d-md-none">Thanh toán</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <form asp-action="CreateOrder" asp-controller="Order" method="post" id="checkout-form">
            @Html.AntiForgeryToken()
            <!-- Hidden fields -->
            <input type="hidden" name="shippingFee" id="shippingFeeInput" value="20000" />
            <input type="hidden" name="paymentMethod" id="paymentMethodInput" value="COD" />

            <div class="row gx-lg-5">
                <!-- Left Column: Shipping Info -->
                <div class="col-lg-7 mb-4 mb-lg-0">
                    <!-- Customer Info Card -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-header bg-white py-3 px-4 border-bottom">
                            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                                <span class="fs-4">📍</span> Thông tin giao hàng
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-medium">Họ và tên người nhận</label>
                                    <input type="text" class="form-control bg-light border-0" value="@User.Identity.Name" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-medium">Số điện thoại <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control border" name="phone" placeholder="Nhập số điện thoại" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-medium">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                                    <select class="form-select border" name="city" id="citySelect" required onchange="onCityChange()">
                                        <option value="" selected disabled>Chọn Tỉnh/Thành phố</option>
                                    </select>
                                </div>
                                <div class="col-md-6" id="districtCol" style="display:none;">
                                    <label class="form-label text-muted small fw-medium">Quận/Huyện <span class="text-danger">*</span></label>
                                    <select class="form-select border" name="district" id="districtSelect" onchange="onDistrictChange()">
                                        <option value="">Chọn Quận/Huyện</option>
                                    </select>
                                    <input type="hidden" name="cityName" id="cityNameInput" />
                                    <input type="hidden" name="districtName" id="districtNameInput" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-muted small fw-medium">Địa chỉ cụ thể <span class="text-danger">*</span></label>
                                    <textarea class="form-control border" name="address" rows="2" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label text-muted small fw-medium">Ghi chú đơn hàng (Tùy chọn)</label>
                                    <textarea class="form-control border" name="note" rows="2" placeholder="Giao giờ hành chính, gọi trước khi giao..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Shipping Method -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-header bg-white py-3 px-4 border-bottom">
                            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                                <span class="fs-4">🚚</span> Phương thức vận chuyển
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 border">
                                <div>
                                    <div class="fw-semibold">Giao hàng tiêu chuẩn</div>
                                    <div class="text-muted small">Dự kiến 2-5 ngày làm việc</div>
                                </div>
                                <div class="fw-bold text-danger" id="shippingFeeDisplay">20.000₫</div>
                            </div>
                            <div class="mt-3 p-3 bg-info-subtle rounded-3 border border-info-subtle" style="font-size:13px;">
                                <b>💡 Phí vận chuyển:</b><br>
                                • Đà Nẵng nội thành (Hải Châu, Thanh Khê, Sơn Trà, Ngũ Hành Sơn, Liên Chiểu, Cẩm Lệ): <b>20.000₫</b><br>
                                • Đà Nẵng ngoại thành (Hòa Vang, Hoàng Sa): <b>35.000₫</b><br>
                                • Tỉnh/Thành khác: <b>45.000₫</b>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-header bg-white py-3 px-4 border-bottom">
                            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                                <span class="fs-4">💳</span> Phương thức thanh toán
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="payment-options d-flex flex-column gap-3">
                                <label class="payment-option position-relative" style="cursor:pointer;">
                                    <input type="radio" name="payment_method_display" value="COD" class="position-absolute opacity-0" checked onchange="document.getElementById('paymentMethodInput').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="radio-custom border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; flex-shrink:0;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(1); transition: transform 0.2s;"></div>
                                            </div>
                                            <span style="font-size: 22px;">💵</span>
                                            <div>
                                                <div class="fw-bold">Thanh toán khi nhận hàng (COD)</div>
                                                <div class="text-muted small">Thanh toán bằng tiền mặt khi giao hàng</div>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                                <label class="payment-option position-relative" style="cursor:pointer;">
                                    <input type="radio" name="payment_method_display" value="VNPay" class="position-absolute opacity-0" onchange="document.getElementById('paymentMethodInput').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="radio-custom border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; flex-shrink:0;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(0); transition: transform 0.2s;"></div>
                                            </div>
                                            <span style="font-size: 22px;">🏦</span>
                                            <div>
                                                <div class="fw-bold">VNPay</div>
                                                <div class="text-muted small">Thẻ ATM nội địa, thẻ quốc tế, QR Code</div>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                                <label class="payment-option position-relative" style="cursor:pointer;">
                                    <input type="radio" name="payment_method_display" value="MoMo" class="position-absolute opacity-0" onchange="document.getElementById('paymentMethodInput').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="radio-custom border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; flex-shrink:0;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(0); transition: transform 0.2s;"></div>
                                            </div>
                                            <span style="font-size: 22px;">📱</span>
                                            <div>
                                                <div class="fw-bold">MoMo</div>
                                                <div class="text-muted small">Thanh toán qua ví điện tử MoMo</div>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Order Summary -->
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 80px;">
                        <div class="card-header bg-white py-3 px-4 border-bottom d-flex align-items-center justify-content-between">
                            <h5 class="mb-0 fw-bold">Đơn hàng của bạn</h5>
                            <span class="badge bg-primary rounded-pill px-3 py-2">@(Model?.Items?.Count ?? 0) sản phẩm</span>
                        </div>
                        <div class="card-body p-4">
                            @if (Model != null && Model.Items != null)
                            {
                                <div class="order-items vstack gap-3 mb-4" style="max-height: 300px; overflow-y: auto;">
                                    @foreach (var item in Model.Items)
                                    {
                                        var itemPrice = item.Variant != null ? item.Variant.Price : item.Product?.Price ?? 0;
                                        var variantLabel = item.Variant != null
                                            ? string.Join("/", new[] { item.Variant.Color, item.Variant.ProductVersion?.Name }.Where(v => !string.IsNullOrEmpty(v)))
                                            : "";
                                        <div class="d-flex align-items-center bg-light p-2 rounded-3 border">
                                            <div class="position-relative me-3 bg-white p-1 rounded border border-light flex-shrink-0" style="width: 65px; height: 65px; display:flex; align-items:center;">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "/img/default.png" : item.Product.ImageUrl)" alt="@item.Product?.Name" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger border border-white" style="font-size: 0.7rem;">@item.Quantity</span>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <div class="fw-bold text-truncate" style="font-size:14px;">@item.Product?.Name</div>
                                                @if (!string.IsNullOrEmpty(variantLabel))
                                                {
                                                    <div class="text-muted" style="font-size:12px;">@variantLabel</div>
                                                }
                                            </div>
                                            <div class="text-end ms-2 flex-shrink-0">
                                                <div class="fw-bold text-danger" style="font-size:14px;">@((itemPrice * item.Quantity).ToString("N0"))₫</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Coupon Code -->
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-medium">Mã giảm giá</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" name="couponCode" id="couponInput" placeholder="Nhập mã giảm giá..." style="text-transform: uppercase;">
                                    <button class="btn btn-outline-secondary fw-bold" type="button" onclick="applyCoupon()">Áp dụng</button>
                                </div>
                                <div id="couponMsg" class="small mt-1"></div>
                            </div>

                            <hr class="opacity-25 my-3">

                            @{
                                var subTotal = Model?.Items?.Sum(i => (i.Variant != null ? i.Variant.Price : i.Product?.Price ?? 0) * i.Quantity) ?? 0;
                            }

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-medium" id="subTotalDisplay">@subTotal.ToString("N0")₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí giao hàng:</span>
                                <span class="fw-medium" id="shippingFeeText">20.000₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 text-success" id="discountRow" style="display:none !important;">
                                <span>Giảm giá:</span>
                                <span id="discountText">-0₫</span>
                            </div>

                            <div class="bg-light p-3 rounded-3 mt-3 mb-4 border">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-6 fw-bold">Tổng cộng:</span>
                                    <span class="fs-4 fw-bold text-danger" id="totalDisplay">@((subTotal + 20000).ToString("N0"))₫</span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-danger w-100 py-3 rounded-pill fw-bold fs-5 shadow-sm">
                                🛒 ĐẶT HÀNG NGAY
                            </button>
                            <p class="text-center text-muted small mt-3 mb-0">
                                Bằng việc đặt hàng, bạn đồng ý với <a href="#" class="text-primary text-decoration-none">Điều khoản sử dụng</a> của chúng tôi.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .payment-option input:checked + .option-content {
        border-color: var(--bs-primary) !important;
        background-color: rgba(var(--bs-primary-rgb), 0.05);
    }
    .payment-option input:checked + .option-content .radio-custom { border-color: var(--bs-primary) !important; }
    .payment-option input:checked + .option-content .radio-inner { transform: scale(1) !important; }
    .payment-option input:not(:checked) + .option-content .radio-inner { transform: scale(0) !important; }
</style>

@section Scripts {
<script>
    const subTotal = @((Model?.Items?.Sum(i => (i.Variant != null ? i.Variant.Price : i.Product?.Price ?? 0) * i.Quantity) ?? 0));
    const innerDistricts = ['Hải Châu', 'Thanh Khê', 'Sơn Trà', 'Ngũ Hành Sơn', 'Liên Chiểu', 'Cẩm Lệ'];
    const outerDistricts = ['Hòa Vang', 'Hoàng Sa'];
    let currentShipping = 30000;
    let currentDiscount = 0;
    let provincesData = [];

    // Load provinces on page load
    fetch('https://provinces.open-api.vn/api/?depth=2')
        .then(response => response.json())
        .then(data => {
            provincesData = data;
            const citySelect = document.getElementById('citySelect');
            data.forEach(province => {
                const option = document.createElement('option');
                option.value = province.code;
                option.text = province.name;
                citySelect.appendChild(option);
            });
        });

    function onCityChange() {
        const cityCode = document.getElementById('citySelect').value;
        const districtCol = document.getElementById('districtCol');
        const districtSelect = document.getElementById('districtSelect');
        const cityNameInput = document.getElementById('cityNameInput');
        
        const selectedProvince = provincesData.find(p => p.code == cityCode);
        if (selectedProvince) {
            cityNameInput.value = selectedProvince.name;
            districtCol.style.display = 'block';
            districtSelect.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
            selectedProvince.districts.forEach(district => {
                const option = document.createElement('option');
                option.value = district.name;
                option.text = district.name;
                districtSelect.appendChild(option);
            });
            districtSelect.required = true;
            
            if (selectedProvince.name.includes('Đà Nẵng')) {
                currentShipping = 20000;
            } else {
                currentShipping = 45000;
            }
        } else {
            districtCol.style.display = 'none';
            districtSelect.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
            districtSelect.required = false;
            cityNameInput.value = '';
            currentShipping = 45000;
        }
        document.getElementById('districtNameInput').value = '';
        updateShippingDisplay();
    }

    function onDistrictChange() {
        const districtName = document.getElementById('districtSelect').value;
        document.getElementById('districtNameInput').value = districtName;
        const cityCode = document.getElementById('citySelect').value;
        const selectedProvince = provincesData.find(p => p.code == cityCode);
        
        if (selectedProvince && selectedProvince.name.includes('Đà Nẵng')) {
            if (!districtName) { currentShipping = 20000; }
            else if (innerDistricts.some(d => districtName.includes(d))) { currentShipping = 20000; }
            else if (outerDistricts.some(d => districtName.includes(d))) { currentShipping = 35000; }
            else { currentShipping = 35000; }
        }
        updateShippingDisplay();
    }

    function updateShippingDisplay() {
        document.getElementById('shippingFeeInput').value = currentShipping;
        document.getElementById('shippingFeeDisplay').textContent = currentShipping.toLocaleString('vi-VN') + '₫';
        document.getElementById('shippingFeeText').textContent = currentShipping.toLocaleString('vi-VN') + '₫';
        updateTotal();
    }

    function updateTotal() {
        const total = subTotal + currentShipping - currentDiscount;
        document.getElementById('totalDisplay').textContent = total.toLocaleString('vi-VN') + '₫';
    }

    function applyCoupon() {
        const code = document.getElementById('couponInput').value.trim().toUpperCase();
        const msg = document.getElementById('couponMsg');
        if (!code) { msg.textContent = ''; return; }
        // Simple client-side demo; server validates on submit
        msg.className = 'small mt-1 text-info';
        msg.textContent = 'Mã giảm giá sẽ được áp dụng khi đặt hàng.';
    }

    // Init
    updateTotal();
</script>
}

