@model HDKmall.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="main-content bg-light py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="section-title mb-0">Chi tiết đơn hàng #@Model.Id</h2>
            <a href="/Order/History" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-arrow-left"></i> Lịch sử</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        
        <div class="row gx-lg-5">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                    <div class="card-header bg-white py-3 px-4 border-bottom">
                        <h5 class="mb-0 fw-bold">Sản phẩm trong đơn hàng</h5>
                    </div>
                    <div class="card-body p-4">
                        @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                        {
                            foreach (var item in Model.OrderDetails)
                            {
                                <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                                    <div class="position-relative me-3 bg-light p-2 rounded border border-white flex-shrink-0" style="width: 80px; height: 80px; display:flex; align-items:center;">
                                        <img src="@(item.Product?.ImageUrl ?? "/img/default.png")" alt="@item.Product?.Name" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 text-dark fw-bold">
                                            <a href="/Product/Detail/@item.ProductId" class="text-decoration-none text-dark">
                                                @item.Product?.Name 
                                                @if (item.ProductVariant?.ProductVersion != null) {
                                                    <span class="text-primary">(@item.ProductVariant.ProductVersion.Name)</span>
                                                    <div style="color:#ffc107; font-size:12px;">
                                                        @for (int s = 1; s <= 5; s++) {
                                                            <span>@(s <= Math.Round(item.ProductVariant.ProductVersion.AverageRating) ? "★" : "☆")</span>
                                                        }
                                                        <span class="text-muted ms-1">(@item.ProductVariant.ProductVersion.AverageRating.ToString("F1"))</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(item.ProductVariant?.Color)) {
                                                    <small class="text-muted fw-normal">- @item.ProductVariant.Color</small>
                                                }
                                            </a>
                                        </h6>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <div>
                                                <span class="text-muted small">Số lượng: x @item.Quantity</span>
                                                @if (Model.Status == "Delivered")
                                                {
                                                    <a href="/Product/Detail/@item.ProductId?versionId=@item.ProductVariant?.ProductVersionId&autoReview=true#review-section" class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-3">
                                                        <i class="bi bi-star-fill me-1"></i>Đánh giá
                                                    </a>
                                                }
                                            </div>
                                            <span class="text-danger fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                    <div class="card-header bg-white py-3 px-4 border-bottom">
                        <h5 class="mb-0 fw-bold">Thông tin thanh toán</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>Tạm tính (@Model.OrderDetails?.Sum(x => x.Quantity))</span>
                            <span>@((Model.TotalAmount).ToString("N0"))₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-success">
                            <span>Giảm giá</span>
                            <span>-0₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted border-bottom pb-3">
                            <span>Phí giao hàng</span>
                            <span>Chưa tính</span>
                        </div>
                        <div class="d-flex justify-content-between mb-0 align-items-center">
                            <span class="fw-bold fs-5 text-dark">Tổng cộng</span>
                            <span class="fw-bold fs-4 text-danger">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>
                    </div>
                </div>
                
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 d-flex align-items-center text-dark"><i class="bi bi-geo-alt me-2 text-primary"></i> Địa chỉ giao hàng</h6>
                        <p class="text-muted mb-4 pb-3 border-bottom">@Model.Address</p>
                        
                        <h6 class="fw-bold mb-3 d-flex align-items-center text-dark"><i class="bi bi-wallet2 me-2 text-primary"></i> Phương thức thanh toán</h6>
                        <p class="text-muted mb-0">@Model.PaymentMethod</p>
                        
                        <h6 class="fw-bold mb-3 mt-4 pt-3 border-top d-flex align-items-center text-dark"><i class="bi bi-box-seam me-2 text-primary"></i> Trạng thái đơn hàng</h6>
                        @{
                            var detailStatusClass = Model.Status switch {
                                "Pending" => "bg-warning text-dark",
                                "Processing" => "bg-info text-dark",
                                "Shipping" => "bg-primary",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                "Failed" => "bg-dark",
                                _ => "bg-secondary"
                            };
                            var detailStatusText = Model.Status switch {
                                "Pending" => "Chờ xử lý",
                                "Processing" => "Đang xử lý",
                                "Shipping" => "Đang giao",
                                "Delivered" => "Đã giao",
                                "Cancelled" => "Đã hủy",
                                "Failed" => "Thanh toán thất bại",
                                _ => Model.Status
                            };
                        }
                        <span class="badge @detailStatusClass rounded-pill px-3 py-2">@detailStatusText</span>
                    </div>
                </div>
                
                @if (Model.Status == "Pending" || Model.Status == "Processing")
                {
                    <form asp-action="Cancel" asp-controller="Order" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không? Khôi phục không khả dụng.');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger w-100 rounded-pill py-3 fw-bold flex-center">
                            Hủy đơn hàng
                        </button>
                    </form>
                }
                @if (Model.Status == "Pending" && (Model.PaymentMethod == "VNPay" || Model.PaymentMethod == "MoMo"))
                {
                    <a href="@Url.Action("Index", "Payment", new { orderId = Model.Id })" class="btn btn-primary w-100 rounded-pill py-3 fw-bold mt-2">
                        💳 Thanh toán ngay
                    </a>
                }
                @if (Model.Status == "Failed" && (Model.PaymentMethod == "VNPay" || Model.PaymentMethod == "MoMo"))
                {
                    <div class="alert alert-danger mt-3 small">
                        <strong>⚠️ Thanh toán thất bại.</strong> Vui lòng thử lại hoặc chọn phương thức khác.
                    </div>
                    <a href="@Url.Action("Index", "Payment", new { orderId = Model.Id })" class="btn btn-warning w-100 rounded-pill py-3 fw-bold mt-1">
                        🔄 Thử thanh toán lại
                    </a>
                }
            </div>
        </div>
    </div>
</div>
