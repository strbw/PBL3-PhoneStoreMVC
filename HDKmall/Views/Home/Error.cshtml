@model ErrorViewModel
@{
    ViewData["Title"] = ViewData["ErrorTitle"] ?? "Lỗi";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="text-center p-5 rounded-4 shadow-sm bg-white border border-light" style="max-width: 600px;">
        <div class="mb-4">
            <div class="display-1 fw-bold text-danger mb-3" style="letter-spacing: -2px;">
                @if (ViewData["ErrorTitle"] != null && ViewData["ErrorTitle"].ToString().Contains("404"))
                {
                    <i class="bi bi-search" style="font-size: 4rem;"></i>
                }
                else
                {
                    <i class="bi bi-exclamation-triangle" style="font-size: 4rem;"></i>
                }
            </div>
            <h1 class="fw-bolder text-dark mb-3">@ViewData["ErrorTitle"]</h1>
            <p class="text-secondary fs-5 mb-4">@ViewData["ErrorMessage"]</p>
        </div>

        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a href="/" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                <i class="bi bi-house-door me-2"></i> Quay về Trang chủ
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm transition-all hover-lift">
                <i class="bi bi-arrow-left me-2"></i> Quay lại
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-5 pt-4 border-top">
                <p class="text-muted small">Mã định danh yêu cầu: <code class="bg-light px-2 py-1 rounded">@Model.RequestId</code></p>
            </div>
        }
    </div>
</div>

<style>
    .transition-all { transition: all 0.3s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
</style>
