@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Trust Bar -->
<div style="background:#d70018; color:#fff; padding:8px 0; border-bottom:1px solid rgba(255,255,255,.15);">
    <div class="container">
        <div class="row g-0 text-center" style="font-size:13px;">
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🚚</span>
                <span>Giao hàng toàn quốc</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🛡️</span>
                <span>Bảo hành chính hãng 12 tháng</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🔄</span>
                <span>Đổi trả 30 ngày</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">✅</span>
                <span>100% hàng chính hãng</span>
            </div>
        </div>
    </div>
</div>

<!-- Hero Banner -->
<div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>
    <div class="carousel-inner rounded-4 shadow">
        <div class="carousel-item active position-relative" style="height: 450px; background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);">
            <div class="container h-100 position-relative z-1 d-flex align-items-center">
                <div class="text-white w-50">
                    <span class="badge bg-danger mb-3 fs-6">Sản phẩm hot</span>
                    <h1 class="display-3 fw-bold mb-3">iPhone 16 Pro Max</h1>
                    <p class="lead mb-4">Sức mạnh Titanium - Đột phá công nghệ với chip A18 Pro mạnh mẽ nhất hiện nay.</p>
                    <a href="/Product" class="btn btn-light text-danger fw-bold rounded-pill px-4 py-2 fs-5">Khám phá ngay</a>
                </div>
            </div>
            <!-- Abstract background shape -->
            <div class="position-absolute end-0 top-0 h-100 w-50" style="background: url('https://placehold.co/600x450/ffffff/ffffff') no-repeat center/cover; opacity: 0.1;"></div>
        </div>
        <div class="carousel-item position-relative" style="height: 450px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
            <div class="container h-100 position-relative z-1 d-flex align-items-center">
                <div class="text-white w-50">
                    <span class="badge bg-info text-dark mb-3 fs-6">Hàng mới về</span>
                    <h1 class="display-3 fw-bold mb-3">Galaxy S24 Ultra</h1>
                    <p class="lead mb-4">Mở ra kỷ nguyên AI mới trên di động, hỗ trợ dịch trực tiếp, thông minh bất tận.</p>
                    <a href="/Product" class="btn btn-light text-primary fw-bold rounded-pill px-4 py-2 fs-5">Khám phá ngay</a>
                </div>
            </div>
            <!-- Abstract background shape -->
            <div class="position-absolute end-0 top-0 h-100 w-50" style="background: url('https://placehold.co/600x450/ffffff/ffffff') no-repeat center/cover; opacity: 0.1;"></div>
        </div>
        <div class="carousel-item position-relative" style="height: 450px; background: linear-gradient(135deg, #111 0%, #333 100%);">
            <div class="container h-100 position-relative z-1 d-flex align-items-center">
                <div class="text-white w-50">
                    <span class="badge bg-white text-dark mb-3 fs-6">Tin đồn HOT</span>
                    <h1 class="display-3 fw-bold mb-3">MacBook Pro M4</h1>
                    <p class="lead mb-4">Cấu hình khủng, màn hình đỉnh cao, thời lượng pin vượt trội cho mọi nhu cầu.</p>
                    <a href="/Product" class="btn btn-light fw-bold text-dark rounded-pill px-4 py-2 fs-5">Khám phá ngay</a>
                </div>
            </div>
            <!-- Abstract background shape -->
            <div class="position-absolute end-0 top-0 h-100 w-50" style="background: url('https://placehold.co/600x450/ffffff/ffffff') no-repeat center/cover; opacity: 0.1;"></div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 3rem; height: 3rem;"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true" style="width: 3rem; height: 3rem;"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Categories -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">Danh mục nổi bật</h3>
        <a href="/Product" class="text-decoration-none text-primary fw-medium">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row row-cols-2 row-cols-md-4 g-3">
        @if (ViewBag.Categories != null)
        {
            var icons = new string[] { "bi-phone", "bi-laptop", "bi-tablet", "bi-headphones", "bi-smartwatch", "bi-camera", "bi-speaker", "bi-controller" };
            int i = 0;
            foreach (var cat in ViewBag.Categories)
            {
                var currentIcon = icons[i % icons.Length];
                i++;
                <div class="col mt-2 mb-2">
                    <a href="/Product?categoryId=@cat.Id" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-4 h-100 text-center py-4 hover-up bg-light">
                            <div class="card-body">
                                <i class="bi @currentIcon text-primary mb-3 d-block" style="font-size: 3rem;"></i>
                                <h6 class="card-title text-dark fw-bold mb-0">@cat.Name</h6>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<style>
    .transition-all { transition: all 0.3s ease; }
    .hover-up { transition: all 0.3s ease; }
    .hover-up:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; border: 1px solid var(--bs-primary) !important; background-color: #fff !important; }
    .product-card-hover { transition: all 0.3s ease; }
    .product-card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; border-color: rgba(13, 110, 253, 0.25) !important; }
</style>

@* Hidden form for CSRF token (used by AJAX add-to-cart) *@
<form id="csrf-form" style="display:none">@Html.AntiForgeryToken()</form>

<!-- Featured Products -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">🔥 Sản phẩm nổi bật</h3>
        <a href="/Product" class="text-decoration-none text-danger fw-medium">Xem thêm <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row row-cols-2 row-cols-lg-4 g-4 border border-1 border-light">
        @if (ViewBag.FeaturedProducts != null)
        {
            foreach (var item in ViewBag.FeaturedProducts)
            {
                <div class="col">
                    <div class="card h-100 border border-light shadow-sm rounded-4 overflow-hidden product-card-hover position-relative">
                        <span class="position-absolute top-0 start-0 m-3 badge bg-danger rounded-pill fw-bold z-1" style="font-size: 0.75rem;">HOT</span>
                        
                        <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)" class="text-center bg-white py-4 d-block" style="height: 220px;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default.png" : item.ImageUrl)" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain;" onerror="this.src='/img/default.png'">
                        </a>
                        <div class="card-body d-flex flex-column bg-white">
                            <div class="text-muted small fw-medium mb-1">@(string.IsNullOrEmpty(item.BrandName) ? "Hãng" : item.BrandName)</div>
                            <h5 class="card-title fs-6 lh-sm mb-3">
                                <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)" class="text-decoration-none text-dark fw-bold">@item.Name</a>
                            </h5>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="text-danger fw-bolder fs-5">@item.Price.ToString("N0")₫</div>
                                <button type="button" class="btn btn-outline-primary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:35px; height:35px;" title="Thêm vào giỏ" onclick="addToCartFromHome(@item.Id, this)">
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- New Products -->
<div class="container mb-5 pb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">✨ Sản phẩm mới về</h3>
        <a href="/Product" class="text-decoration-none text-primary fw-medium">Xem thêm <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row row-cols-2 row-cols-lg-4 g-4 border border-1 border-light">
        @if (ViewBag.NewProducts != null)
        {
            foreach (var item in ViewBag.NewProducts)
            {
                <div class="col">
                    <div class="card h-100 border border-light shadow-sm rounded-4 overflow-hidden product-card-hover position-relative">
                        <span class="position-absolute top-0 start-0 m-3 badge bg-primary rounded-pill fw-bold z-1" style="font-size: 0.75rem;">MỚI</span>
                        
                        <a href="@(!string.IsNullOrEmpty(item.Slug) ? "/product/" + item.Slug : "/Product/Detail/" + item.Id)" class="text-center bg-white py-4 d-block" style="height: 220px;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default.png" : item.ImageUrl)" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain;">
                        </a>
                        <div class="card-body d-flex flex-column bg-white">
                            <div class="text-muted small fw-medium mb-1">@(string.IsNullOrEmpty(item.BrandName) ? "Hãng" : item.BrandName)</div>
                            <h5 class="card-title fs-6 lh-sm mb-3">
                                <a href="@(!string.IsNullOrEmpty(item.Slug) ? "/product/" + item.Slug : "/Product/Detail/" + item.Id)" class="text-decoration-none text-dark fw-bold">@item.Name</a>
                            </h5>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="text-danger fw-bolder fs-5">@item.Price.ToString("N0")₫</div>
                                <button type="button" class="btn btn-outline-primary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:35px; height:35px;" title="Thêm vào giỏ" onclick="addToCartFromHome(@item.Id, this)">
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Toast thông báo giỏ hàng -->
<div id="home-cart-toast" style="display:none; position:fixed; bottom:24px; right:24px; z-index:9999; min-width:280px; border-radius:10px; font-size:15px; box-shadow:0 4px 20px rgba(0,0,0,.15); padding:14px 18px;" class="alert"></div>

@section Scripts {
<script>
    function addToCartFromHome(productId, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        
        btn.disabled = true;
        btn.classList.add('btn-loading');

        fetch('/Cart/Add', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token
            },
            body: 'productId=' + productId + '&variantId=0&quantity=1'
        })
        .then(r => r.json())
        .then(data => {
            if (typeof toastr !== 'undefined') {
                if (data.success) toastr.success(data.message);
                else toastr.error(data.message);
            } else {
                showHomeToast(data.message || (data.success ? 'Đã thêm vào giỏ hàng!' : 'Lỗi thêm sản phẩm'), data.success ? 'success' : 'danger');
            }

            if (data.success) {
                const badge = document.getElementById('cart-badge');
                if (badge) {
                    badge.textContent = data.cartCount;
                    badge.classList.remove('d-none');
                }
            }
        })
        .catch(() => {
            if (typeof toastr !== 'undefined') toastr.error('Có lỗi xảy ra, vui lòng thử lại');
            else showHomeToast('Có lỗi xảy ra, vui lòng thử lại', 'danger');
        })
        .finally(() => {
            btn.classList.remove('btn-loading');
            btn.disabled = false;
        });
    }

    function showHomeToast(msg, type) {
        const toast = document.getElementById('home-cart-toast');
        toast.className = 'alert alert-' + type;
        toast.style.display = 'block';
        toast.innerHTML = (type === 'success' ? '✅ ' : '❌ ') + msg;
        clearTimeout(toast._timer);
        toast._timer = setTimeout(() => { toast.style.display = 'none'; }, 2500);
    }
</script>
}
