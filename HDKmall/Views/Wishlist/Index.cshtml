@model List<HDKmall.ViewModels.ProductListVM>
@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<div class="container py-5" style="min-height: 600px;">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
            <i class="bi bi-heart-fill text-danger fs-3"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0">Danh sách yêu thích</h2>
            <p class="text-muted mb-0">Lưu lại những sản phẩm bạn quan tâm để dễ dàng theo dõi và mua sắm.</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light">
            <div class="mb-4">
                <i class="bi bi-heart text-muted opacity-25" style="font-size: 5rem;"></i>
            </div>
            <h4 class="text-muted">Danh sách yêu thích của bạn đang trống</h4>
            <p class="text-muted mb-4">Hãy dạo quanh cửa hàng và chọn cho mình những sản phẩm ưng ý nhé!</p>
            <a href="/Product" class="btn btn-danger rounded-pill px-5 py-2 fw-bold">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4">
            @foreach (var item in Model)
            {
                <div class="col" id="wishlist-item-@item.Id-@item.VersionId">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card-hover position-relative">
                        @if (item.DiscountPercent > 0)
                        {
                            <span class="position-absolute top-0 start-0 m-2 badge bg-danger rounded-pill fw-bold z-1" style="font-size: 0.7rem;">Giảm @(item.DiscountPercent)%</span>
                        }
                        
                        <button type="button" class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 rounded-circle shadow-sm z-1" 
                                onclick="removeFromWishlist(@item.Id, @(item.VersionId ?? 0))" title="Xóa khỏi yêu thích">
                            <i class="bi bi-x-lg"></i>
                        </button>

                        <a href="/product/@item.Slug@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="text-center bg-white py-4 d-block" style="height: 180px;">
                            <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain;">
                        </a>
                        <div class="card-body d-flex flex-column bg-white p-3">
                            <div class="text-muted small mb-1">@item.BrandName</div>
                            <h6 class="card-title fw-bold mb-3" style="height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                <a href="/product/@item.Slug@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="text-decoration-none text-dark">
                                    @item.Name @(string.IsNullOrEmpty(item.VersionName) || item.Name.Contains(item.VersionName) ? "" : " - " + item.VersionName)
                                </a>
                            </h6>
                            <div class="mt-auto">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <div class="text-danger fw-bold">@item.Price.ToString("N0")₫</div>
                                    @if (item.OriginalPrice > item.Price)
                                    {
                                        <div class="text-muted text-decoration-line-through small" style="font-size: 0.75rem;">@item.OriginalPrice.Value.ToString("N0")₫</div>
                                    }
                                </div>
                                <a href="/product/@item.Slug@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        async function removeFromWishlist(productId, versionId) {
            const confirmed = await modernConfirm('Xóa khỏi yêu thích?', 'Bạn có chắc chắn muốn xóa sản phẩm này không?');
            if(!confirmed) return;
            
            $.post('/Wishlist/Toggle', { productId: productId, versionId: versionId == 0 ? null : versionId }, function(res) {
                if(res.success && !res.isAdded) {
                    const selector = `#wishlist-item-${productId}-${versionId}`;
                    $(selector).fadeOut(300, function() {
                        $(this).remove();
                        if($('.row-cols-2 .col').length == 0) {
                            location.reload();
                        }
                    });
                    updateWishlistBadge(res.count);
                    if(typeof showSuccessToast === 'function') {
                        showSuccessToast('Đã xóa khỏi danh sách yêu thích');
                    }
                }
            });
        }
    </script>
}
