@using HDKmall.BLL.Interfaces
@using System.Security.Claims
@inject ICartService CartService
@{
    int? layoutUserId = null;
    string layoutSessionId = null;
    var uidClaim = User.FindFirst(ClaimTypes.NameIdentifier);
    if (int.TryParse(uidClaim?.Value, out var parsedUid)) layoutUserId = parsedUid;
    if (Context.Session.TryGetValue("SessionId", out byte[] sidBytes))
        layoutSessionId = System.Text.Encoding.UTF8.GetString(sidBytes);
    var cartItemCount = CartService.GetCartItemCount(layoutUserId, layoutSessionId);
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - PhoneStore</title>
  <!-- Thêm Bootstrap và Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="~/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📱</text></svg>" />
  @RenderSection("SEO", required: false)
</head>
<body>

<!-- ========== MOBILE MENU ========== -->
<div class="mobile-menu-overlay" id="mobile-menu-overlay"></div>
<nav class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-header">
    <div class="logo">
      <div class="logo-icon">📱</div>
      <div class="logo-text">Phone<span>Store</span></div>
    </div>
    <button class="mobile-menu-close" id="mobile-menu-close">✕</button>
  </div>
  <a href="/" class="mobile-nav-item">🏠 Trang chủ</a>
  <a href="/Product" class="mobile-nav-item">📱 Điện thoại</a>
  <a href="/Cart" class="mobile-nav-item">🛒 Giỏ hàng</a>
  <a href="/Order/History" class="mobile-nav-item">📦 Tra cứu đơn hàng</a>
  @if (User.Identity!.IsAuthenticated)
  {
    <a href="/Account/Profile" class="mobile-nav-item">👤 Hồ sơ</a>
    @if (User.IsInRole("Admin"))
    {
      <a href="/Admin/Dashboard" class="mobile-nav-item">🛠 Quản trị cửa hàng</a>
    }
    <a href="/Account/Logout" class="mobile-nav-item">⏻ Đăng xuất</a>
  }
  else
  {
    <a href="/Account/Login" class="mobile-nav-item">👤 Tài khoản</a>
  }
</nav>

<!-- ========== HEADER ========== -->
<header class="header">
  <div class="header-top">
    <div class="container">
      <button class="mobile-menu-btn" id="mobile-menu-btn">☰</button>
      <a href="/" class="logo">
        <div class="logo-icon">📱</div>
        <div class="logo-text">Phone<span>Store</span></div>
      </a>
      <form class="search-bar" id="search-form" action="/Product/Search">
        <div class="search-input-wrapper">
          <input type="text" id="search-input" name="q" class="search-input" placeholder="Tìm điện thoại, phụ kiện..." autocomplete="off">
          <button type="submit" class="search-btn">🔍</button>
        </div>
        <div class="search-dropdown" id="search-dropdown">
          <div class="dropdown-section recent-searches-section" id="recent-searches-section" style="display:none; padding:12px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <span style="font-size:12px; font-weight:700; color:#999; text-transform:uppercase;">Tìm kiếm gần đây</span>
            </div>
            <div id="recent-searches-list" style="display:flex; flex-wrap:wrap; gap:8px;"></div>
          </div>
          <div class="dropdown-section recommended-section" id="recommended-section" style="padding:12px;">
            <div style="font-size:12px; font-weight:700; color:#999; text-transform:uppercase; margin-bottom:8px;">Có thể bạn quan tâm</div>
            <div id="search-recommended-list"></div>
          </div>
        </div>
      </form>
      <div class="header-actions">
        <a href="/Wishlist" class="header-btn position-relative">
          <span class="btn-icon">❤️</span>
          <span>Yêu thích</span>
          <span class="cart-badge bg-danger" id="wishlist-badge" style="display:none;">0</span>
        </a>

        <a href="/Cart" class="header-btn position-relative">
          <span class="btn-icon">🛒</span>
          <span>Giỏ hàng</span>
          <span class="cart-badge @(cartItemCount > 0 ? "" : "d-none")" id="cart-badge">@cartItemCount</span>
        </a>

        <a href="/Order/History" class="header-btn" title="Tra cứu đơn hàng">
          <span class="btn-icon">📦</span>
          <span>Đơn hàng</span>
        </a>

        @if (User.Identity!.IsAuthenticated)
        {

            <div class="header-user-menu" style="display:flex; align-items:center; gap: 8px;">
              <span class="btn-icon">👤</span>
              <span class="user-name">@User.Identity.Name</span>
              <a href="/Account/Profile" class="header-btn" title="Hồ sơ">Hồ sơ</a>
              @if (User.IsInRole("Admin"))
              {
                <a href="/Admin/Dashboard" class="header-btn" title="Quản trị cửa hàng">Quản trị</a>
              }
              <a href="/Account/Logout" class="header-btn logout-btn" title="Đăng xuất">⏻</a>
            </div>
        }
        else
        {
            <a href="/Account/Login" class="header-btn header-auth-btn">
              <span class="btn-icon">👤</span>
              <span>Đăng nhập</span>
            </a>
        }

      </div>
    </div>
  </div>
  <nav class="header-nav">
    <div class="container">
      <a href="/Product?cat=dien-thoai" class="nav-item"><span class="nav-icon">📱</span>Điện thoại</a>
      <a href="/Product?cat=may-tinh-bang" class="nav-item"><span class="nav-icon">📟</span>Máy tính bảng</a>
      <a href="/Product?cat=laptop" class="nav-item"><span class="nav-icon">💻</span>Laptop</a>
      <a href="/Product?cat=dong-ho" class="nav-item"><span class="nav-icon"><i class="bi bi-watch"></i></span>Đồng hồ</a>
      <a href="/Product?cat=loa" class="nav-item"><span class="nav-icon"><i class="bi bi-speaker"></i></span>Loa</a>
      <a href="/Product?cat=phu-kien" class="nav-item"><span class="nav-icon">🎧</span>Phụ kiện</a>
      <a href="/Product/Promotions" class="nav-item" style="margin-left:auto;background:rgba(255,255,255,.15); color:#fff; font-weight:700;">🔥 Khuyến mãi</a>
    </div>
  </nav>
</header>

<!-- ========== MAIN ========== -->
<main>
    @RenderBody()
</main>

<!-- ========== FOOTER ========== -->
<footer class="footer">
  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <div class="logo" style="margin-bottom:12px">
          <div class="logo-icon">📱</div>
          <div class="logo-text" style="font-size:20px">Phone<span>Store</span></div>
        </div>
        <p class="footer-desc">Cửa hàng điện thoại và phụ kiện chính hãng với hơn 200 sản phẩm từ các thương hiệu uy tín trên thế giới.</p>
      </div>
      <div>
        <div class="footer-heading">Hỗ trợ</div>
        <div class="footer-links">
          <a href="#">Chính sách bảo hành</a>
          <a href="#">Liên hệ</a>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      © 2026 PhoneStore. All rights reserved.
    </div>
  </div>
</footer>

<!-- Floating Chat Widget -->
<style>
    .chat-widget-container { position: fixed; bottom: 30px; right: 30px; z-index: 9999; }
    .chat-floating-btn { width: 60px; height: 60px; background: #d70018; color: #fff; border: none; border-radius: 50%; font-size: 24px; box-shadow: 0 4px 15px rgba(215,0,24,0.4); cursor: pointer; transition: transform 0.3s; display: flex; align-items: center; justify-content: center; position: relative; }
    .chat-floating-btn:hover { transform: scale(1.1); }
    .chat-button-group { display: flex; align-items: center; gap: 12px; flex-direction: row-reverse; }
    .chat-btn-label { background: #333; color: #fff; padding: 8px 18px; border-radius: 30px; font-weight: bold; font-size: 14px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); white-space: nowrap; }
    .chat-widget-panel { position: absolute; bottom: 85px; right: 0; width: 350px; height: 450px; background: #fff; border-radius: 20px; box-shadow: 0 15px 50px rgba(0,0,0,0.25); display: none; flex-direction: column; overflow: hidden; transform-origin: bottom right; transition: all 0.3s; z-index: 10000; border: 1px solid #eee; }
    .chat-panel-header { background: #d70018; color: #fff; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; }
    .chat-panel-body { flex: 1; padding: 15px; overflow-y: auto; background: #f8f9fa; display: flex; flex-direction: column; gap: 10px; }
    .chat-panel-footer { padding: 15px; background: #fff; border-top: 1px solid #eee; display: flex; gap: 10px; }
    
    .chat-msg { max-width: 80%; padding: 10px 14px; border-radius: 15px; font-size: 14px; line-height: 1.4; position: relative; }
    .chat-msg.admin { align-self: flex-start; background: #fff; border: 1px solid #eee; color: #333; border-bottom-left-radius: 2px; }
    .chat-msg.user { align-self: flex-end; background: #d70018; color: #fff; border-bottom-right-radius: 2px; }
    .chat-time { font-size: 10px; opacity: 0.6; margin-top: 4px; display: block; }
</style>

<div class="chat-widget-container">
    <div class="chat-widget-panel" id="chatPanel">
        <div class="chat-panel-header">
            <div class="d-flex align-items-center">
                <div class="bg-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                    <i class="bi bi-headset text-danger"></i>
                </div>
                <h6 class="mb-0 fw-bold">Hỗ trợ HDKmall</h6>
            </div>
            <button type="button" class="btn-close btn-close-white" style="font-size: 10px;" onclick="toggleChatPanel()"></button>
        </div>
        <div class="chat-panel-body" id="chatBody">
            <!-- Messages will load here -->
            <div class="text-center py-5 text-muted small">
                <i class="bi bi-chat-dots fs-1 opacity-25 d-block mb-2"></i>
                Đang tải tin nhắn...
            </div>
        </div>
        <div class="chat-panel-footer">
            <input type="text" id="chatInput" class="form-control border-0 bg-light" placeholder="Nhập nội dung..." onkeypress="handleChatKey(event)">
            <button type="button" class="btn btn-danger rounded-circle p-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" onclick="sendChatMessage()">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
    <div class="chat-button-group">
        @if (User.Identity.IsAuthenticated)
        {
            <button class="chat-floating-btn" onclick="toggleChatPanel()" id="chatFloatBtn">
                <i class="bi bi-chat-right-text-fill"></i>
            </button>
            <div class="chat-btn-label" id="chatLabel">Chat với Admin</div>
        }
        else
        {
            <a href="/Account/Login" class="chat-floating-btn text-white text-decoration-none" title="Đăng nhập để chat">
                <i class="bi bi-chat-right-text-fill"></i>
            </a>
            <div class="chat-btn-label">Đăng nhập để hỗ trợ</div>
        }
    </div>
</div>

<script>
    let chatInterval = null;

    function toggleChatPanel() {
        const panel = document.getElementById('chatPanel');
        const isVisible = panel.style.display === 'flex';
        panel.style.display = isVisible ? 'none' : 'flex';
        
        if (!isVisible) {
            loadChatHistory();
            // Poll for new messages every 5 seconds when open
            chatInterval = setInterval(loadChatHistory, 5000);
            scrollToBottom();
        } else {
            clearInterval(chatInterval);
        }
    }

    async function loadChatHistory() {
        try {
            const res = await fetch('/Chat/GetHistory');
            if (res.ok) {
                const history = await res.json();
                renderChat(history);
            }
        } catch (e) { console.error(e); }
    }

    function renderChat(history) {
        const body = document.getElementById('chatBody');
        if (history.length === 0) {
            body.innerHTML = '<div class="text-center py-5 text-muted small">Bắt đầu cuộc trò chuyện với chúng tôi!</div>';
            return;
        }

        body.innerHTML = history.map(msg => `
            <div class="chat-msg ${msg.isFromAdmin ? 'admin' : 'user'}">
                ${msg.message}
                <span class="chat-time">${new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
            </div>
        `).join('');
        scrollToBottom();
    }

    function scrollToBottom() {
        const body = document.getElementById('chatBody');
        body.scrollTop = body.scrollHeight;
    }

    function handleChatKey(e) {
        if (e.key === 'Enter') sendChatMessage();
    }

    async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const msg = input.value.trim();
        if (!msg) return;

        input.value = '';
        try {
            const res = await fetch('/Chat/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(msg)
            });
            if (res.ok) loadChatHistory();
        } catch (e) { console.error(e); }
    }
</script>

<partial name="_NotificationPartial" />
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="~/js/main.js"></script>
<style>
    /* Modern Green Toast - CellphoneS Style */
    .cps-toast-container { position: fixed; top: 80px; left: 50%; transform: translateX(-50%); z-index: 9999; display: none; }
    .cps-toast { background: #4CAF50; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); animation: slideDown 0.3s ease-out; }
    .cps-toast-icon { width: 24px; height: 24px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    @@keyframes slideDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>
<div class="cps-toast-container" id="global-toast">
    <div class="cps-toast">
        <div class="cps-toast-icon">✓</div>
        <span id="toast-message">Thêm vào giỏ hàng thành công</span>
    </div>
</div>

<script>
    function showSuccessToast(message) {
        const toast = document.getElementById('global-toast');
        const msgEl = document.getElementById('toast-message');
        if (!toast || !msgEl) return;
        msgEl.textContent = message || "Thành công!";
        toast.style.display = 'block';
        clearTimeout(window._toastTimer);
        window._toastTimer = setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // Global Confirm function using SweetAlert2
    async function modernConfirm(title, text) {
        const result = await Swal.fire({
            title: title || 'Xác nhận?',
            text: text || 'Bạn có chắc chắn muốn thực hiện hành động này?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d70018',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Đồng ý',
            cancelButtonText: 'Hủy'
        });
        return result.isConfirmed;
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
