<!-- Floating Chat Widget -->
<style>
    /* === Shared Widget Styles === */
    .chat-widget-container { position: fixed; bottom: 30px; right: 30px; z-index: 9999; display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
    
    /* Floating buttons */
    .chat-floating-btn {
        width: 56px; height: 56px; border: none; border-radius: 50%;
        font-size: 22px; cursor: pointer; transition: transform 0.25s, box-shadow 0.25s;
        display: flex; align-items: center; justify-content: center; position: relative;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    }
    .chat-floating-btn:hover { transform: scale(1.12); }
    .chat-floating-btn.admin-btn  { background: #d70018; color: #fff; box-shadow: 0 4px 16px rgba(215,0,24,0.45); }

    /* Button labels */
    .chat-btn-row { display: flex; align-items: center; gap: 10px; flex-direction: row-reverse; }
    .chat-btn-label {
        background: #222; color: #fff; padding: 6px 14px; border-radius: 30px;
        font-weight: 700; font-size: 13px; white-space: nowrap; box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        pointer-events: none;
    }

    /* Panels */
    .chat-widget-panel {
        position: fixed; bottom: 110px; right: 30px;
        width: 360px; height: 500px;
        background: #fff; border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        display: none; flex-direction: column; overflow: hidden;
        z-index: 10000; border: 1px solid #e8e8e8;
        animation: panelIn 0.25s ease;
    }
    @@keyframes panelIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    #chatPanel .chat-panel-header   { background: linear-gradient(135deg,#d70018,#ff3d3d); }
    #aiChatPanel .chat-panel-header { background: linear-gradient(135deg,#6c47ff,#9d72ff); }

    .chat-panel-header {
        color: #fff; padding: 14px 18px;
        display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
    }
    .chat-panel-header h6 { margin: 0; font-weight: 700; font-size: 15px; }
    .chat-panel-header .header-sub { font-size: 11px; opacity: 0.85; }

    .chat-panel-body {
        flex: 1; padding: 14px; overflow-y: auto; background: #f4f6fb;
        display: flex; flex-direction: column; gap: 10px;
    }
    .chat-panel-footer {
        padding: 12px 14px; background: #fff; border-top: 1px solid #eee;
        display: flex; gap: 8px; flex-shrink: 0;
    }
    .chat-panel-footer input {
        flex: 1; border: 1.5px solid #e0e0e0; border-radius: 30px;
        padding: 9px 16px; font-size: 14px; outline: none; background: #f8f8f8;
        transition: border-color 0.2s;
    }
    .chat-panel-footer input:focus { border-color: #6c47ff; background: #fff; }
    .chat-send-btn {
        width: 40px; height: 40px; border: none; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; cursor: pointer; transition: transform 0.2s;
        flex-shrink: 0;
    }
    .chat-send-btn:hover { transform: scale(1.1); }
    #chatPanel    .chat-send-btn { background: #d70018; color: #fff; }
    #aiChatPanel  .chat-send-btn { background: #6c47ff; color: #fff; }

    /* Messages */
    .chat-msg {
        max-width: 82%; padding: 10px 14px; border-radius: 16px;
        font-size: 14px; line-height: 1.5; word-break: break-word;
    }
    .chat-msg.admin-msg {
        align-self: flex-start; background: #fff; border: 1px solid #e8e8e8;
        color: #333; border-bottom-left-radius: 4px;
    }
    .chat-msg.user-msg {
        align-self: flex-end; background: #d70018; color: #fff;
        border-bottom-right-radius: 4px;
    }
    .chat-msg.ai-msg {
        align-self: flex-start; background: #f0f0f0; color: #333;
        border-bottom-left-radius: 4px; border: 1px solid #ddd;
    }
    .chat-msg.ai-user-msg {
        align-self: flex-end; background: #6c47ff; color: #fff;
        border-bottom-right-radius: 4px;
    }

    .chat-time { font-size: 10px; opacity: 0.55; margin-top: 4px; display: block; }

    /* Typing indicator */
    .typing-indicator { align-self: flex-start; display: flex; gap: 5px; padding: 12px 16px; background: #fff; border-radius: 16px; border: 1px solid #e8e8e8; border-bottom-left-radius: 4px; }
    .typing-dot { width: 7px; height: 7px; border-radius: 50%; background: #aaa; animation: typingBounce 1.2s infinite; }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
    }

    /* Unread badge */
    .chat-unread-badge {
        position: absolute; top: -4px; right: -4px;
        background: #ff3d3d; color: #fff; font-size: 10px; font-weight: 700;
        width: 18px; height: 18px; border-radius: 50%;
        display: none; align-items: center; justify-content: center;
    }
</style>

<div class="chat-widget-container">

    @if (User.Identity.IsAuthenticated)
    {


        <!-- === Admin Chat Panel === -->
        <div class="chat-widget-panel" id="chatPanel">
            <div class="chat-panel-header">
                <div style="display:flex; align-items:center; gap:8px;">
                    <div style="width:32px;height:32px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-headset"></i>
                    </div>
                    <div>
                        <h6>Hỗ trợ HDKmall</h6>
                        <div class="header-sub">Chat trực tiếp với nhân viên</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" style="font-size:10px;" onclick="toggleChatPanel()"></button>
            </div>
            <div class="chat-panel-body" id="chatBody">
                <div class="text-center py-5 text-muted small">
                    <i class="bi bi-chat-dots fs-1 opacity-25 d-block mb-2"></i>
                    Đang tải tin nhắn...
                </div>
            </div>
            <div class="chat-panel-footer">
                <input type="text" id="chatInput" placeholder="Nhập nội dung..." onkeypress="handleChatKey(event)" />
                <button type="button" class="chat-send-btn" onclick="sendChatMessage()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>

        <!-- === AI Chat Panel === -->
        <div class="chat-widget-panel" id="aiChatPanel">
            <div class="chat-panel-header">
                <div style="display:flex; align-items:center; gap:8px;">
                    <div style="width:32px;height:32px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-robot"></i>
                    </div>
                    <div>
                        <h6>AI Tư vấn HDKmall</h6>
                        <div class="header-sub">Hỗ trợ 24/7 bằng trí tuệ nhân tạo</div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" style="font-size:10px;" onclick="toggleAIChatPanel()"></button>
            </div>
            <div class="chat-panel-body" id="aiChatBody">
                <div class="chat-msg ai-msg">
                    Dạ, em chào Anh/Chị! Em là trợ lý ảo của HDKmall. Em có thể giúp gì cho Anh/Chị về thông tin sản phẩm và khuyến mãi ạ?
                    <span class="chat-time">${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>
                </div>
            </div>
            <div class="chat-panel-footer">
                <input type="text" id="aiChatInput" placeholder="Hỏi AI về sản phẩm..." onkeypress="handleAIChatKey(event)" />
                <button type="button" class="chat-send-btn" onclick="sendAIChatMessage()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>

        <!-- === Buttons === -->
        <div class="chat-btn-row">
            <button class="chat-floating-btn admin-btn" onclick="toggleChatPanel()" id="chatFloatBtn" title="Chat với Admin">
                <i class="bi bi-chat-right-text-fill"></i>
            </button>
            <div class="chat-btn-label">Chat Admin</div>
        </div>

        <div class="chat-btn-row" style="margin-top: 10px;">
            <button class="chat-floating-btn" style="background: #6c47ff; color: #fff; box-shadow: 0 4px 16px rgba(108,71,255,0.45);" onclick="toggleAIChatPanel()" id="aiChatFloatBtn" title="Hỏi AI tư vấn">
                <i class="bi bi-robot"></i>
            </button>
            <div class="chat-btn-label">AI Tư vấn</div>
        </div>

    }
    else
    {
        <div class="chat-btn-row">
            <a href="/Account/Login" class="chat-floating-btn admin-btn text-white text-decoration-none" title="Đăng nhập để chat">
                <i class="bi bi-chat-right-text-fill"></i>
            </a>
            <div class="chat-btn-label">Hỗ trợ</div>
        </div>
    }
</div>

<script>
    // ===== ADMIN CHAT =====
    let chatInterval = null;

    function toggleChatPanel() {
        const panel = document.getElementById('chatPanel');
        const isVisible = panel.style.display === 'flex';
        panel.style.display = isVisible ? 'none' : 'flex';
        if (!isVisible) { loadChatHistory(); chatInterval = setInterval(loadChatHistory, 5000); }
        else            { clearInterval(chatInterval); }
    }

    async function loadChatHistory() {
        try {
            const res = await fetch('/Chat/GetHistory');
            if (res.ok) { const h = await res.json(); renderChat(h); }
        } catch (e) {}
    }

    function renderChat(history) {
        const body = document.getElementById('chatBody');
        if (history.length === 0) {
            body.innerHTML = '<div class="text-center py-5 text-muted small">Bắt đầu cuộc trò chuyện với chúng tôi!</div>';
            return;
        }
        body.innerHTML = history.map(msg => `
            <div class="chat-msg ${msg.isFromAdmin ? 'admin-msg' : 'user-msg'}">
                ${msg.message.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}
                <span class="chat-time">${new Date(msg.timestamp).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>
            </div>
        `).join('');
        document.getElementById('chatBody').scrollTop = 99999;
    }

    function handleChatKey(e) { if (e.key === 'Enter') sendChatMessage(); }

    async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const msg = input.value.trim();
        if (!msg) return;
        input.value = '';
        try {
            const res = await fetch('/Chat/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(msg)
            });
            if (res.ok) loadChatHistory();
        } catch (e) {}
    }

    // ===== AI CHAT =====
    function toggleAIChatPanel() {
        const panel = document.getElementById('aiChatPanel');
        const isVisible = panel.style.display === 'flex';
        panel.style.display = isVisible ? 'none' : 'flex';
        if (!isVisible) {
            document.getElementById('aiChatInput').focus();
            document.getElementById('aiChatBody').scrollTop = 99999;
        }
    }

    function handleAIChatKey(e) { if (e.key === 'Enter') sendAIChatMessage(); }

    async function sendAIChatMessage() {
        const input = document.getElementById('aiChatInput');
        const msg = input.value.trim();
        if (!msg) return;

        const body = document.getElementById('aiChatBody');
        
        // Render user message
        const userHtml = `
            <div class="chat-msg ai-user-msg">
                ${msg.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}
                <span class="chat-time">${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>
            </div>
        `;
        body.insertAdjacentHTML('beforeend', userHtml);
        input.value = '';
        body.scrollTop = 99999;

        // Show typing indicator
        const typingId = 'typing-' + Date.now();
        const typingHtml = `
            <div class="typing-indicator" id="${typingId}">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        body.insertAdjacentHTML('beforeend', typingHtml);
        body.scrollTop = 99999;

        try {
            const res = await fetch('/Chatbot/Chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg })
            });
            
            // Remove typing indicator
            document.getElementById(typingId).remove();

            if (res.ok) {
                const data = await res.json();
                const aiHtml = `
                    <div class="chat-msg ai-msg">
                        ${data.response.replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}
                        <span class="chat-time">${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>
                    </div>
                `;
                body.insertAdjacentHTML('beforeend', aiHtml);
            } else {
                body.insertAdjacentHTML('beforeend', '<div class="chat-msg ai-msg">Dạ, em gặp chút lỗi kỹ thuật ạ. Anh/Chị thử lại nhé!</div>');
            }
        } catch (e) {
            document.getElementById(typingId).remove();
            body.insertAdjacentHTML('beforeend', '<div class="chat-msg ai-msg">Dạ, kết nối mạng có vấn đề ạ.</div>');
        }
        body.scrollTop = 99999;
    }


</script>

<partial name="_NotificationPartial" />
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="~/js/main.js"></script>
<style>
    /* Modern Green Toast - CellphoneS Style */
    .cps-toast-container { position: fixed; top: 80px; left: 50%; transform: translateX(-50%); z-index: 9999; display: none; }
    .cps-toast { background: #4CAF50; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); animation: slideDown 0.3s ease-out; }
    .cps-toast-icon { width: 24px; height: 24px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    @@keyframes slideDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>
<div class="cps-toast-container" id="global-toast">
    <div class="cps-toast">
        <div class="cps-toast-icon">✓</div>
        <span id="toast-message">Thêm vào giỏ hàng thành công</span>
    </div>
</div>

<script>
    function showSuccessToast(message) {
        const toast = document.getElementById('global-toast');
        const msgEl = document.getElementById('toast-message');
        if (!toast || !msgEl) return;
        msgEl.textContent = message || "Thành công!";
        toast.style.display = 'block';
        clearTimeout(window._toastTimer);
        window._toastTimer = setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // Global Confirm function using SweetAlert2
    async function modernConfirm(title, text) {
        const result = await Swal.fire({
            title: title || 'Xác nhận?',
            text: text || 'Bạn có chắc chắn muốn thực hiện hành động này?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d70018',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Đồng ý',
            cancelButtonText: 'Hủy'
        });
        return result.isConfirmed;
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
