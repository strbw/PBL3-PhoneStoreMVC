@if (TempData["success"] != null || TempData["SuccessMessage"] != null || TempData["Success"] != null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
            showSuccessToast('@Html.Raw(TempData["success"] ?? TempData["SuccessMessage"] ?? TempData["Success"])');
        });
    </script>
}
@if (TempData["error"] != null || TempData["ErrorMessage"] != null || TempData["Error"] != null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
            Swal.fire({
                title: 'Lỗi!',
                text: '@Html.Raw(TempData["error"] ?? TempData["ErrorMessage"] ?? TempData["Error"])',
                icon: 'error',
                confirmButtonColor: '#d70018'
            });
        });
    </script>
}
@if (TempData["info"] != null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
            Swal.fire({
                title: 'Thông tin',
                text: '@Html.Raw(TempData["info"])',
                icon: 'info',
                confirmButtonColor: '#d70018'
            });
        });
    </script>
}
