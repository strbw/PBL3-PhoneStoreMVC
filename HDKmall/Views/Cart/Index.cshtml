@model HDKmall.Models.ShoppingCart
@using HDKmall.Helpers
@{
    ViewData["Title"] = "Giỏ hàng";
}

<style>
    .cps-bg { background-color: #f4f6f8; }
    .cps-cart-container { max-width: 680px; margin: 0 auto; }
    .cps-title { font-size: 18px; font-weight: 700; color: #333; }
    .cps-card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); border: none; }
    .cps-text-red { color: #d70018 !important; }
    .cps-bg-red { background-color: #d70018 !important; color: #fff !important; pointer-events: auto; border: none; }
    .cps-bg-red:hover { background-color: #bd0015 !important; color: #fff; }
    .cps-product-name { font-size: 15px; font-weight: 600; color: #333; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
    .cps-product-name:hover { color: #d70018; }
    .cps-qty-btn { width: 32px; height: 32px; background: #fff; border: 1px solid #e5e5e5; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; color: #333; transition: all 0.2s; }
    .cps-qty-btn:hover { background: #f0f0f0; }
    .cps-qty-input { width: 40px; height: 32px; text-align: center; border-top: 1px solid #e5e5e5; border-bottom: 1px solid #e5e5e5; border-left: none; border-right: none; font-size: 14px; outline: none; }
    .cps-btn-delete { background: none; border: none; padding: 0; color: #999; cursor: pointer; transition: all 0.2s; }
    .cps-btn-delete:hover { color: #d70018; }
    .cps-total-group { font-size: 15px; color: #444; }
    .cps-fixed-bottom { position: sticky; bottom: 0; background: #fff; z-index: 1000; box-shadow: 0 -4px 15px rgba(0,0,0,0.05); }
    .cps-checkbox { width: 20px; height: 20px; accent-color: #d70018; cursor: pointer; flex-shrink: 0; }
    .cps-select-all-bar { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); padding: 10px 16px; }
    .cps-item-subtotal { font-size: 14px; color: #d70018; font-weight: 600; white-space: nowrap; }
</style>

<div class="main-content cps-bg py-4 min-vh-100">
    <div class="container cps-cart-container">
        <!-- Header -->
        <div class="d-flex align-items-center mb-3">
            <a asp-controller="Product" asp-action="Index" class="text-dark d-flex align-items-center text-decoration-none" title="Trở về">
                <i class="bi bi-chevron-left fw-bold"></i><span class="ms-1 fw-bold">Trở về</span>
            </a>
            <h1 class="cps-title m-0 flex-grow-1 text-center pe-4">Giỏ hàng của bạn</h1>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        @if (Model != null && Model.Items.Any())
        {
            <form id="checkout-form" asp-controller="Cart" asp-action="ProceedToCheckout" method="post">
                @Html.AntiForgeryToken()

                <!-- Select All Bar -->
                <div class="cps-select-all-bar mb-2 d-flex align-items-center gap-2">
                    <input type="checkbox" id="select-all" class="cps-checkbox" checked />
                    <label for="select-all" class="mb-0 fw-semibold" style="cursor:pointer; font-size:14px;">Chọn tất cả (@Model.Items.Count sản phẩm)</label>
                </div>

                <!-- List Items -->
                <div class="d-flex flex-column gap-3 mb-4" id="cart-items-list">
                    @foreach (var item in Model.Items)
                    {
                        var itemPrice = item.Variant != null ? item.Variant.Price : item.Product.Price;
                        var variantLabel = (item.Variant != null)
                            ? string.Join(" / ", new[] { item.Variant.Color, item.Variant.Capacity }.Where(v => !string.IsNullOrEmpty(v)))
                            : "";
                        <div class="cps-card p-3 cart-item-row" data-item-id="@item.Id" data-price="@itemPrice">
                            <div class="d-flex align-items-start gap-2">
                                <!-- Checkbox -->
                                <input type="checkbox" name="selectedItems" value="@item.Id" class="cps-checkbox item-checkbox mt-1" checked />

                                <!-- Product Image -->
                                <div style="width: 90px; height: 90px; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                                    <img src="@ImageHelper.GetImageUrl(item.Product.ImageUrl)" alt="@item.Product.Name" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                </div>

                                <!-- Product Info -->
                                <div class="flex-grow-1 min-w-0">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId" class="cps-product-name mb-1 d-block">@item.Product.Name</a>
                                    @if (!string.IsNullOrEmpty(variantLabel))
                                    {
                                        <div class="text-muted" style="font-size:12px;">@variantLabel</div>
                                    }
                                    <div class="cps-text-red fw-bold fs-6 mb-2">@itemPrice.ToString("N0")₫</div>

                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                        <!-- Quantity Stepper -->
                                        <div class="d-flex rounded" style="overflow: hidden;">
                                            <button class="cps-qty-btn rounded-start" type="button" onclick="updateQty(@item.Id, @(item.Quantity - 1))">−</button>
                                            <input type="number" class="cps-qty-input fw-medium text-dark bg-white qty-input" id="qty-@item.Id" value="@item.Quantity" min="1" max="99" onchange="updateQty(@item.Id, this.value)">
                                            <button class="cps-qty-btn rounded-end" type="button" onclick="updateQty(@item.Id, @(item.Quantity + 1))">+</button>
                                        </div>

                                        <!-- Item subtotal -->
                                        <span class="cps-item-subtotal" id="subtotal-@item.Id">@((itemPrice * item.Quantity).ToString("N0"))₫</span>

                                        <!-- Delete Button -->
                                        <button type="button" class="cps-btn-delete" title="Xóa" onclick="removeItem(@item.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                                <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Total Bottom Bar -->
                <div class="cps-card p-3 cps-fixed-bottom border-top-0 rounded-bottom-0 rounded-top-4">
                    <div class="d-flex justify-content-between align-items-center mb-2 cps-total-group">
                        <span class="fw-medium">Đã chọn <span id="selected-count">@Model.Items.Count</span> sản phẩm</span>
                        <span class="fw-medium" id="selected-qty-text">(@Model.Items.Sum(x => x.Quantity) sản phẩm)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-bold">Tổng tiền</span>
                        <span class="fs-5 fw-bold cps-text-red" id="total-amount">@Model.Items.Sum(x => (x.Variant != null ? x.Variant.Price : x.Product.Price) * x.Quantity).ToString("N0")₫</span>
                    </div>
                    <button type="submit" class="btn w-100 py-3 fw-bold cps-bg-red text-uppercase rounded-3 shadow-sm d-block text-center" id="checkout-btn">
                        Tiến hành đặt hàng
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="cps-card p-5 text-center mt-4">
                <div class="mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#d70018" class="bi bi-cart-x" viewBox="0 0 16 16">
                      <path d="M7.354 5.646a.5.5 0 1 0-.708.708L7.793 7.5 6.646 8.646a.5.5 0 1 0 .708.708L8.5 8.207l1.146 1.147a.5.5 0 0 0 .708-.708L9.207 7.5l1.147-1.146a.5.5 0 0 0-.708-.708L8.5 6.793z"/>
                      <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                    </svg>
                </div>
                <h6 class="fw-bold text-dark mb-2">Chưa có sản phẩm nào trong giỏ hàng</h6>
                <p class="text-muted mb-4" style="font-size: 14px;">Cùng khám phá hàng ngàn sản phẩm công nghệ tại màn hình chính nhé!</p>
                <a asp-controller="Product" asp-action="Index" class="btn cps-bg-red fw-bold px-4 py-2 rounded-3 text-decoration-none">
                    VỀ TRANG CHỦ
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // Cart item prices map
    const itemPrices = {};
    @foreach (var item in (Model?.Items ?? new List<HDKmall.Models.CartItem>()))
    {
        var price = item.Variant != null ? item.Variant.Price : item.Product.Price;
        <text>itemPrices[@item.Id] = @price;</text>
    }

    // Select All toggle
    const selectAllCb = document.getElementById('select-all');
    if (selectAllCb) {
        selectAllCb.addEventListener('change', function () {
            document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = this.checked);
            updateTotals();
        });
        document.querySelectorAll('.item-checkbox').forEach(cb => {
            cb.addEventListener('change', function () {
                const all = document.querySelectorAll('.item-checkbox');
                const checked = document.querySelectorAll('.item-checkbox:checked');
                selectAllCb.checked = all.length === checked.length;
                updateTotals();
            });
        });
    }

    function updateTotals() {
        const checked = document.querySelectorAll('.item-checkbox:checked');
        let total = 0;
        let totalQty = 0;
        checked.forEach(cb => {
            const itemId = parseInt(cb.value);
            const qtyInput = document.getElementById('qty-' + itemId);
            const qty = qtyInput ? parseInt(qtyInput.value) : 1;
            total += (itemPrices[itemId] || 0) * qty;
            totalQty += qty;
        });
        document.getElementById('selected-count').textContent = checked.length;
        document.getElementById('selected-qty-text').textContent = '(' + totalQty + ' sản phẩm)';
        document.getElementById('total-amount').textContent = total.toLocaleString('vi-VN') + '₫';
    }

    function updateQty(itemId, newQty) {
        newQty = parseInt(newQty);
        if (isNaN(newQty) || newQty < 1) newQty = 1;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch('/Cart/Update', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token || ''
            },
            body: 'cartItemId=' + itemId + '&quantity=' + newQty
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const input = document.getElementById('qty-' + itemId);
                if (input) input.value = newQty;
                const subtotalEl = document.getElementById('subtotal-' + itemId);
                if (subtotalEl) {
                    const price = itemPrices[itemId] || 0;
                    subtotalEl.textContent = (price * newQty).toLocaleString('vi-VN') + '₫';
                }
                updateCartBadge(data.cartCount);
                updateTotals();
            }
        });
    }

    function removeItem(itemId) {
        if (!confirm('Xóa sản phẩm này khỏi giỏ hàng?')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch('/Cart/Remove', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token || ''
            },
            body: 'cartItemId=' + itemId
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const row = document.querySelector('.cart-item-row[data-item-id="' + itemId + '"]');
                if (row) row.remove();
                delete itemPrices[itemId];
                updateCartBadge(data.cartCount);
                updateTotals();
                // If no items left, reload
                if (document.querySelectorAll('.cart-item-row').length === 0) {
                    location.reload();
                }
            }
        });
    }

    function updateCartBadge(count) {
        const badge = document.getElementById('cart-badge');
        if (badge) {
            badge.textContent = count;
            badge.classList.toggle('d-none', count <= 0);
        }
    }
</script>
}

