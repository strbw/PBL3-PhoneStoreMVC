@model HDKmall.ViewModels.PaginationVM
@{
    ViewData["Title"] = "Sản phẩm";
    var currentCat = (int?)ViewBag.SelectedCategoryId;
    var currentBrand = (int?)ViewBag.SelectedBrandId;
    var currentSort = (string)ViewBag.SelectedSortBy ?? "";
    var currentQ = (string)ViewBag.SearchQuery ?? "";
    string PageUrl(int page) {
        var qs = new System.Collections.Specialized.NameValueCollection();
        if (currentCat.HasValue) qs["categoryId"] = currentCat.Value.ToString();
        if (currentBrand.HasValue) qs["brandId"] = currentBrand.Value.ToString();
        if (!string.IsNullOrEmpty(currentSort)) qs["sortBy"] = currentSort;
        if (!string.IsNullOrEmpty(currentQ)) qs["q"] = currentQ;
        qs["page"] = page.ToString();
        return "/Product?" + string.Join("&", qs.AllKeys.Select(k => k + "=" + Uri.EscapeDataString(qs[k])));
    }
    string FilterUrl(string key, string value) {
        var qs = new System.Collections.Specialized.NameValueCollection();
        if (key != "categoryId" && currentCat.HasValue) qs["categoryId"] = currentCat.Value.ToString();
        if (key != "brandId" && currentBrand.HasValue) qs["brandId"] = currentBrand.Value.ToString();
        if (key != "sortBy" && !string.IsNullOrEmpty(currentSort)) qs["sortBy"] = currentSort;
        if (!string.IsNullOrEmpty(currentQ)) qs["q"] = currentQ;
        if (!string.IsNullOrEmpty(value)) qs[key] = value;
        return "/Product?" + string.Join("&", qs.AllKeys.Select(k => k + "=" + Uri.EscapeDataString(qs[k])));
    }
}

<style>
    .filter-pill { display:inline-block; padding:6px 14px; border:1.5px solid #ddd; border-radius:20px; font-size:13px; color:#444; cursor:pointer; text-decoration:none; transition:all .15s; margin:3px; background:#fff; }
    .filter-pill:hover, .filter-pill.active { border-color:#d70018; color:#d70018; background:#fff5f5; font-weight:600; }
    .sort-link { display:inline-block; padding:6px 14px; border:1.5px solid #ddd; border-radius:6px; font-size:13px; color:#444; cursor:pointer; text-decoration:none; transition:all .15s; margin-right:6px; margin-bottom:6px; background:#fff; }
    .sort-link:hover, .sort-link.active { border-color:#d70018; color:#d70018; background:#fff5f5; font-weight:600; }
    .pl-product-card { background:#fff; border-radius:10px; border:1.5px solid #f0f0f0; overflow:hidden; transition:all .2s; display:flex; flex-direction:column; }
    .pl-product-card:hover { border-color:#d70018; box-shadow:0 6px 18px rgba(215,0,24,.1); transform:translateY(-3px); }
    .pl-product-card .img-box { background:#fafafa; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; padding:12px; }
    .pl-product-card img { max-height:100%; object-fit:contain; transition:transform .2s; }
    .pl-product-card:hover img { transform:scale(1.05); }
    .pl-wishlist-btn { background:none; border:none; padding:0; cursor:pointer; color:#aaa; font-size:18px; transition:color .2s; display:flex; align-items:center; gap:4px; }
    .pl-wishlist-btn:hover, .pl-wishlist-btn.active { color:#d70018; }
    .pl-wishlist-btn .heart-label { font-size:12px; color:#888; }
    .pl-wishlist-btn.active .heart-label { color:#d70018; }
    .sidebar-section-title { font-size:14px; font-weight:700; color:#222; margin-bottom:10px; padding-bottom:8px; border-bottom:2px solid #d70018; display:inline-block; }
</style>

@* Hidden form for CSRF token (used by AJAX add-to-cart) *@
<form id="csrf-form" style="display:none">@Html.AntiForgeryToken()</form>

<div style="background:#f4f6f8; min-height:80vh; padding:20px 0 40px;">
  <div class="container">

    <!-- Page title + breadcrumb -->
    <div class="mb-3">
        <nav style="font-size:13px; color:#888;">
            <a href="/" class="text-decoration-none text-muted">Trang chủ</a>
            <span class="mx-1">›</span>
            <span class="text-dark fw-medium">Tất cả sản phẩm</span>
            @if (!string.IsNullOrEmpty(currentQ))
            {
                <span class="mx-1">›</span>
                <span class="text-dark">Kết quả: "@currentQ"</span>
            }
        </nav>
    </div>

    <div class="row gx-4">
      <!-- Sidebar -->
      <div class="col-lg-3 d-none d-lg-block">
        <div style="background:#fff; border-radius:12px; padding:20px; box-shadow:0 1px 6px rgba(0,0,0,.07);">

          <!-- Categories -->
          <div class="mb-4">
            <div class="sidebar-section-title">Danh mục</div>
            <div class="mt-2">
                <a href="@FilterUrl("categoryId", "")" class="filter-pill @(!currentCat.HasValue ? "active" : "")">Tất cả</a>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <a href="@FilterUrl("categoryId", cat.Id.ToString())"
                           class="filter-pill @(currentCat.HasValue && currentCat.Value == (int)cat.Id ? "active" : "")">
                            @cat.Name
                        </a>
                    }
                }
            </div>
          </div>

          <!-- Brands -->
          <div class="mb-2">
            <div class="sidebar-section-title">Thương hiệu</div>
            <div class="mt-2">
                <a href="@FilterUrl("brandId", "")" class="filter-pill @(!currentBrand.HasValue ? "active" : "")">Tất cả</a>
                @if (ViewBag.Brands != null)
                {
                    foreach (var brand in ViewBag.Brands)
                    {
                        <a href="@FilterUrl("brandId", brand.Id.ToString())"
                           class="filter-pill @(currentBrand.HasValue && currentBrand.Value == (int)brand.Id ? "active" : "")">
                            @brand.Name
                        </a>
                    }
                }
            </div>
          </div>

        </div>
      </div>

      <!-- Main content -->
      <div class="col-lg-9">

        <!-- Sort bar -->
        <div style="background:#fff; border-radius:10px; padding:12px 16px; margin-bottom:16px; box-shadow:0 1px 4px rgba(0,0,0,.06); display:flex; align-items:center; flex-wrap:wrap; gap:6px;">
            <span style="font-size:13px; color:#666; margin-right:6px; white-space:nowrap;">Sắp xếp:</span>
            <a href="@FilterUrl("sortBy", "newest")" class="sort-link @(string.IsNullOrEmpty(currentSort) || currentSort == "newest" ? "active" : "")">Mới nhất</a>
            <a href="@FilterUrl("sortBy", "price-low")" class="sort-link @(currentSort == "price-low" ? "active" : "")">Giá tăng dần</a>
            <a href="@FilterUrl("sortBy", "price-high")" class="sort-link @(currentSort == "price-high" ? "active" : "")">Giá giảm dần</a>
            <a href="@FilterUrl("sortBy", "rating")" class="sort-link @(currentSort == "rating" ? "active" : "")">Đánh giá cao</a>
            @if (Model != null)
            {
                <span class="ms-auto text-muted" style="font-size:13px;">@Model.TotalCount sản phẩm</span>
            }
        </div>

        <!-- Mobile filters (compact) -->
        <div class="d-lg-none mb-3">
            <div style="background:#fff; border-radius:10px; padding:12px 16px; box-shadow:0 1px 4px rgba(0,0,0,.06);">
                <div class="mb-2" style="font-size:13px; font-weight:700;">Danh mục:</div>
                <a href="@FilterUrl("categoryId", "")" class="filter-pill @(!currentCat.HasValue ? "active" : "")">Tất cả</a>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <a href="@FilterUrl("categoryId", cat.Id.ToString())"
                           class="filter-pill @(currentCat.HasValue && currentCat.Value == (int)cat.Id ? "active" : "")">
                            @cat.Name
                        </a>
                    }
                }
            </div>
        </div>

        <!-- Product Grid -->
        <div class="row row-cols-2 row-cols-md-3 g-3">
            @if (Model != null && Model.Products != null && Model.Products.Any())
            {
                foreach (var item in Model.Products)
                {
                    <div class="col">
                        <div class="pl-product-card h-100 position-relative">
                            @if (item.DiscountPercent > 0)
                            {
                                <span class="position-absolute top-0 start-0 m-2 badge bg-danger rounded-pill fw-bold z-1" style="font-size: 0.7rem;">Giảm @(item.DiscountPercent)%</span>
                            }
                            <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="img-box d-block text-center text-decoration-none" style="height:180px;">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/Product_Default.jpg" : item.ImageUrl)"
                                     alt="@item.Name" style="max-height:100%; object-fit:contain; display:inline-block;" onerror="this.src='/img/Product_Default.jpg'">
                            </a>
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <div class="text-muted" style="font-size:12px; margin-bottom:4px;">@item.BrandName</div>
                                <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="text-decoration-none text-dark fw-semibold lh-sm mb-2" style="font-size:14px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                    @item.Name @(string.IsNullOrEmpty(item.VersionName) || item.Name.Contains(item.VersionName) ? "" : " - " + item.VersionName)
                                </a>
                                <div class="mt-auto">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <div class="text-danger fw-bold fs-6">@item.Price.ToString("N0")₫</div>
                                        @if (item.OriginalPrice > item.Price)
                                        {
                                            <div class="text-muted text-decoration-line-through small" style="font-size: 0.75rem;">@item.OriginalPrice.Value.ToString("N0")₫</div>
                                        }
                                    </div>
                                    <!-- Stars + Wishlist row -->
                                    <div class="d-flex align-items-center justify-content-between mt-1">
                                        <div style="color:#ffc107; font-size:13px; display:flex; align-items:center; gap:2px;">
                                            @for (int s = 1; s <= 5; s++)
                                            {
                                                <span>@(s <= Math.Round(item.AverageRating) ? "★" : "☆")</span>
                                            }
                                            <span class="text-muted" style="font-size:11px; margin-left:3px;">@item.AverageRating.ToString("F1")</span>
                                        </div>
                                        <button type="button" class="pl-wishlist-btn" onclick="toggleWishlist(event, @item.Id, @(item.VersionId ?? 0), this)" title="Yêu thích">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M8 2.748l-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748z"/>
                                            </svg>
                                            <span class="heart-label">Yêu thích</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 mt-5 text-center">
                    <div class="p-5 bg-white rounded-4 shadow-sm">
                        <div style="font-size: 4rem; color: #ccc;" class="mb-3">😞</div>
                        <h4>Không tìm thấy sản phẩm nào!</h4>
                        <p class="text-muted">Vui lòng thử lại với các tiêu chí tìm kiếm khác.</p>
                        <a href="/Product" class="btn px-4 py-2 mt-2 rounded-pill" style="background:#d70018; color:#fff; font-weight:700;">Xem tất cả</a>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model != null && Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" href="@PageUrl(Model.PageNumber - 1)">‹ Trang trước</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="@PageUrl(i)">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" href="@PageUrl(Model.PageNumber + 1)">Trang sau ›</a>
                    </li>
                </ul>
            </nav>
        }
      </div>
    </div>
  </div>
</div>

<!-- Toast thông báo -->
@* Removed local toast, using global global-toast *@

@section Scripts {
<script>
    // Wishlist stored in localStorage (simple client-side)
    const wishlistKey = 'hdkmall_wishlist';
    function getWishlist() {
        try { return JSON.parse(localStorage.getItem(wishlistKey) || '[]'); } catch { return []; }
    }
    function saveWishlist(list) {
        localStorage.setItem(wishlistKey, JSON.stringify(list));
    }

    function toggleWishlist(e, productId, versionId, btn) {
        e.preventDefault();
        e.stopPropagation();
        const list = getWishlist();
        const key = productId + '_' + versionId;
        const idx = list.indexOf(key);
        if (idx === -1) {
            list.push(key);
            btn.classList.add('active');
            showSuccessToast('❤️ Đã thêm vào danh sách yêu thích!');
        } else {
            list.splice(idx, 1);
            btn.classList.remove('active');
            showSuccessToast('💔 Đã xóa khỏi danh sách yêu thích');
        }
        saveWishlist(list);
    }

    // Mark already-wishlisted items on load
    document.addEventListener('DOMContentLoaded', () => {
        const list = getWishlist();
        document.querySelectorAll('.pl-wishlist-btn').forEach(btn => {
            const onclick = btn.getAttribute('onclick') || '';
            const match = onclick.match(/toggleWishlist\(event,\s*(\d+),\s*(\d+)/);
            if (match) {
                const key = match[1] + '_' + match[2];
                if (list.includes(key)) btn.classList.add('active');
            }
        });
    });
</script>
}
