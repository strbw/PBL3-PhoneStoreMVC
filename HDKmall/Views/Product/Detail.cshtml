@model ProductDetailVM

@{
    ViewData["Title"] = Model.Name;
    ViewData["MetaDescription"] = Model.Description?.Length > 160 ? Model.Description.Substring(0, 157) + "..." : Model.Description;
    
    // Default version is the first one
    var defaultVersion = Model.Versions.FirstOrDefault();
    ViewData["OgImage"] = defaultVersion?.ImageUrl ?? Model.ImageUrl;
}

<style>
    :root {
        --primary-red: #d70018;
        --soft-bg: #f4f6f8;
        --card-shadow: 0 1px 6px rgba(0,0,0,.08);
    }

    .pd-section { background: var(--soft-bg); padding: 24px 0 60px; }
    .glass-card { background: #fff; border-radius: 16px; box-shadow: var(--card-shadow); border: none; }
    
    /* Version & Variant Selectors */
    .selector-label { font-size: 14px; font-weight: 700; color: #444; margin-bottom: 12px; display: block; }
    .option-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 10px; margin-bottom: 24px; }
    
    .option-item {
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        background: #fff;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 56px;
    }
    .option-item:hover { border-color: var(--primary-red); background: #fff5f5; }
    .option-item.active { border-color: var(--primary-red); background: #fff5f5; box-shadow: 0 0 0 1px var(--primary-red); }
    .option-name { font-size: 13px; font-weight: 700; color: #333; display: block; }
    .option-price { font-size: 11px; color: #666; margin-top: 2px; }
    
    /* Price display */
    .price-container { background: #fff5f5; border-radius: 12px; padding: 20px; margin-bottom: 24px; }
    .current-price { color: var(--primary-red); font-size: 2.2rem; font-weight: 800; line-height: 1; }
    
    /* Gallery */
    .gallery-main-wrapper { position: relative; padding: 20px; background: #fff; border-radius: 16px; margin-bottom: 15px; }
    .gallery-main { width: 100%; aspect-ratio: 1/1; object-fit: contain; }
    .thumb-scroll { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px; justify-content: center; }
    .thumb-item { width: 60px; height: 60px; border-radius: 8px; border: 2px solid #eee; cursor: pointer; object-fit: cover; transition: .2s; }
    .thumb-item.active { border-color: var(--primary-red); }

    /* Action Buttons */
    .btn-action-group { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    .btn-buy-now { background: var(--primary-red); color: #fff; border: none; border-radius: 12px; padding: 16px; font-weight: 700; transition: .2s; }
    .btn-buy-now:hover { background: #b5000f; transform: translateY(-2px); }
    .btn-cart-outline { background: #fff; color: var(--primary-red); border: 2px solid var(--primary-red); border-radius: 12px; padding: 16px; font-weight: 700; transition: .2s; }
    .btn-cart-outline:hover { background: var(--primary-red); color: #fff; transform: translateY(-2px); }

    /* Tabs-like sections */
    .section-title { font-size: 18px; font-weight: 800; color: #333; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #f0f0f0; position: relative; }
    .section-title::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 60px; height: 2px; background: var(--primary-red); }
</style>

<div class="pd-section">
    <div class="container">
        <!-- Breadcrumb -->
        <nav class="mb-4 small">
            <a href="/" class="text-muted text-decoration-none">Trang chủ</a>
            <span class="mx-2">/</span>
            <a href="/Product" class="text-muted text-decoration-none">Điện thoại</a>
            @if (Model.Category != null) {
                <span class="mx-2">/</span>
                <a href="/Product?categoryId=@Model.CategoryId" class="text-muted text-decoration-none">@Model.Category.Name</a>
            }
            <span class="mx-2">/</span>
            <span class="fw-bold text-dark">@Model.Name</span>
        </nav>

        <div class="row gx-4">
            <!-- Image Column -->
            <div class="col-lg-5 mb-4">
                <div class="glass-card p-2">
                    <div class="gallery-main-wrapper">
                        <img id="mainDisplayImg" src="@(defaultVersion?.ImageUrl ?? Model.ImageUrl ?? "/img/Product_Default.jpg")" class="gallery-main" />
                    </div>
                    <div class="thumb-scroll" id="galleryThumbs">
                        <!-- Thumbs will be injected by JS based on selected version -->
                    </div>
                </div>
            </div>

            <!-- Content Column -->
            <div class="col-lg-7">
                <div class="glass-card p-4 h-100">
                    <h1 class="fw-bolder mb-3 fs-3">@Model.Name</h1>
                    
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="text-warning fw-bold"><i class="bi bi-star-fill me-1"></i>@Model.AverageRating.ToString("F1")</div>
                        <div class="text-muted small">| @Model.TotalReviews đánh giá</div>
                        @if (Model.Brand != null) {
                            <span class="badge bg-light text-secondary border">@Model.Brand.Name</span>
                        }
                    </div>

                    <!-- Versions (Capacities) -->
                    <span class="selector-label">Chọn dung lượng</span>
                    <div class="option-grid">
                        @foreach (var v in Model.Versions)
                        {
                            <div class="option-item @(v == defaultVersion ? "active" : "")" 
                                 onclick="selectVersion(@v.Id)" 
                                 data-version-id="@v.Id">
                                <span class="option-name">@v.Name</span>
                                <span class="option-price">@v.BasePrice.ToString("N0")₫</span>
                            </div>
                        }
                    </div>

                    <!-- Variants (Colors) -->
                    <span class="selector-label">Chọn màu sắc</span>
                    <div class="option-grid" id="colorSelector">
                        <!-- Colors injected by JS -->
                    </div>

                    <!-- Price -->
                    <div class="price-container">
                        <div class="current-price" id="activePrice">0₫</div>
                        <div class="mt-2 small text-muted"><i class="bi bi-truck me-1"></i> Miễn phí giao hàng toàn quốc</div>
                    </div>

                    <div class="btn-action-group">
                        <button class="btn-buy-now" onclick="handleBuyNow()">MUA NGAY</button>
                        <button class="btn-cart-outline" onclick="handleAddToCart()">THÊM VÀO GIỎ</button>
                    </div>

                    <div class="p-3 rounded-3 border bg-light small text-muted">
                        <div class="d-flex gap-2 mb-2"><i class="bi bi-shield-check text-success"></i> Bảo hành 12 tháng chính hãng</div>
                        <div class="d-flex gap-2"><i class="bi bi-arrow-repeat text-success"></i> Đổi trả trong 30 ngày nếu có lỗi</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Details Row -->
        <div class="row mt-4 gx-4">
            <!-- ... (content omitted for brevity) ... -->
        </div>

        <!-- Related Products Section (Shopee-like) -->
        @if (ViewBag.RelatedProducts != null && ((List<ProductListVM>)ViewBag.RelatedProducts).Any())
        {
            <div class="mt-5">
                <h2 class="section-title">Sản phẩm tương tự</h2>
                <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-3">
                    @foreach (var item in (List<ProductListVM>)ViewBag.RelatedProducts)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card-hover position-relative" style="transition:all .3s">
                                <a href="/product/@(item.Slug ?? item.Id.ToString())" class="text-center p-3 d-block" style="height:180px;">
                                    <img src="@(item.ImageUrl ?? "/img/default.png")" class="img-fluid" style="max-height:100%; object-fit:contain;" alt="@item.Name">
                                </a>
                                <div class="card-body p-3">
                                    <h5 class="card-title fs-6 fw-bold mb-2 text-truncate-2" style="height:38px; overflow:hidden;">
                                        <a href="/product/@(item.Slug ?? item.Id.ToString())" class="text-decoration-none text-dark">@item.Name</a>
                                    </h5>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="text-danger fw-bold">@item.Price.ToString("N0")₫</div>
                                        <div class="text-muted" style="font-size:11px;">Đã bán @(item.ReviewCount * 7 + 5)</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    const productData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    let currentVersion = null;
    let currentVariant = null;

    function selectVersion(id) {
        currentVersion = productData.Versions.find(v => v.Id === id);
        
        // Update Active UI
        document.querySelectorAll('[data-version-id]').forEach(el => {
            el.classList.toggle('active', parseInt(el.dataset.versionId) === id);
        });

        // Update Colors
        const colorWrap = document.getElementById('colorSelector');
        colorWrap.innerHTML = '';
        currentVersion.Variants.forEach(vr => {
            const item = document.createElement('div');
            item.className = 'option-item';
            item.innerHTML = `<span class="option-name">${vr.Color}</span>`;
            item.onclick = () => selectVariant(vr);
            item.dataset.variantId = vr.Id;
            colorWrap.appendChild(item);
        });

        // Update Description
        document.getElementById('versionDescription').innerHTML = 
            (currentVersion.Description || productData.Description || 'Đang cập nhật...').replace(/\n/g, '<br/>');

        // Update Specs
        const specWrap = document.getElementById('specContainer');
        specWrap.innerHTML = '<table class="table table-sm border-0 small"><tbody></tbody></table>';
        const tbody = specWrap.querySelector('tbody');
        currentVersion.Specifications.forEach(s => {
            tbody.innerHTML += `<tr><td class="text-muted border-0 py-2">${s.SpecName}</td><td class="fw-bold border-0 py-2 text-end">${s.SpecValue}</td></tr>`;
        });

        // Select first variant by default
        if (currentVersion.Variants.length > 0) {
            selectVariant(currentVersion.Variants[0]);
        } else {
            updatePrice(currentVersion.BasePrice);
        }

        updateGallery();
    }

    function selectVariant(vr) {
        currentVariant = vr;
        document.querySelectorAll('#colorSelector .option-item').forEach(el => {
            el.classList.toggle('active', parseInt(el.dataset.variantId) === vr.Id);
        });
        
        const displayPrice = vr.Price > 0 ? vr.Price : currentVersion.BasePrice;
        updatePrice(displayPrice);

        if (vr.ImageUrl) {
            document.getElementById('mainDisplayImg').src = vr.ImageUrl;
        }
    }

    function updatePrice(price) {
        document.getElementById('activePrice').innerText = price.toLocaleString('vi-VN') + '₫';
    }

    function updateGallery() {
        const thumbWrap = document.getElementById('galleryThumbs');
        thumbWrap.innerHTML = '';
        
        const imgs = [];
        if (currentVersion.ImageUrl) imgs.push(currentVersion.ImageUrl);
        currentVersion.Variants.forEach(v => { if(v.ImageUrl) imgs.push(v.ImageUrl); });
        
        [...new Set(imgs)].forEach((src, i) => {
            const img = document.createElement('img');
            img.src = src;
            img.className = 'thumb-item' + (i === 0 ? ' active' : '');
            img.onclick = () => {
                document.getElementById('mainDisplayImg').src = src;
                document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
                img.classList.add('active');
            };
            thumbWrap.appendChild(img);
        });
    }

    function handleAddToCart() {
        if (!currentVariant) return alert('Vui lòng chọn màu sắc');
        
        fetch('/Cart/Add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `productId=${productData.Id}&variantId=${currentVariant.Id}&quantity=1`
        }).then(r => r.json()).then(data => {
            if(data.success) {
                alert('Đã thêm vào giỏ hàng!');
                // Update cart badge if exists
            }
        });
    }

    function handleBuyNow() {
        if (!currentVariant) return alert('Vui lòng chọn màu sắc');
        // Logic similar to add to cart then redirect
        handleAddToCart();
        window.location.href = '/Cart';
    }

    // Init
    window.onload = () => {
        if (productData.Versions.length > 0) {
            selectVersion(productData.Versions[0].Id);
        }
    };
</script>