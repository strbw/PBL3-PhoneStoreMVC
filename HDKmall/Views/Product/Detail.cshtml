@model ProductDetailVM

@{
    ViewData["Title"] = Model.Name;
    var colors = Model.Variants.Select(v => v.Color).Where(c => !string.IsNullOrEmpty(c)).Distinct().ToList();
    var capacities = Model.Variants.Select(v => v.Capacity).Where(c => !string.IsNullOrEmpty(c)).Distinct().ToList();
    var totalStock = Model.Variants.Any() ? Model.Variants.Sum(v => v.Stock) : 1;

    // Build image gallery: prioritize ProductImages, fallback to variant images and product image
    var galleryImages = Model.Images.OrderBy(i => i.DisplayOrder).ToList();
    if (!galleryImages.Any() && !string.IsNullOrEmpty(Model.ImageUrl))
    {
        galleryImages = new List<HDKmall.ViewModels.ProductImageVM> {
            new HDKmall.ViewModels.ProductImageVM { Id = 0, ImageUrl = Model.ImageUrl, IsMain = true, DisplayOrder = 0 }
        };
    }

    // ADD: include variant images into gallery (for thumbnails)
    var variantImageUrls = Model.Variants
        .Where(v => !string.IsNullOrEmpty(v.ImageUrl))
        .Select(v => v.ImageUrl)
        .Distinct()
        .ToList();

    foreach (var url in variantImageUrls)
    {
        if (!galleryImages.Any(i => i.ImageUrl == url))
        {
            galleryImages.Add(new HDKmall.ViewModels.ProductImageVM
            {
                Id = 0,
                ImageUrl = url,
                IsMain = false,
                DisplayOrder = galleryImages.Count
            });
        }
    }
}

<style>
    /* ---- Product Detail ---- */
    .pd-section { background: #f4f6f8; padding: 24px 0 40px; }
    .pd-card { background: #fff; border-radius: 12px; box-shadow: 0 1px 6px rgba(0,0,0,.08); }

    /* Image */
    .pd-img-main { width: 100%; aspect-ratio: 1/1; object-fit: contain; border-radius: 10px; background: #fff; padding: 16px; }
    .pd-img-thumb { width: 64px; height: 64px; object-fit: cover; border-radius: 6px; border: 2px solid #eee; cursor: pointer; transition: border-color .15s; }
    .pd-img-thumb.active { border-color: #d70018; }
    .pd-thumbs { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; justify-content: center; }

    /* Variant buttons */
    .variant-btn {
        display: inline-block; padding: 7px 16px; border: 1.5px solid #ddd;
        border-radius: 6px; font-size: 14px; cursor: pointer; background: #fff;
        color: #333; transition: all .15s; user-select: none; margin: 4px 4px 4px 0;
    }
    .variant-btn:hover { border-color: #d70018; color: #d70018; }
    .variant-btn.active { border-color: #d70018; color: #d70018; background: #fff5f5; font-weight: 600; }
    .variant-btn.out-stock { opacity: .5; cursor: not-allowed; text-decoration: line-through; }

    /* Service badges */
    .service-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #444; padding: 6px 0; }
    .service-item .svc-icon { font-size: 18px; flex-shrink: 0; }

    /* Qty */
    .qty-box { display: inline-flex; align-items: center; border: 1.5px solid #ddd; border-radius: 8px; overflow: hidden; }
    .qty-box button { width: 36px; height: 36px; background: #f5f5f5; border: none; font-size: 20px; cursor: pointer; color: #555; }
    .qty-box button:hover { background: #e8e8e8; }
    .qty-box input { width: 44px; height: 36px; text-align: center; border: none; border-left: 1.5px solid #ddd; border-right: 1.5px solid #ddd; font-size: 15px; font-weight: 600; outline: none; }

    /* Buy button */
    .btn-buy-now { background: #d70018; color: #fff; border: none; border-radius: 8px; padding: 14px 0; font-size: 15px; font-weight: 700; cursor: pointer; transition: background .15s; }
    .btn-buy-now:hover { background: #b5000f; }
    .btn-buy-now:disabled { background: #ccc; cursor: not-allowed; }
    .btn-add-cart-outline { background: #fff5f5; color: #d70018; border: 2px solid #d70018; border-radius: 8px; padding: 14px 0; font-size: 15px; font-weight: 700; cursor: pointer; transition: all .15s; }
    .btn-add-cart-outline:hover { background: #d70018; color: #fff; }
    .btn-add-cart-outline:disabled { background: #f5f5f5; color: #ccc; border-color: #ccc; cursor: not-allowed; }
    /* Toast */
    .cart-toast { position: fixed; bottom: 24px; right: 24px; z-index: 9999; min-width: 280px; border-radius: 10px; font-size: 15px; box-shadow: 0 4px 20px rgba(0,0,0,.15); }

    /* Review stars */
    .star-display { color: #ffc107; font-size: 15px; }
    .review-card { border: 1px solid #f0f0f0; border-radius: 12px; padding: 20px; margin-bottom: 16px; background: #fff; transition: transform .15s; }
    .review-card:hover { border-color: #eee; box-shadow: 0 4px 12px rgba(0,0,0,.05); }

    /* Rating selector */
    .rating-stars { display: flex; flex-direction: row-reverse; width: fit-content; gap: 4px; }
    .rating-stars input { display: none; }
    .rating-stars label { font-size: 32px; color: #ddd; cursor: pointer; transition: color .15s, transform .1s; }
    .rating-stars label:hover,
    .rating-stars label:hover ~ label,
    .rating-stars input:checked ~ label { color: #ffc107; transform: scale(1.1); }
    .rating-stars label:active { transform: scale(0.9); }

    /* Tags & Images */
    .review-tag { font-size: 11px; padding: 4px 10px; border-radius: 50px; background: #f8f9fa; color: #666; border: 1px solid #eee; }
    .review-img-thumb { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; cursor: pointer; border: 1px solid #eee; transition: opacity .15s; }
    .review-img-thumb:hover { opacity: 0.8; }
    
    /* Preset Tags Checkbox */
    .preset-tag-btn { cursor: pointer; border: 1px solid #ddd; border-radius: 20px; padding: 5px 15px; font-size: 13px; transition: all .15s; display: inline-block; margin: 0 5px 5px 0; background: #fff; color: #555; }
    .preset-tag-check:checked + .preset-tag-btn { background: #d70018; border-color: #d70018; color: #fff; }
    .preset-tag-check { display: none; }

    /* Filter buttons */
    .filter-btn { border: 1px solid #eee; background: #fff; color: #555; padding: 6px 16px; border-radius: 50px; font-size: 13px; transition: all .15s; }
    .filter-btn:hover { border-color: #d70018; color: #d70018; }
    .filter-btn.active { background: #fff5f5; border-color: #d70018; color: #d70018; font-weight: 600; }

    /* Spec table */
    .spec-table td { padding: 8px 12px; font-size: 14px; }
    .spec-table tr:nth-child(even) { background: #f9f9f9; }
</style>

<div class="pd-section">
  <div class="container">
    <!-- Breadcrumb -->
    <nav class="mb-3" style="font-size:14px;">
        <a href="/" class="text-decoration-none text-muted">Trang chủ</a>
        <span class="mx-1 text-muted">›</span>
        <a href="/Product" class="text-decoration-none text-muted">Sản phẩm</a>
        @if (Model.Category != null)
        {
            <span class="mx-1 text-muted">›</span>
            <a href="/Product?categoryId=@Model.CategoryId" class="text-decoration-none text-muted">@Model.Category.Name</a>
        }
        <span class="mx-1 text-muted">›</span>
        <span class="text-dark fw-medium">@Model.Name</span>
    </nav>

    <div class="row gx-4">
        <!-- Left: Image Gallery -->
        <div class="col-md-5 mb-4 mb-md-0">
            <div class="pd-card p-3 text-center">
                <img id="mainImage"
                     src="@(galleryImages.Any() ? galleryImages.First().ImageUrl : "/img/Product_Default.jpg")"
                     alt="@Model.Name"
                     class="pd-img-main" />

                @if (galleryImages.Count > 1)
                {
                    <div class="pd-thumbs">
                        @foreach (var img in galleryImages)
                        {
                            <img src="@img.ImageUrl"
                                 alt="@Model.Name"
                                 class="pd-img-thumb @(img.IsMain || img == galleryImages.First() ? "active" : "")"
                                 onclick="switchMainImage(this, '@img.ImageUrl')" />
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Right: Info -->
        <div class="col-md-7">
            <div class="pd-card p-4">
                <!-- Brand tag -->
                @if (Model.Brand != null)
                {
                    <a href="/Product?brandId=@Model.BrandId" class="text-decoration-none">
                        <span class="badge bg-light text-secondary border mb-2" style="font-size:12px;">@Model.Brand.Name</span>
                    </a>
                }

                <!-- Name -->
                <h1 class="fs-4 fw-bold text-dark mb-2" style="line-height:1.3;">@Model.Name</h1>

                <!-- Rating row -->
                <div class="d-flex align-items-center gap-2 mb-3" style="font-size:14px;">
                    <span class="star-display">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <span>@(s <= Math.Round(Model.AverageRating) ? "★" : "☆")</span>
                        }
                    </span>
                    <span class="fw-bold">@Model.AverageRating.ToString("F1")</span>
                    <span class="text-muted">(@Model.TotalReviews đánh giá)</span>
                    @if (totalStock > 0)
                    {
                        <span class="ms-auto badge bg-success-subtle text-success border border-success" style="font-size:12px;">Còn hàng</span>
                    }
                    else
                    {
                        <span class="ms-auto badge bg-danger-subtle text-danger border border-danger" style="font-size:12px;">Hết hàng</span>
                    }
                </div>

                <!-- Price -->
                <div class="mb-3" style="background:#fff5f5; border-radius:8px; padding:14px 16px;">
                    <span id="displayPrice" class="text-danger fw-bolder" style="font-size:2rem; line-height:1;">@Model.BasePrice.ToString("N0")₫</span>
                </div>

                <!-- Color variants -->
                @if (colors.Any())
                {
                    <div class="mb-3">
                        <div class="fw-semibold mb-2" style="font-size:14px;">Màu sắc:</div>
                        <div id="colorOptions">
                            @foreach (var color in colors)
                            {
                                var firstVariant = Model.Variants.First(v => v.Color == color);
                                <button type="button"
                                        class="variant-btn @(firstVariant.InStock ? "" : "out-stock")"
                                        data-color="@color"
                                        onclick="selectColor(this)">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Capacity variants -->
                @if (capacities.Any())
                {
                    <div class="mb-3">
                        <div class="fw-semibold mb-2" style="font-size:14px;">Dung lượng:</div>
                        <div id="capacityOptions">
                            @foreach (var cap in capacities)
                            {
                                var firstVariant = Model.Variants.First(v => v.Capacity == cap);
                                <button type="button"
                                        class="variant-btn @(firstVariant.InStock ? "" : "out-stock")"
                                        data-capacity="@cap"
                                        onclick="selectCapacity(this)">
                                    @cap
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Quantity + Add to Cart -->
                <div class="mb-4">
                    <input type="hidden" id="selectedVariantId" value="0" />
                    <input type="hidden" id="selectedQuantity" value="1" />

                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="fw-semibold" style="font-size:14px; white-space:nowrap;">Số lượng:</div>
                        <div class="qty-box">
                            <button type="button" onclick="changeQty(-1)">−</button>
                            <input type="text" id="qtyDisplay" value="1" readonly />
                            <button type="button" onclick="changeQty(1)">+</button>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn-buy-now flex-fill" id="btnBuyNow" @(totalStock <= 0 ? "disabled" : "") onclick="buyNow()">
                            MUA NGAY
                        </button>
                        <button type="button" class="btn-add-cart-outline flex-fill" id="btnAddCart" @(totalStock <= 0 ? "disabled" : "") onclick="addToCartAjax()">
                            🛒 THÊM VÀO GIỎ
                        </button>
                    </div>
                    <!-- Hidden form for fallback -->
                    <form id="add-cart-form" method="post" asp-controller="Cart" asp-action="Add" style="display:none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" id="form-productId" />
                        <input type="hidden" name="variantId" id="form-variantId" value="0" />
                        <input type="hidden" name="quantity" id="form-quantity" value="1" />
                    </form>                </div>

                <!-- Service badges -->
                <div class="border-top pt-3">
                    <div class="service-item"><span class="svc-icon">🛡️</span> Bảo hành chính hãng 12 tháng</div>
                    <div class="service-item"><span class="svc-icon">🔄</span> Đổi trả miễn phí trong 30 ngày</div>
                    <div class="service-item"><span class="svc-icon">🚚</span> Giao hàng toàn quốc, miễn phí từ 500K</div>
                    <div class="service-item"><span class="svc-icon">✅</span> Sản phẩm chính hãng 100%</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Description + Specs + Reviews row -->
    <div class="row gx-4 mt-4">
        <div class="col-lg-8">
            <!-- Description tab card -->
            <div class="pd-card p-4 mb-4">
                <h5 class="fw-bold mb-3 section-title">Mô tả sản phẩm</h5>
                <div style="font-size:15px; color:#444; line-height:1.7;">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                    }
                    else
                    {
                        <p class="text-muted">Chưa có mô tả sản phẩm.</p>
                    }
                </div>
            </div>

            <!-- Specifications -->
            @if (Model.Specifications.Any())
            {
                <div class="pd-card p-4 mb-4">
                    <h5 class="fw-bold mb-3 section-title">Thông số kỹ thuật</h5>
                    <table class="table spec-table mb-0">
                        <tbody>
                            @foreach (var spec in Model.Specifications)
                            {
                                <tr>
                                    <td class="text-muted fw-semibold" style="width:40%;">@spec.SpecName</td>
                                    <td>@spec.SpecValue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Reviews -->
            <div class="pd-card p-4">
                <h5 class="fw-bold mb-4 section-title">Đánh giá từ khách hàng</h5>

                <!-- Rating summary -->
                <div class="row align-items-center mb-4 p-4" style="background:#fafafa; border-radius:15px; border: 1px solid #eee;">
                    <div class="col-md-4 text-center border-end">
                        <div class="text-danger fw-bolder" style="font-size:3.5rem; line-height:1;">@Model.AverageRating.ToString("F1")</div>
                        <div class="star-display fs-5 mb-2">
                            @for (int s = 1; s <= 5; s++) { <span>@(s <= Math.Round(Model.AverageRating) ? "★" : "☆")</span> }
                        </div>
                        <div class="text-muted">@Model.TotalReviews đánh giá</div>
                    </div>
                    <div class="col-md-8 ps-md-4">
                        @for (int i = 5; i >= 1; i--)
                        {
                            var count = Model.Reviews.Count(r => r.Rating == i);
                            var percent = Model.TotalReviews > 0 ? (count * 100 / Model.TotalReviews) : 0;
                            <div class="d-flex align-items-center gap-2 mb-1" style="font-size:13px;">
                                <div style="width:10px;">@i</div>
                                <div class="text-warning" style="width:12px;">★</div>
                                <div class="progress flex-grow-1" style="height:6px; background:#eee;">
                                    <div class="progress-bar bg-warning" style="width:@percent%"></div>
                                </div>
                                <div class="text-muted" style="width:30px;">@percent%</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Review Filter & Sort -->
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 p-3 bg-light rounded-3">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="text-muted small fw-bold me-2">Lọc theo:</span>
                        <button type="button" class="filter-btn active" onclick="filterReviews(0, this)">Tất cả</button>
                        <button type="button" class="filter-btn" onclick="filterReviews(5, this)">5 ★</button>
                        <button type="button" class="filter-btn" onclick="filterReviews(4, this)">4 ★</button>
                        <button type="button" class="filter-btn" onclick="filterReviews(3, this)">3 ★</button>
                        <button type="button" class="filter-btn" onclick="filterReviews(2, this)">2 ★</button>
                        <button type="button" class="filter-btn" onclick="filterReviews(1, this)">1 ★</button>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small fw-bold">Sắp xếp:</span>
                        <select class="form-select form-select-sm border-0 rounded-pill px-3 shadow-sm" onchange="sortReviews(this.value)" style="width:140px;">
                            <option value="newest">Mới nhất</option>
                            <option value="highest">Đánh giá cao</option>
                            <option value="lowest">Đánh giá thấp</option>
                        </select>
                    </div>
                </div>

                @if ((bool)(ViewBag.CanReview ?? false))
                {
                    <div class="mb-4 p-4 shadow-sm border" style="background:#fff; border-radius:15px;">
                        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                            <span class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; font-size:12px;"><i class="bi bi-pencil-fill"></i></span>
                            Viết đánh giá của bạn
                        </h6>
                        <form method="post" asp-controller="Review" asp-action="Add" enctype="multipart/form-data">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted mb-1">Mức độ hài lòng</label>
                                <div class="rating-stars">
                                    @for (int ri = 5; ri >= 1; ri--)
                                    {
                                        <input type="radio" name="rating" value="@ri" id="r_@ri" required />
                                        <label for="r_@ri">★</label>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted mb-1">Cảm nhận của bạn</label>
                                <textarea class="form-control" name="comment" rows="3" placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..." required style="border-radius:10px; font-size:14px; border-color:#eee;"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted mb-2">Thêm thẻ (Tùy chọn)</label>
                                <div class="d-flex flex-wrap">
                                    @foreach (var tag in new[] { "Sản phẩm tốt", "Giao hàng nhanh", "Đóng gói kỹ", "Đúng mô tả", "Giá hợp lý" })
                                    {
                                        <label class="preset-tag">
                                            <input type="checkbox" name="tags" value="@tag" class="preset-tag-check" />
                                            <span class="preset-tag-btn">@tag</span>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted mb-2">Đính kèm ảnh thực tế</label>
                                <div class="d-flex align-items-center gap-3">
                                    <label class="border rounded-3 d-flex flex-column align-items-center justify-content-center" style="width:80px; height:80px; cursor:pointer; background:#f8f9fa; border-style:dashed !important;">
                                        <input type="file" name="ImageFile" class="d-none" accept="image/*" onchange="previewReviewImg(this)" />
                                        <i class="bi bi-camera text-muted fs-4"></i>
                                        <span style="font-size:10px;" class="text-muted">Thêm ảnh</span>
                                    </label>
                                    <div id="reviewImgPreview" class="d-none">
                                        <img src="" class="rounded" style="width:80px; height:80px; object-fit:cover; border:1px solid #eee;" />
                                    </div>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-danger fw-bold px-5 py-2" style="border-radius:30px;">Gửi đánh giá ngay</button>
                            </div>
                        </form>
                    </div>
                }
                else if (User.Identity!.IsAuthenticated)
                {
                    <div class="alert alert-light border mb-4" style="border-radius:10px;">
                        <i class="bi bi-bag-x me-1 text-muted"></i> Chỉ khách hàng đã mua và nhận sản phẩm mới có thể đánh giá.
                        <a href="@Url.Action("History", "Order", new { status = "delivered" })" class="text-danger fw-bold ms-1">Xem đơn hàng đã nhận</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border mb-4" style="border-radius:10px;">
                        <a href="@Url.Action("Login", "Account")" class="text-danger fw-bold">Đăng nhập</a> để viết đánh giá sản phẩm.
                    </div>
                }

                <!-- Review list -->
                <div id="reviewList">
                    @if (Model.Reviews.Any())
                    {
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-card" data-rating="@review.Rating" data-date="@review.CreatedAt.Ticks">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-danger bg-opacity-10 text-danger d-flex align-items-center justify-content-center fw-bold" style="width:36px; height:36px; font-size:14px;">
                                            @review.UserName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark" style="font-size:14px;">@review.UserName</div>
                                            <div class="star-display" style="font-size:12px;">
                                                @for (int s = 1; s <= 5; s++) { <span class="me-1">@(s <= review.Rating ? "★" : "☆")</span> }
                                                <span class="text-success ms-2 small"><i class="bi bi-check-circle-fill"></i> Đã mua tại HDKmall</span>
                                            </div>
                                        </div>
                                    </div>
                                    <small class="text-muted" style="font-size:12px;">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                
                                <p class="mb-3" style="font-size:14px; color:#444; line-height:1.6;">@review.Comment</p>

                                @if (!string.IsNullOrEmpty(review.Tags))
                                {
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        @{
                                            try {
                                                var tags = System.Text.Json.JsonSerializer.Deserialize<List<string>>(review.Tags);
                                                if (tags != null)
                                                {
                                                    foreach (var tag in tags)
                                                    {
                                                        <span class="review-tag">#@tag</span>
                                                    }
                                                }
                                            } catch {}
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(review.ImageUrl))
                                {
                                    <div class="mb-2">
                                        <img src="@review.ImageUrl" class="review-img-thumb" onclick="window.open(this.src)" />
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                            <p>Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right info card -->
        <div class="col-lg-4">
            <div class="pd-card p-4">
                <h6 class="fw-bold mb-3 section-title">Thông tin sản phẩm</h6>
                <table class="table table-sm table-borderless mb-0" style="font-size:14px;">
                    <tbody>
                        @if (Model.Brand != null)
                        {
                            <tr><td class="text-muted ps-0">Thương hiệu</td><td class="fw-semibold"><a href="/Product?brandId=@Model.BrandId" class="text-decoration-none text-dark">@Model.Brand.Name</a></td></tr>
                        }
                        @if (Model.Category != null)
                        {
                            <tr><td class="text-muted ps-0">Danh mục</td><td class="fw-semibold"><a href="/Product?categoryId=@Model.CategoryId" class="text-decoration-none text-dark">@Model.Category.Name</a></td></tr>
                        }
                        <tr>
                            <td class="text-muted ps-0">Tình trạng</td>
                            <td>
                                @if (totalStock > 0) { <span class="text-success fw-semibold">Còn hàng</span> }
                                else { <span class="text-danger fw-semibold">Hết hàng</span> }
                            </td>
                        </tr>
                        @if (colors.Any())
                        {
                            <tr><td class="text-muted ps-0">Màu sắc</td><td class="fw-semibold">@string.Join(", ", colors)</td></tr>
                        }
                        @if (capacities.Any())
                        {
                            <tr><td class="text-muted ps-0">Dung lượng</td><td class="fw-semibold">@string.Join(", ", capacities)</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
  </div>
</div>

<script>
    // Variant data from server
    const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Variants.Select(v => new {
        id = v.Id,
        color = v.Color ?? "",
        capacity = v.Capacity ?? "",
        price = v.Price,
        stock = v.Stock,
        imageUrl = v.ImageUrl ?? ""
    })));

    let selectedColor = '';
    let selectedCapacity = '';

    function switchMainImage(thumb, url) {
        document.getElementById('mainImage').src = url;
        document.querySelectorAll('.pd-img-thumb').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
    }

    function selectColor(btn) {
        document.querySelectorAll('#colorOptions .variant-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedColor = btn.dataset.color;
        updateSelectedVariant();
    }

    function selectCapacity(btn) {
        document.querySelectorAll('#capacityOptions .variant-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedCapacity = btn.dataset.capacity;
        updateSelectedVariant();
    }

    function updateSelectedVariant() {
        const match = variants.find(v =>
            (!selectedColor || v.color === selectedColor) &&
            (!selectedCapacity || v.capacity === selectedCapacity)
        );
        if (match) {
            document.getElementById('selectedVariantId').value = match.id;
            document.getElementById('form-variantId').value = match.id;
            if (match.price > 0) {
                document.getElementById('displayPrice').innerText =
                    match.price.toLocaleString('vi-VN') + '₫';
            }
            if (match.imageUrl) {
                document.getElementById('mainImage').src = match.imageUrl;
                document.querySelectorAll('.pd-img-thumb').forEach(t => t.classList.remove('active'));
            }
        }
    }

    function changeQty(delta) {
        const input = document.getElementById('qtyDisplay');
        const hidden = document.getElementById('selectedQuantity');
        let val = parseInt(input.value) + delta;
        if (val < 1) val = 1;
        input.value = val;
        hidden.value = val;
        document.getElementById('form-quantity').value = val;
    }

    function addToCartAjax() {
        const productId = @Model.Id;
        const variantId = document.getElementById('selectedVariantId').value || 0;
        const quantity = document.getElementById('selectedQuantity').value || 1;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        fetch('/Cart/Add', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token || ''
            },
            body: `productId=${productId}&variantId=${variantId}&quantity=${quantity}`
        })
        .then(r => r.json())
        .then(data => {
            showCartToast(data.message, data.success ? 'success' : 'danger');
            if (data.success) {
                const badge = document.getElementById('cart-badge');
                if (badge) {
                    badge.textContent = data.cartCount;
                    badge.classList.remove('d-none');
                }
            }
        })
        .catch(() => {
            document.getElementById('add-cart-form').submit();
        });
    }

    function buyNow() {
        const productId = @Model.Id;
        const variantId = document.getElementById('selectedVariantId').value || 0;
        const quantity = document.getElementById('selectedQuantity').value || 1;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        fetch('/Cart/Add', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token || ''
            },
            body: `productId=${productId}&variantId=${variantId}&quantity=${quantity}`
        })
        .then(r => r.json())
        .then(data => {
            window.location.href = '/Cart';
        })
        .catch(() => {
            document.getElementById('add-cart-form').submit();
        });
    }

    function showCartToast(msg, type) {
        let toast = document.getElementById('cart-toast-el');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'cart-toast-el';
            toast.className = 'cart-toast alert d-flex align-items-center gap-2';
            document.body.appendChild(toast);
        }
        toast.className = `cart-toast alert alert-${type} d-flex align-items-center gap-2`;
        toast.innerHTML = `<span>${type === 'success' ? '✅' : '❌'}</span> <span>${msg}</span>`;
        toast.style.display = 'block';
        clearTimeout(toast._timer);
        toast._timer = setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // Review logic
    function previewReviewImg(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('reviewImgPreview');
                preview.querySelector('img').src = e.target.result;
                preview.classList.remove('d-none');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function filterReviews(stars, btn) {
        // Toggle active class
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter elements
        const cards = document.querySelectorAll('.review-card');
        cards.forEach(card => {
            const rating = parseInt(card.dataset.rating);
            if (stars === 0 || rating === stars) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function sortReviews(type) {
        const list = document.getElementById('reviewList');
        const cards = Array.from(list.querySelectorAll('.review-card'));

        cards.sort((a, b) => {
            if (type === 'newest') {
                return b.dataset.date - a.dataset.date;
            } else if (type === 'highest') {
                return b.dataset.rating - a.dataset.rating;
            } else if (type === 'lowest') {
                return a.dataset.rating - b.dataset.rating;
            }
            return 0;
        });

        cards.forEach(card => list.appendChild(card));
    }

    // Auto-select first available variants
    const firstColorBtn = document.querySelector('#colorOptions .variant-btn:not(.out-stock)');
    if (firstColorBtn) firstColorBtn.click();
    const firstCapBtn = document.querySelector('#capacityOptions .variant-btn:not(.out-stock)');
    if (firstCapBtn) firstCapBtn.click();
</script>