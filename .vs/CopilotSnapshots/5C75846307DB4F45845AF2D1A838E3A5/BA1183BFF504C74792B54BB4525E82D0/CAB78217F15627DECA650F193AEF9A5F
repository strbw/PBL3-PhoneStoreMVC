  <a href="index.html" class="mobile-nav-item">🏠 Trang chủ</a>
  <a href="products.html?cat=dien-thoai" class="mobile-nav-item">📱 Điện thoại</a>
  <a href="products.html?cat=may-tinh-bang" class="mobile-nav-item">📟 Máy tính bảng</a>
  <a href="products.html?cat=phu-kien" class="mobile-nav-item">🎧 Phụ kiện</a>
