        </a>
        <div class="header-user-menu" style="display:none">
          <span class="btn-icon">👤</span>
          <span class="user-name"></span>
          <a href="orders.html" class="header-btn" style="margin-left:4px">📦</a>
          <a href="#" class="header-btn logout-btn" title="Đăng xuất">⏻</a>
        </div>
      </div>
    </div>
  </div>
  <nav class="header-nav">
    <div class="container">
      <a href="products.html?cat=dien-thoai" class="nav-item"><span class="nav-icon">📱</span>Điện thoại</a>
      <a href="products.html?cat=may-tinh-bang" class="nav-item"><span class="nav-icon">📟</span>Máy tính bảng</a>
      <a href="products.html?cat=phu-kien" class="nav-item"><span class="nav-icon">🎧</span>Phụ kiện</a>
      <a href="products.html?cat=laptop" class="nav-item"><span class="nav-icon">💻</span>Laptop</a>
      <a href="orders.html" class="nav-item"><span class="nav-icon">📦</span>Đơn hàng</a>
      <a href="products.html" class="nav-item" style="margin-left:auto;background:rgba(255,255,255,.15)">🔥 Khuyến mãi</a>
    </div>
  </nav>
</header>

<!-- MAIN -->
<main>
  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:480px">

    <!-- Breadcrumb -->
    <div class="breadcrumb" style="margin-bottom:24px">
      <a href="index.html">Trang chủ</a>
      <span class="breadcrumb-sep">›</span>
      <span id="breadcrumb-label">Đăng nhập</span>
    </div>

    <!-- Already logged in -->
    <div id="already-logged-in" style="display:none;text-align:center;padding:40px 0">
      <div style="font-size:64px;margin-bottom:16px">👋</div>
      <h2 style="margin-bottom:8px">Xin chào, <span id="logged-in-name"></span>!</h2>
      <p style="color:#666;margin-bottom:24px">Bạn đã đăng nhập thành công.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="orders.html" class="btn-primary">📦 Xem đơn hàng</a>
        <a href="index.html" class="btn-outline">🏠 Về trang chủ</a>
        <button class="btn-outline logout-btn" style="color:var(--primary);border-color:var(--primary)">⏻ Đăng xuất</button>
      </div>
    </div>

    <!-- Auth forms -->
    <div id="auth-forms">
      <!-- Tabs -->
      <div class="auth-tabs">
        <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">Đăng nhập</button>
        <button class="auth-tab" id="tab-register" onclick="switchTab('register')">Đăng ký</button>
      </div>

      <!-- Login Form -->
      <div id="form-login" class="auth-form-panel">
        <h2 class="auth-title">Chào mừng trở lại!</h2>
        <p class="auth-subtitle">Đăng nhập để xem đơn hàng và nhận ưu đãi cá nhân.</p>

        <form id="login-form" action="/Account/Login" method="post">
          <div class="form-group">
            <label class="form-label" for="login-email">Email <span class="required">*</span></label>
            <input type="email" id="login-email" name="Email" class="form-input" placeholder="example@email.com" required />
            <div class="form-error" id="login-email-err"></div>
          </div>
          <div class="form-group">
            <label class="form-label" for="login-password">Mật khẩu <span class="required">*</span></label>
            <div class="input-password-wrapper">
              <input type="password" id="login-password" name="Password" class="form-input" placeholder="Nhập mật khẩu" required />
              <button type="button" class="toggle-password" onclick="togglePassword('login-password', this)">👁</button>
            </div>
            <div class="form-error" id="login-password-err"></div>
          </div>
          <div class="form-error" id="login-general-err" style="margin-bottom:12px"></div>
          <button type="submit" class="btn-primary btn-full" id="login-submit-btn">Đăng nhập</button>
        </form>

        <div class="auth-footer-text">
          Chưa có tài khoản?
          <a href="#" onclick="switchTab('register');return false">Đăng ký ngay</a>
        </div>
      </div>

      <!-- Register Form -->
      <div id="form-register" class="auth-form-panel" style="display:none">
        <h2 class="auth-title">Tạo tài khoản mới</h2>
        <p class="auth-subtitle">Đăng ký để mua sắm và theo dõi đơn hàng dễ dàng hơn.</p>

        <form id="register-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="reg-name">Họ và tên <span class="required">*</span></label>
            <input type="text" id="reg-name" class="form-input" placeholder="Nguyễn Văn A" required />
            <div class="form-error" id="reg-name-err"></div>
          </div>
          <div class="form-group">
            <label class="form-label" for="reg-email">Email <span class="required">*</span></label>
            <input type="email" id="reg-email" class="form-input" placeholder="example@email.com" required />
            <div class="form-error" id="reg-email-err"></div>
          </div>
          <div class="form-group">
            <label class="form-label" for="reg-phone">Số điện thoại <span class="required">*</span></label>
            <input type="tel" id="reg-phone" class="form-input" placeholder="09xxxxxxxx" required />
            <div class="form-error" id="reg-phone-err"></div>
          </div>
          <div class="form-group">
            <label class="form-label" for="reg-password">Mật khẩu <span class="required">*</span></label>
            <div class="input-password-wrapper">
              <input type="password" id="reg-password" class="form-input" placeholder="Ít nhất 6 ký tự" required />
              <button type="button" class="toggle-password" onclick="togglePassword('reg-password', this)">👁</button>
            </div>
            <div class="form-error" id="reg-password-err"></div>
          </div>
          <div class="form-group">
            <label class="form-label" for="reg-confirm">Xác nhận mật khẩu <span class="required">*</span></label>
            <div class="input-password-wrapper">
              <input type="password" id="reg-confirm" class="form-input" placeholder="Nhập lại mật khẩu" required />
              <button type="button" class="toggle-password" onclick="togglePassword('reg-confirm', this)">👁</button>
            </div>
            <div class="form-error" id="reg-confirm-err"></div>
          </div>
          <div class="form-group">
            <label class="form-check">
              <input type="checkbox" id="reg-terms" required />
              <span>Tôi đồng ý với <a href="#">điều khoản sử dụng</a> và <a href="#">chính sách bảo mật</a></span>
            </label>
            <div class="form-error" id="reg-terms-err"></div>
          </div>
          <div class="form-error" id="reg-general-err" style="margin-bottom:12px"></div>
          <button type="submit" class="btn-primary btn-full" id="reg-submit-btn">Đăng ký</button>
        </form>

        <div class="auth-footer-text">
          Đã có tài khoản?
          <a href="#" onclick="switchTab('login');return false">Đăng nhập ngay</a>
        </div>
      </div>
    </div>
    <!-- /auth-forms -->

  </div>
</main>

<!-- FOOTER -->
