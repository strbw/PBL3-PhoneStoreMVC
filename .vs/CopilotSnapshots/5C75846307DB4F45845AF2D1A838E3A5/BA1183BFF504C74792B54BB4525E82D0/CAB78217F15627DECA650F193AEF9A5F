  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <div class="logo" style="margin-bottom:12px">
          <div class="logo-icon">📱</div>
          <div class="logo-text" style="font-size:20px">Phone<span>Store</span></div>
        </div>
        <p class="footer-desc">Cửa hàng điện thoại và phụ kiện chính hãng với hơn 200 sản phẩm từ các thương hiệu uy tín trên thế giới.</p>
      </div>
      <div>
        <div class="footer-heading">Tài khoản</div>
        <div class="footer-links">
          <a href="auth.html">Đăng nhập</a>
          <a href="auth.html?tab=register">Đăng ký</a>
          <a href="orders.html">Đơn hàng của tôi</a>
        </div>
      </div>
      <div>
        <div class="footer-heading">Hỗ trợ</div>
        <div class="footer-links">
          <a href="#">Chính sách bảo hành</a>
          <a href="#">Chính sách đổi trả</a>
          <a href="orders.html">Tra cứu đơn hàng</a>
          <a href="#">Liên hệ</a>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      © 2026 PhoneStore. All rights reserved. | Được xây dựng với ❤️ bởi PBL3 Team
    </div>
  </div>
</footer>

<script src="js/data.js"></script>
<script src="js/cart.js"></script>
<script src="js/auth.js"></script>
<script src="js/main.js"></script>
<script>
  // ---- Tab switching ----
  function switchTab(tab) {
    document.getElementById('form-login').style.display = tab === 'login' ? '' : 'none';
    document.getElementById('form-register').style.display = tab === 'register' ? '' : 'none';
    document.getElementById('tab-login').classList.toggle('active', tab === 'login');
    document.getElementById('tab-register').classList.toggle('active', tab === 'register');
    document.getElementById('breadcrumb-label').textContent = tab === 'login' ? 'Đăng nhập' : 'Đăng ký';
  }

  // ---- Toggle password visibility ----
  function togglePassword(inputId, btn) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
      input.type = 'text';
      btn.textContent = '🙈';
    } else {
      input.type = 'password';
      btn.textContent = '👁';
    }
  }

  // ---- Validation helpers ----
  function showError(id, msg) {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.style.display = msg ? 'block' : 'none'; }
  }

  function clearErrors(...ids) {
    ids.forEach(id => showError(id, ''));
  }

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function isValidPhone(phone) {
    return /^(0[3-9])\d{8}$/.test(phone.replace(/\s/g, ''));
  }

  // ---- Login form ----
  document.getElementById('login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    clearErrors('login-email-err', 'login-password-err', 'login-general-err');

    const email = document.getElementById('login-email').value.trim();
    const password = document.getElementById('login-password').value;
    let valid = true;

    if (!email) { showError('login-email-err', 'Vui lòng nhập email.'); valid = false; }
    else if (!isValidEmail(email)) { showError('login-email-err', 'Email không hợp lệ.'); valid = false; }

    if (!password) { showError('login-password-err', 'Vui lòng nhập mật khẩu.'); valid = false; }

    if (!valid) return;

      const result = await Auth.login(email, password);
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng nhập';

      if (result.success) {
          Cart.showToast('Đăng nhập thành công! Chào ' + result.user.fullName);

          setTimeout(() => {
              // Lấy role của user (mặc định là Customer nếu không có)
              const userRole = result.user.role || 'Customer';

              // Nếu có tham số redirect trên URL thì ưu tiên chuyển về đó (ví dụ từ trang thanh toán)
              const redirectParam = new URLSearchParams(window.location.search).get('redirect');

              if (redirectParam) {
                  window.location.href = redirectParam;
              } else if (userRole === 'Admin' || userRole === 'Staff') {
                  // Nếu là Admin hoặc Staff thì chuyển thẳng vào trang Admin
                  window.location.href = 'admin.html';
              } else {
                  // User bình thường thì về trang chủ
                  window.location.href = 'index.html';
              }
          }, 800);
      } else {
          showError('login-general-err', result.message);
      }
  });

  // ---- Register form ----
  document.getElementById('register-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    clearErrors('reg-name-err', 'reg-email-err', 'reg-phone-err', 'reg-password-err', 'reg-confirm-err', 'reg-terms-err', 'reg-general-err');

    const name = document.getElementById('reg-name').value.trim();
    const email = document.getElementById('reg-email').value.trim();
    const phone = document.getElementById('reg-phone').value.trim();
    const password = document.getElementById('reg-password').value;
    const confirm = document.getElementById('reg-confirm').value;
    const terms = document.getElementById('reg-terms').checked;
    let valid = true;

    if (!name || name.length < 2) { showError('reg-name-err', 'Họ tên phải có ít nhất 2 ký tự.'); valid = false; }
    if (!email) { showError('reg-email-err', 'Vui lòng nhập email.'); valid = false; }
    else if (!isValidEmail(email)) { showError('reg-email-err', 'Email không hợp lệ.'); valid = false; }
    if (!phone) { showError('reg-phone-err', 'Vui lòng nhập số điện thoại.'); valid = false; }
    else if (!isValidPhone(phone)) { showError('reg-phone-err', 'Số điện thoại không hợp lệ (VD: 0901234567).'); valid = false; }
    if (!password || password.length < 6) { showError('reg-password-err', 'Mật khẩu phải có ít nhất 6 ký tự.'); valid = false; }
    if (password !== confirm) { showError('reg-confirm-err', 'Mật khẩu xác nhận không khớp.'); valid = false; }
    if (!terms) { showError('reg-terms-err', 'Bạn phải đồng ý với điều khoản sử dụng.'); valid = false; }

    if (!valid) return;

    const submitBtn = document.getElementById('reg-submit-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Đang đăng ký...';

    const result = await Auth.register(name, email, phone, password);
    submitBtn.disabled = false;
    submitBtn.textContent = 'Đăng ký';
    if (result.success) {
      Cart.showToast('Đăng ký thành công! Chào mừng ' + result.user.fullName);
      setTimeout(() => { window.location.href = 'index.html'; }, 800);
    } else {
      showError('reg-general-err', result.message);
    }
  });

  // ---- Check if already logged in ----
  document.addEventListener('DOMContentLoaded', () => {
    // Check for ?tab=register
    const tab = new URLSearchParams(window.location.search).get('tab');
    if (tab === 'register') switchTab('register');

    const user = Auth.getCurrentUser();
    if (user) {
      document.getElementById('already-logged-in').style.display = '';
      document.getElementById('auth-forms').style.display = 'none';
      document.getElementById('logged-in-name').textContent = user.fullName;
    }
  });
</script>
</body>
</html>
