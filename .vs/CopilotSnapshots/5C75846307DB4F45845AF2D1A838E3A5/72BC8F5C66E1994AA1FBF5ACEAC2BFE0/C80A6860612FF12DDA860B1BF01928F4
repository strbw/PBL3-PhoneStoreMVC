using Microsoft.AspNetCore.Authentication;
using Microsoft.AspNetCore.Authentication.Cookies;
using Microsoft.AspNetCore.Mvc;
using HDKmall.BLL.Interfaces;
using HDKmall.ViewModels;
using System.Security.Claims;

namespace HDKmall.Controllers.Api
{
    [Route("api/[controller]")]
    [ApiController]
    public class AuthController : ControllerBase
    {
        private readonly IAccountService _accountService;

        public AuthController(IAccountService accountService)
        {
            _accountService = accountService;
        }

        [HttpPost("login")]
        public async Task<IActionResult> Login([FromBody] LoginVM model)
        {
            if (!ModelState.IsValid)
            {
                return BadRequest(new { success = false, message = "Dữ liệu không hợp lệ." });
            }

            var user = _accountService.Authenticate(model);
            if (user != null)
            {
                var claims = new List<Claim>
                {
                    new Claim(ClaimTypes.Name, user.FullName),
                    new Claim(ClaimTypes.Email, user.Email),
                    new Claim(ClaimTypes.Role, user.Role?.RoleName ?? "Customer")
                };

                var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
                var principal = new ClaimsPrincipal(identity);

                await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);

                return Ok(new
                {
                    success = true,
                    user = new { fullName = user.FullName, email = user.Email, role = user.Role?.RoleName ?? "Customer" }
                });
            }

            return Ok(new { success = false, message = "Email hoặc mật khẩu không đúng." });
        }

        [HttpPost("register")]
        public IActionResult Register([FromBody] RegisterVM model)
        {
            if (!ModelState.IsValid)
            {
                return BadRequest(new { success = false, message = "Dữ liệu không hợp lệ." });
            }

            // Client side uses "phone", but RegisterVM expects "PhoneNumber". Need to map carefully.
            // Oh actually RegisterVM uses "PhoneNumber", let's check the JSON payload which says 'phone'.
            
            var success = _accountService.RegisterUser(model);
            if (success)
            {
                var user = _accountService.Authenticate(new LoginVM { Email = model.Email, Password = model.Password });
                return Ok(new
                {
                    success = true,
                    message = "Đăng ký thành công.",
                    user = new { fullName = model.FullName, email = model.Email, role = "Customer" }
                });
            }

            return Ok(new { success = false, message = "Email này đã được sử dụng." });
        }
    }
}
