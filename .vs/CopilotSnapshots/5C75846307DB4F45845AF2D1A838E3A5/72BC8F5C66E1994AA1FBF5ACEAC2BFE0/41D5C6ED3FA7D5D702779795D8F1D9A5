@model HDKmall.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Đăng ký - HDKmall";
}

<div class="container" style="padding-top:40px;padding-bottom:60px;max-width:480px">
    <div class="breadcrumb" style="margin-bottom:24px">
        <a href="/">Trang chủ</a>
        <span class="breadcrumb-sep">›</span>
        <span id="breadcrumb-label">Đăng ký</span>
    </div>

    <div id="auth-forms">
        <!-- Tabs -->
        <div class="auth-tabs" style="display: flex; gap: 10px; margin-bottom: 20px;">
            <a asp-action="Login" class="auth-tab" style="flex:1; text-align:center; text-decoration:none; padding:10px; border-bottom: 2px solid #ccc; color:#666;">Đăng nhập</a>
            <a asp-action="Register" class="auth-tab active" style="flex:1; text-align:center; text-decoration:none; padding:10px; border-bottom: 2px solid var(--primary); font-weight:bold; color:var(--primary);">Đăng ký</a>
        </div>

        <!-- Register Form -->
        <div id="form-register" class="auth-form-panel">
            <h2 class="auth-title">Tạo tài khoản mới</h2>
            <p class="auth-subtitle">Đăng ký để mua sắm và theo dõi đơn hàng dễ dàng hơn.</p>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="form-error text-danger mb-3" style="color:red;"></div>
                
                <div class="form-group mb-3">
                    <label class="form-label" asp-for="FullName">Họ và tên <span class="required">*</span></label>
                    <input asp-for="FullName" class="form-input" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="form-error" style="color:red; display:block; margin-top:5px;"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label class="form-label" asp-for="Email">Email <span class="required">*</span></label>
                    <input asp-for="Email" class="form-input" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="form-error" style="color:red; display:block; margin-top:5px;"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label class="form-label" asp-for="PhoneNumber">Số điện thoại <span class="required">*</span></label>
                    <input asp-for="PhoneNumber" class="form-input" placeholder="09xxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="form-error" style="color:red; display:block; margin-top:5px;"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label class="form-label" asp-for="Password">Mật khẩu <span class="required">*</span></label>
                    <div class="input-password-wrapper" style="position: relative;">
                        <input asp-for="Password" class="form-input" placeholder="Ít nhất 6 ký tự" id="reg-password" />
                        <button type="button" class="toggle-password" onclick="togglePassword('reg-password', this)" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); border: none; background: transparent; cursor: pointer;">👁</button>
                    </div>
                    <span asp-validation-for="Password" class="form-error" style="color:red; display:block; margin-top:5px;"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label class="form-label" asp-for="ConfirmPassword">Xác nhận mật khẩu <span class="required">*</span></label>
                    <div class="input-password-wrapper" style="position: relative;">
                        <input asp-for="ConfirmPassword" class="form-input" placeholder="Nhập lại mật khẩu" id="reg-confirm" />
                        <button type="button" class="toggle-password" onclick="togglePassword('reg-confirm', this)" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); border: none; background: transparent; cursor: pointer;">👁</button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="form-error" style="color:red; display:block; margin-top:5px;"></span>
                </div>
                
                <button type="submit" class="btn-primary btn-full w-100" style="padding: 12px; background: var(--primary); color: white; border: none; border-radius: 4px; cursor: pointer;">Đăng ký</button>
            </form>

            <div class="auth-footer-text mt-3 text-center" style="margin-top: 20px;">
                Đã có tài khoản?
                <a asp-action="Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁';
      }
    }
</script>