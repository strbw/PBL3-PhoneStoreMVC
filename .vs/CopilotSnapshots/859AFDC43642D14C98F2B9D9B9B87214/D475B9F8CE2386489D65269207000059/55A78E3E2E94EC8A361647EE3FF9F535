using Microsoft.EntityFrameworkCore;

namespace HDKmall.Models
{
    public class ApplicationDbContext : DbContext
    {
        public ApplicationDbContext(DbContextOptions<ApplicationDbContext> options) : base(options)
        {
        }

        public DbSet<User> Users { get; set; }
        public DbSet<Product> Products { get; set; }
        public DbSet<Role> Roles { get; set; }

        protected override void OnModelCreating(ModelBuilder modelBuilder)
        {
            base.OnModelCreating(modelBuilder);
            
            // Seed Data for Roles
            modelBuilder.Entity<Role>().HasData(
                new Role { RoleId = 1, RoleName = "Admin" },
                new Role { RoleId = 2, RoleName = "Customer" }
            );

            // Seed Data for an Admin User
            // Note: PasswordHash requires hashing, but if AccountService uses a specific hash, 
            // you might just need to put a plain string if it's stored plain, or replace with actual hash.
            // But let's verify how PasswordHash is generated
        }
    }
}