@model HDKmall.Models.ShoppingCart
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="main-content bg-light pb-5 pt-4">
    <div class="container">
        <!-- Progress Steps -->
        <div class="d-flex justify-content-center mb-5 d-none d-md-flex">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px; z-index: 1;">1</div>
                <div class="bg-primary" style="height: 4px; width: 100px; margin: 0 -5px;"></div>
                <div class="rounded-circle bg-primary border border-2 border-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm position-relative" style="width: 40px; height: 40px; z-index: 1;">
                    2
                    <span class="position-absolute top-100 mt-2 text-primary fw-bold text-nowrap" style="font-size: 14px;">Thanh toán</span>
                </div>
                <div class="bg-secondary" style="height: 4px; width: 100px; margin: 0 -5px; opacity: 0.3;"></div>
                <div class="rounded-circle bg-white border border-2 border-secondary text-secondary d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px; z-index: 1; opacity: 0.5;">3</div>
            </div>
        </div>
        <h2 class="section-title mb-4 d-md-none">Thanh toán</h2>

        <form asp-action="CreateOrder" asp-controller="Order" method="post" id="checkout-form">
            <div class="row gx-lg-5">
                <!-- Left Column: Shipping Info -->
                <div class="col-lg-7 mb-4 mb-lg-0">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-header bg-white py-3 px-4 border-bottom-0">
                            <h5 class="mb-0 fw-bold d-flex align-items-center">
                                <span class="fs-4 me-2">📍</span> Thông tin giao hàng
                            </h5>
                        </div>
                        <div class="card-body p-4 pt-1">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-medium">Họ và tên người nhận</label>
                                    <input type="text" class="form-control form-control-lg bg-light border-0" value="@User.Identity.Name" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-medium">Số điện thoại</label>
                                    <input type="tel" class="form-control form-control-lg border ps-3" placeholder="Nhập số điện thoại (*)" required>
                                </div>
                                <div class="col-12 mt-3">
                                    <label class="form-label text-muted small fw-medium">Tỉnh/Thành phố</label>
                                    <select class="form-select form-select-lg border" required>
                                        <option value="" selected disabled>Chọn Tỉnh/Thành phố</option>
                                        <option value="HN">Hà Nội</option>
                                        <option value="DN">Đà Nẵng</option>
                                        <option value="HCM">Hồ Chí Minh</option>
                                    </select>
                                </div>
                                <div class="col-12 mt-3">
                                    <label class="form-label text-muted small fw-medium">Địa chỉ cụ thể</label>
                                    <textarea class="form-control border p-3" name="address" rows="3" placeholder="Số nhà, tên đường, phường/xã, quận/huyện (*)" required></textarea>
                                </div>
                                <div class="col-12 mt-3">
                                    <label class="form-label text-muted small fw-medium">Ghi chú đơn hàng (Tùy chọn)</label>
                                    <textarea class="form-control border" rows="2" placeholder="Giao giờ hành chính, gọi trước khi giao..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="card-header bg-white py-3 px-4 border-bottom-0">
                            <h5 class="mb-0 fw-bold d-flex align-items-center">
                                <span class="fs-4 me-2">💳</span> Phương thức thanh toán
                            </h5>
                        </div>
                        <div class="card-body p-4 pt-1">
                            <!-- Hidden input for payment method -->
                            <input type="hidden" name="paymentMethod" id="paymentMethod" value="COD">
                            
                            <div class="payment-options d-flex flex-column gap-3">
                                <!-- Option 1: COD -->
                                <label class="payment-option position-relative cursor-pointer">
                                    <input type="radio" name="payment_method_display" value="COD" class="position-absolute opacity-0" checked onchange="document.getElementById('paymentMethod').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content transition-all">
                                        <div class="d-flex align-items-center">
                                            <div class="radio-custom me-3 border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(0); transition: transform 0.2s;"></div>
                                            </div>
                                            <div class="d-flex align-items-center flex-grow-1">
                                                <div class="bg-light rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 48px; border: 1px solid #eee;">
                                                    <span style="font-size: 24px; line-height: 1;">💵</span>
                                                </div>
                                                <div>
                                                    <div class="fw-bold mb-1">Thanh toán khi nhận hàng (COD)</div>
                                                    <div class="text-muted small">Thanh toán bằng tiền mặt khi giao hàng</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </label>

                                <!-- Option 2: VNPay -->
                                <label class="payment-option position-relative cursor-pointer">
                                    <input type="radio" name="payment_method_display" value="VNPAY" class="position-absolute opacity-0" onchange="document.getElementById('paymentMethod').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content transition-all">
                                        <div class="d-flex align-items-center">
                                            <div class="radio-custom me-3 border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(0); transition: transform 0.2s;"></div>
                                            </div>
                                            <div class="d-flex align-items-center flex-grow-1">
                                                <div class="bg-light rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 48px; border: 1px solid #eee;">
                                                    <img src="https://vnpay.vn/s1/vnpay/logo.svg" alt="VNPay" class="img-fluid" style="max-height: 24px;">
                                                </div>
                                                <div>
                                                    <div class="fw-bold mb-1">Thanh toán qua VNPAY</div>
                                                    <div class="text-muted small">Thẻ ATM nội địa, thẻ quốc tế hoặc ví VNPAY</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </label>

                                <!-- Option 3: MoMo -->
                                <label class="payment-option position-relative cursor-pointer">
                                    <input type="radio" name="payment_method_display" value="MOMO" class="position-absolute opacity-0" onchange="document.getElementById('paymentMethod').value = this.value;">
                                    <div class="card border-2 rounded-3 p-3 option-content transition-all">
                                        <div class="d-flex align-items-center">
                                            <div class="radio-custom me-3 border rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px;">
                                                <div class="radio-inner rounded-circle bg-primary" style="width:12px; height:12px; transform: scale(0); transition: transform 0.2s;"></div>
                                            </div>
                                            <div class="d-flex align-items-center flex-grow-1">
                                                <div class="bg-light rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 48px; border: 1px solid #eee;">
                                                    <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" alt="MoMo" class="img-fluid" style="max-height: 24px;">
                                                </div>
                                                <div>
                                                    <div class="fw-bold mb-1">Thanh toán qua Ví MoMo</div>
                                                    <div class="text-muted small">Mở ứng dụng MoMo để quét mã QR</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            </div>

                            <style>
                                .payment-option input:checked + .option-content {
                                    border-color: var(--bs-primary) !important;
                                    background-color: rgba(var(--bs-primary-rgb), 0.05);
                                }
                                .payment-option input:checked + .option-content .radio-custom {
                                    border-color: var(--bs-primary) !important;
                                }
                                .payment-option input:checked + .option-content .radio-inner {
                                    transform: scale(1) !important;
                                }
                                .cursor-pointer { cursor: pointer; }
                                .transition-all { transition: all 0.2s ease; }
                                .payment-option:hover .option-content {
                                    border-color: #dee2e6;
                                }
                                .payment-option input:checked:hover + .option-content {
                                    border-color: var(--bs-primary) !important;
                                }
                            </style>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Order Summary -->
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 80px;">
                        <div class="card-header bg-white py-3 px-4 border-bottom position-relative">
                            <h5 class="mb-0 fw-bold">Đơn hàng của bạn</h5>
                            <span class="position-absolute top-50 end-0 translate-middle-y me-4 badge bg-primary rounded-pill px-3 py-2">@(Model?.Items?.Count ?? 0) sản phẩm</span>
                        </div>
                        <div class="card-body p-4">
                            @if (Model != null && Model.Items != null)
                            {
                                <div class="order-items vstack gap-3 mb-4" style="max-height: 350px; overflow-y: auto;">
                                    @foreach (var item in Model.Items)
                                    {
                                        <div class="d-flex align-items-center bg-light p-2 rounded-3 border">
                                            <div class="position-relative me-3 bg-white p-1 rounded border border-light flex-shrink-0" style="width: 65px; height: 65px; display:flex; align-items:center;">
                                                <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/img/default.png" : item.Product.ImageUrl)" alt="@item.Product.Name" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-secondary border border-white" style="font-size: 0.7rem;">@item.Quantity</span>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <h6 class="mb-1 text-truncate fs-6 border-0 text-dark fw-bold">@item.Product.Name</h6>
                                            </div>
                                            <div class="text-end ms-2 flex-shrink-0">
                                                <div class="fw-bold text-danger">@((item.Product.Price * item.Quantity).ToString("N0"))₫</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Coupon Code -->
                            <div class="mb-4">
                                <label class="form-label text-muted small fw-medium">Mã giảm giá</label>
                                <div class="input-group input-group-lg">
                                    <input type="text" class="form-control fs-6" name="couponCode" placeholder="Nhập mã giảm giá..." style="text-transform: uppercase;">
                                    <button class="btn btn-dark px-4 fw-bold" type="button">Áp dụng</button>
                                </div>
                            </div>
                            
                            <hr class="border-secondary opacity-25 my-4">

                            @{
                                var subTotal = Model?.Items?.Sum(i => i.Product.Price * i.Quantity) ?? 0;
                                var shippingFee = 0; // Default or calculated
                                var discount = 0;
                                var totalAmount = subTotal + shippingFee - discount;
                            }

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-medium">@subTotal.ToString("N0")₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí giao hàng:</span>
                                <span>@(shippingFee == 0 ? "Miễn phí" : shippingFee.ToString("N0") + "₫")</span>
                            </div>
                            @if (discount > 0)
                            {
                                <div class="d-flex justify-content-between mb-2 text-success">
                                    <span>Giảm giá:</span>
                                    <span>-@discount.ToString("N0")₫</span>
                                </div>
                            }
                            
                            <div class="bg-light p-3 rounded-3 mt-4 mb-4 border">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-5 fw-bold">Tổng cộng:</span>
                                    <div class="text-end">
                                        <span class="fs-3 fw-bold text-danger d-block lh-1">@totalAmount.ToString("N0")₫</span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm d-flex align-items-center justify-content-center fs-5 transition-all">
                                <span class="me-2">💳</span> ĐT HÀNG NGAY
                            </button>
                            <p class="text-center text-muted small mt-3 mb-0">
                                Bằng việc đặt hàng, bạn đồng ý với <a href="#" class="text-primary text-decoration-none">Điều khoản sử dụng</a> của chúng tôi.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
