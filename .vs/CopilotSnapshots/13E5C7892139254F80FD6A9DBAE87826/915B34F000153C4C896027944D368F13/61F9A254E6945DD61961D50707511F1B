@model ProductDetailVM

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    <div class="row">
        <!-- Images -->
        <div class="col-md-5">
            <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Name" style="max-height: 500px; object-fit: cover;">
        </div>

        <!-- Product Info -->
        <div class="col-md-7">
            <h1 class="mb-3">@Model.Name</h1>

            <!-- Rating -->
            <div class="mb-3">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <span class="badge bg-warning">
                            ⭐ @Model.AverageRating.ToString("F1") 
                        </span>
                        <span class="text-muted">(@Model.TotalReviews đánh giá)</span>
                    </div>
                </div>
            </div>

            <!-- Category & Brand -->
            <p class="text-muted">
                <strong>Danh Mục:</strong> @Model.Category?.Name<br>
                <strong>Thương Hiệu:</strong> @Model.Brand?.Name
            </p>

            <hr>

            <!-- Price -->
            <h3 class="text-danger mb-3">₫@Model.BasePrice.ToString("N0")</h3>

            <!-- Description -->
            <p>@Model.Description</p>

            <!-- Variants -->
            @if (Model.Variants.Any())
            {
                <div class="mb-4">
                    <h5>Chọn Phiên Bản</h5>

                    <div class="mb-3">
                        <label class="form-label">Màu Sắc:</label>
                        <select class="form-select" id="colorSelect">
                            <option value="">-- Chọn Màu --</option>
                            @foreach (var variant in Model.Variants.DistinctBy(v => v.Color))
                            {
                                <option value="@variant.Id">@variant.Color</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Dung Lượng:</label>
                        <select class="form-select" id="capacitySelect">
                            <option value="">-- Chọn Dung Lượng --</option>
                            @foreach (var variant in Model.Variants.DistinctBy(v => v.Capacity))
                            {
                                <option value="@variant.Id">@variant.Capacity</option>
                            }
                        </select>
                    </div>

                    <div class="alert alert-info" id="variantInfo">
                        Vui lòng chọn phiên bản
                    </div>
                </div>
            }

            <div class="mb-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Số Lượng:</label>
                    <div class="input-group" style="max-width: 150px;">
                        <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('quantity').value = Math.max(1, parseInt(document.getElementById('quantity').value) - 1); document.getElementById('selectedQuantity').value = document.getElementById('quantity').value;">-</button>
                        <input type="number" class="form-control text-center bg-white" id="quantity" value="1" min="1" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('quantity').value = parseInt(document.getElementById('quantity').value) + 1; document.getElementById('selectedQuantity').value = document.getElementById('quantity').value;">+</button>
                    </div>
                </div>

                <form method="post" asp-controller="Cart" asp-action="Add">
                    <input type="hidden" name="productId" value="@Model.Id">
                    <input type="hidden" name="variantId" id="selectedVariantId" value="0">
                    <input type="hidden" name="quantity" id="selectedQuantity" value="1">

                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold py-3 fs-5 rounded-pill shadow-sm">
                        <i class="bi bi-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                    </button>
                </form>
            </div>

            <hr>

            <!-- Share -->
            <div>
                <strong>Chia sẻ:</strong>
                <a href="#" class="btn btn-sm btn-outline-primary">Facebook</a>
                <a href="#" class="btn btn-sm btn-outline-info">Twitter</a>
            </div>
        </div>
    </div>

    <hr class="my-5">

    <!-- Reviews Section -->
    <div class="row">
        <div class="col-md-8">
            <h3 class="mb-4">📝 Đánh Giá &amp; Bình Luận</h3>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Viết Đánh Giá</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-controller="Review" asp-action="Add">
                            <input type="hidden" name="productId" value="@Model.Id">

                            <div class="mb-3">
                                <label class="form-label">Đánh Giá (Sao)</label>
                                <div class="rating-selector">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <input type="radio" name="rating" value="@i" id="rating_@i" style="display:none;">
                                        <label for="rating_@i" style="cursor: pointer; font-size: 24px; margin-right: 5px;">⭐</label>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Bình Luận</label>
                                <textarea class="form-control" name="comment" rows="4" placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này..." required></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary">Gửi Đánh Giá</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <strong>Lưu Ý:</strong> 
                    <a href="@Url.Action("Login", "Account")">Đăng nhập</a> để viết đánh giá sản phẩm.
                </div>
            }

            <!-- Existing Reviews -->
            <div id="reviewsList">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@review.UserName</h6>
                                        <div class="mb-2">
                                            @for (int i = 0; i < review.Rating; i++)
                                            {
                                                <span style="color: #ffc107;">⭐</span>
                                            }
                                        </div>
                                        <p class="mb-2">@review.Comment</p>
                                        <small class="text-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info">
                        Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Thông Tin Sản Phẩm</h5>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Danh Mục:</strong> <a href="@Url.Action("Index", "Product", new { categoryId = Model.CategoryId })">@Model.Category?.Name</a><br>
                        <strong>Thương Hiệu:</strong> <a href="@Url.Action("Index", "Product", new { brandId = Model.BrandId })">@Model.Brand?.Name</a>
                    </p>

                    <hr>

                    <h6>Đánh Giá Chung</h6>
                    <div class="text-center">
                        <h2 class="text-warning mb-0">⭐ @Model.AverageRating.ToString("F1")</h2>
                        <small class="text-muted">(@Model.TotalReviews đánh giá)</small>
                    </div>

                    @if (Model.Variants.Any())
                    {
                        <hr>
                        <h6>Số Lượng Có Sẵn</h6>
                        var totalStock = Model.Variants.Sum(v => v.Stock);
                        <p>
                            @if (totalStock > 0)
                            {
                                <span class="badge bg-success">Có Hàng (@totalStock)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết Hàng</span>
                            }
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Quantity controls
    document.getElementById('increaseBtn').addEventListener('click', function() {
        const qty = document.getElementById('quantity');
        qty.value = parseInt(qty.value) + 1;
        document.getElementById('selectedQuantity').value = qty.value;
    });

    document.getElementById('decreaseBtn').addEventListener('click', function() {
        const qty = document.getElementById('quantity');
        if (parseInt(qty.value) > 1) {
            qty.value = parseInt(qty.value) - 1;
            document.getElementById('selectedQuantity').value = qty.value;
        }
    });

    // Update quantity when input changes
    document.getElementById('quantity').addEventListener('change', function() {
        document.getElementById('selectedQuantity').value = this.value;
    });

    // Variant selection
    document.getElementById('colorSelect').addEventListener('change', updateVariantInfo);
    document.getElementById('capacitySelect').addEventListener('change', updateVariantInfo);

    function updateVariantInfo() {
        const colorId = document.getElementById('colorSelect').value;
        const capacityId = document.getElementById('capacitySelect').value;

        if (colorId && capacityId) {
            document.getElementById('selectedVariantId').value = colorId;
            document.getElementById('variantInfo').innerHTML = 'Phiên bản được chọn';
        }
    }
</script>
