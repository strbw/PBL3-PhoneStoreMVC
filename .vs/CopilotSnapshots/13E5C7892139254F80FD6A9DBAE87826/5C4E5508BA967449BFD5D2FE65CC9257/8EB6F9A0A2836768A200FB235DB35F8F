@model HDKmall.ViewModels.PaginationVM
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="main-content">
    <div class="container my-5">
        <h2 class="section-title mb-4">Kết quả tìm kiếm sản phẩm</h2>
        
        <div class="row">
            <!-- Filter Sidebar -->
            <div class="col-lg-3 d-none d-lg-block">
                <div class="card p-3 shadow-sm border-0">
                    <h5 class="mb-3">Danh mục</h5>
                    <ul class="list-unstyled">
                        @if(ViewBag.Categories != null)
                        {
                            foreach(var cat in ViewBag.Categories)
                            {
                                <li><a href="/Product?categoryId=@cat.Id" class="text-decoration-none text-dark">@cat.Name</a></li>
                            }
                        }
                    </ul>
                    <hr />
                    <h5 class="mb-3">Thương hiệu</h5>
                    <ul class="list-unstyled">
                        @if(ViewBag.Brands != null)
                        {
                            foreach(var brand in ViewBag.Brands)
                            {
                                <li><a href="/Product?brandId=@brand.Id" class="text-decoration-none text-dark">@brand.Name</a></li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="col-lg-9">
                <div class="row g-4">
                    @if (Model != null && Model.Products != null && Model.Products.Any())
                    {
                        foreach (var item in Model.Products)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="card h-100 shadow-sm border-0 product-card position-relative">
                                    <span class="badge bg-danger position-absolute" style="top:10px; right:10px; z-index:1;">Sale</span>
                                    <div class="text-center p-3">
                                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/Product_Default.jpg" : item.ImageUrl)" class="img-fluid" alt="@item.Name" style="max-height:180px; object-fit:contain;">
                                    </div>
                                    <div class="card-body d-flex flex-column">
                                        <div class="text-muted small mb-1">@item.BrandName</div>
                                        <h5 class="card-title fs-6 lh-sm mb-2"><a href="/Product/Detail/@item.Id" class="text-decoration-none text-dark">@item.Name</a></h5>
                                        <div class="mt-auto">
                                            <div class="d-flex align-items-baseline mb-2">
                                                <span class="fs-5 fw-bold text-danger me-2">@item.Price.ToString("N0")₫</span>
                                            </div>
                                            <div class="d-flex mb-3 text-warning small">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    if (i < Math.Round(item.AverageRating))
                                                    {
                                                        <i class="bi bi-star-fill">★</i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star">☆</i>
                                                    }
                                                }
                                                <span class="text-muted ms-2">(@item.ReviewCount)</span>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <a href="/Product/Detail/@item.Id" class="btn btn-outline-primary fw-bold text-nowrap rounded-pill px-3">Chi tiết</a>
                                                <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1 mx-2">
                                                    <input type="hidden" name="productId" value="@item.Id" />
                                                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold text-nowrap">
                                                        <i class="bi bi-cart-plus me-1"></i> Mua
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 mt-5 text-center">
                            <div class="p-5 bg-white rounded shadow-sm border border-light">
                                <div style="font-size: 4rem; color: #ccc;" class="mb-3">😞</div>
                                <h4>Không tìm thấy sản phẩm nào!</h4>
                                <p class="text-muted">Vui lòng thử lại với các tiêu chí tìm kiếm khác hoặc quay lại trang chủ.</p>
                                <a href="/" class="btn btn-primary px-4 py-2 mt-2 rounded-pill">Về Trang Chủ</a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model != null && Model.TotalPages > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" href="/Product?page=@(Model.PageNumber - 1)">Trang trước</a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="/Product?page=@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" href="/Product?page=@(Model.PageNumber + 1)">Trang sau</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>
