using HDKmall.BLL.Interfaces;
using HDKmall.ViewModels;
using Microsoft.AspNetCore.Mvc;

namespace HDKmall.Controllers.Api
{
    [ApiController]
    [Route("api/[controller]")]
    public class ProductsController : ControllerBase
    {
        private readonly IProductService _productService;
        private readonly IProductSearchService _searchService;

        public ProductsController(IProductService productService, IProductSearchService searchService)
        {
            _productService = productService;
            _searchService = searchService;
        }

        // GET: api/products
        [HttpGet]
        public IActionResult GetAll([FromQuery] int? categoryId = null, [FromQuery] int? brandId = null, [FromQuery] string search = null)
        {
            try
            {
                var filter = new ProductFilterVM
                {
                    CategoryId = categoryId,
                    BrandId = brandId,
                    PageNumber = 1,
                    PageSize = 100,
                    SearchKeyword = search
                };

                var result = _searchService.SearchProducts(filter);
                
                var products = result.Items.Select(p => new
                {
                    id = p.Id,
                    name = p.Name,
                    slug = p.Slug ?? p.Name?.ToLower().Replace(" ", "-") ?? "",
                    brand = p.BrandName ?? "",
                    category = p.CategorySlug ?? "",
                    categoryName = p.CategoryName ?? "",
                    price = p.Price,
                    originalPrice = p.OriginalPrice ?? p.Price,
                    discount = p.Discount ?? 0,
                    description = p.ShortDescription ?? p.FullDescription ?? "",
                    image = p.ImageUrl ?? "",
                    rating = p.AverageRating ?? 0,
                    reviewCount = p.ReviewCount ?? 0,
                    isFeatured = p.IsFeatured ?? false,
                    isOnSale = (p.Discount ?? 0) > 0,
                    isHot = p.IsHot ?? false
                }).ToList();

                return Ok(products);
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { error = ex.Message });
            }
        }

        // GET: api/products/{id}
        [HttpGet("{id}")]
        public IActionResult GetById(int id)
        {
            try
            {
                var product = _productService.GetProductById(id);
                if (product == null)
                    return NotFound(new { error = "Sản phẩm không tìm thấy" });

                var result = new
                {
                    id = product.Id,
                    name = product.Name,
                    slug = product.Slug ?? product.Name?.ToLower().Replace(" ", "-") ?? "",
                    brand = product.BrandName ?? "",
                    category = product.CategorySlug ?? "",
                    categoryName = product.CategoryName ?? "",
                    price = product.Price,
                    originalPrice = product.OriginalPrice ?? product.Price,
                    discount = product.Discount ?? 0,
                    description = product.FullDescription ?? product.ShortDescription ?? "",
                    image = product.ImageUrl ?? "",
                    rating = product.AverageRating ?? 0,
                    reviewCount = product.ReviewCount ?? 0,
                    isFeatured = product.IsFeatured ?? false,
                    isOnSale = (product.Discount ?? 0) > 0,
                    isHot = product.IsHot ?? false
                };

                return Ok(result);
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { error = ex.Message });
            }
        }
    }
}
